{
  "name": "@scheduling/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=../../.env --import tsx src/main.ts",
    "start": "node --env-file=../../.env dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build -w @scheduling/contracts",
    "test": "echo \"tests removed\"",
    "db:migrate": "node --env-file=../../.env --import tsx src/database/run-migrations.ts",
    "admin:bootstrap": "node --env-file=../../.env --import tsx src/admin-auth/bootstrap-admin.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.3",
    "@node-rs/argon2": "^2.0.2",
    "@scheduling/contracts": "*",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "jose": "^6.0.10",
    "kysely": "^0.28.2",
    "mysql2": "^3.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
