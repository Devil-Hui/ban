{
  "name": "smart-scheduling-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "check:workspace": "node tools/verify-workspace.mjs",
    "env:init": "node tools/init-local-env.mjs",
    "build": "npm run build -w @scheduling/contracts && npm run build -w @scheduling/api",
    "test": "npm run test -w @scheduling/contracts && npm run test -w @scheduling/api && npm run test -w @scheduling/notification-worker && npm run test -w @scheduling/miniprogram",
    "typecheck": "npm run build -w @scheduling/contracts && npm run typecheck -w @scheduling/contracts && npm run typecheck -w @scheduling/api",
    "infra:up": "docker compose up -d mysql redis minio",
    "infra:down": "docker compose down",
    "infra:ps": "docker compose ps",
    "db:migrate": "npm run db:migrate -w @scheduling/api",
    "admin:bootstrap": "npm run admin:bootstrap -w @scheduling/api",
    "seed:scenarios": "npm run build && node --env-file=.env tools/seed-scenario-users.mjs",
    "dev:api": "npm run dev -w @scheduling/api",
    "smoke:foundation": "node tools/smoke-foundation.mjs",
    "test:scheduler": "echo \"tests removed\"",
    "test:lifecycle-worker": "node --env-file=.env tools/test-lifecycle-worker.mjs",
    "smoke:scheduling": "node tools/smoke-scheduling-flow.mjs",
    "check:miniprogram-devtools": "node tools/check-miniprogram-devtools.mjs",
    "openapi:lint": "redocly lint docs/openapi.yaml"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.5"
  }
}
