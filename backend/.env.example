# ============ 后端运行环境变量示例 ============
# 复制为 .env 后按需修改；所有项均有默认值，缺省也能以内存模式(DB_MODE=memory)跑通测试。

# ---- 运行环境 ----
# development | staging | production
NODE_ENV=development
# 仓储实现：memory(内存，无需数据库，用于本地开发与测试) | mysql(生产/联调)
DB_MODE=memory
# 服务端口（本地 Express 使用）
PORT=3000

# ---- 数据库连接（仅 DB_MODE=mysql 时生效，支持通过环境变量灵活切换连接地址）----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=scheduling
# 连接池
DB_POOL_LIMIT=10
DB_CONNECT_TIMEOUT=10000
# 字符集与时区（统一 UTC，应用层按客户端时区展示）
DB_CHARSET=utf8mb4
DB_TIMEZONE=+00:00

# ---- 鉴权 ----
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_EXPIRE=2h
JWT_REFRESH_EXPIRE=14d

# ---- 微信小程序 ----
WX_APPID=
WX_SECRET=
# 说明：本项目不接入微信支付，无需商户号/支付密钥
# 订阅消息模板 ID（微信公众平台 → 订阅消息；留空则仅站内 inbox，不调微信下发）
WX_TMPL_TASK_PUBLISHED=
WX_TMPL_DEADLINE_REMIND=
# 截止前提醒提前小时数（默认 24）
DEADLINE_REMIND_HOURS=24

# ---- H5 运维后台 ----
H5_ADMIN_USER=admin
H5_ADMIN_PASS=admin123

# ---- 通用 ----
CORS_ORIGINS=*
RATE_LIMIT_MAX=120
# 分享预览 token 有效期（秒），默认 7 天
SHARE_TOKEN_TTL=604800
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
REQUEST_TIMEOUT_MS=8000
