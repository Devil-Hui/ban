@import '../../common-styles.wxss';
/* ============================================ */
/*  我的日程 - 样式表                            */
/* ============================================ */

/* ---- 页面容器 ---- */
.schedule-page {
  padding: 24rpx 24rpx 60rpx;
}

/* ---- 顶部栏 ---- */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.eyebrow {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--brand, #1e9e5a);
  text-transform: uppercase;
}

.title {
  font-size: 38rpx;
  font-weight: 750;
  color: #1f2a24;
  margin-top: 6rpx;
}

.subtitle {
  font-size: 23rpx;
  color: #7b8780;
  margin-top: 6rpx;
}

.month-switch {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #e8f7ef;
  border-radius: 20rpx;
  color: var(--brand, #1e9e5a);
  font-size: 26rpx;
  font-weight: 600;
}

/* ---- 视图切换 ---- */
.mode-switch {
  display: flex;
  padding: 6rpx;
  background: #eaf0ec;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.mode {
  flex: 1;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #7b8780;
  font-size: 24rpx;
  border-radius: 9rpx;
  transition: all 0.2s ease;
}

.mode.active {
  color: #1f2a24;
  font-weight: 600;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* ---- 列表视图 ---- */
.assignment-list {
  margin-bottom: 18rpx;
  padding: 20rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
  border-bottom: 1rpx solid #eaf0ec;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 650;
  color: #1f2a24;
}

.mini-label {
  font-size: 21rpx;
  color: #9ba79f;
}

.assignment {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  transition: background 0.15s ease;
}

.assignment:active {
  background: #f5f7f6;
}

.date-badge {
  width: 86rpx;
  height: 86rpx;
  border-radius: 16rpx;
  background: #e8f7ef;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: none;
}

.date-badge text:first-child {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e9e5a;
  font-variant-numeric: tabular-nums;
}

.date-badge text:last-child {
  font-size: 18rpx;
  color: #5da87a;
  margin-top: 2rpx;
}

.assignment-copy {
  flex: 1;
  min-width: 0;
}

.task-name {
  font-size: 28rpx;
  font-weight: 650;
  color: #1f2a24;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* ============================================ */
/*  日历视图                                     */
/* ============================================ */

.calendar-board {
  padding: 20rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
}

/* ---- 月份导航 ---- */
.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-arrows {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7f6;
  transition: background 0.15s ease;
}

.nav-btn:active {
  background: #eaf0ec;
}

.calendar-month-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a24;
  min-width: 200rpx;
  text-align: center;
}

.today-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #e8f7ef;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #1e9e5a;
  font-weight: 600;
  transition: opacity 0.15s ease;
}

.today-btn:active {
  opacity: 0.7;
}

.today-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* ---- 星期头 ---- */
.calendar-week {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #eaf0ec;
  margin-bottom: 10rpx;
}

.weekday-item {
  padding: 10rpx 0;
  text-align: center;
  font-size: 21rpx;
  font-weight: 600;
  color: #7b8780;
}

.weekday-item.weekend {
  color: #c3cbc6;
}

/* ---- 日期网格 ---- */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx 0;
}

.calendar-cell {
  position: relative;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  transition: all 0.15s ease;
}

.calendar-cell:active {
  background: #f5f7f6;
}

.cell-day {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f2a24;
  position: relative;
  z-index: 1;
}

.calendar-cell.outside .cell-day {
  color: #c3cbc6;
}

/* 选中状态 */
.calendar-cell.selected {
  background: #1e9e5a;
}

.calendar-cell.selected .cell-day {
  color: #fff;
  font-weight: 650;
}

/* 今日标记 */
.calendar-cell.today:not(.selected) .cell-day {
  color: #1e9e5a;
  font-weight: 700;
}

.today-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 2rpx solid #1e9e5a;
}

/* 班次标记点 */
.shift-dot {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1e9e5a;
}

.shift-dot.selected {
  background: #fff;
}

/* ---- 选中日期排班详情 ---- */
.selected-schedule {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  animation: fadeInUp 0.25s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.empty-schedule {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: #9ba79f;
}

.no-data-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  background: #f9fbfa;
}

/* ---- 通用面板 ---- */
.surface {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}
