.state-box { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; padding: 80rpx 32rpx; text-align: center; color: var(--muted); font-size: 27rpx; } .state-box .t-icon { margin-bottom: 8rpx; } .schedule-page { padding-top: 24rpx; }.month-switch { display: flex; align-items: center; gap: 8rpx; color: var(--brand); font-size: 26rpx; font-weight: 600; }.task-strip { padding: 22rpx 24rpx; display: flex; justify-content: space-between; align-items: center; }.task-name { font-size: 28rpx; font-weight: 650; margin-top: 7rpx; }.deadline { display: flex; flex-direction: column; align-items: flex-end; gap: 7rpx; color: var(--subtle); font-size: 20rpx; }.time-left { color: var(--warning); font-size: 25rpx; font-weight: 650; font-variant-numeric: tabular-nums; }.mode-switch { display: flex; padding: 6rpx; background: #eaf0ec; border-radius: 12rpx; margin: 20rpx 0; }.mode { flex: 1; height: 62rpx; display: flex; align-items: center; justify-content: center; gap: 8rpx; color: var(--subtle); font-size: 24rpx; border-radius: 9rpx; }.mode.active { color: var(--ink); font-weight: 600; background: #fff; }.date-head { display: flex; align-items: center; padding: 0 8rpx 12rpx; }.time-column { width: 102rpx; flex: none; display: flex; flex-direction: column; justify-content: center; color: var(--subtle); font-size: 20rpx; }.date-cell { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 7rpx; }.weekday { color: var(--muted); font-size: 20rpx; }.date { width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; }.date.today { color: #fff; background: var(--brand); }.grid { overflow: hidden; padding: 8rpx; }.slot-row { display: flex; min-height: 84rpx; align-items: center; border-bottom: 1rpx solid var(--line); }.slot-row:last-child { border-bottom: 0; }.slot-label { margin-top: 6rpx; color: var(--muted); font-size: 18rpx; }.slot-cell { flex: 1; height: 58rpx; margin: 5rpx; border-radius: 9rpx; background: #edf1ee; display: flex; align-items: center; justify-content: center; }.slot-cell.available { background: #8ed9a6; }.slot-cell.preferred { background: #20a95d; }.slot-cell.unavailable { background: #e87968; }.legend { display: flex; justify-content: space-between; margin: 20rpx 6rpx 24rpx; color: var(--subtle); font-size: 20rpx; }.legend-dot { display: inline-block; width: 14rpx; height: 14rpx; border-radius: 4rpx; margin-right: 6rpx; }.legend-dot.off { background: #edf1ee; }.legend-dot.available { background: #8ed9a6; }.legend-dot.preferred { background: #20a95d; }.legend-dot.unavailable { background: #e87968; }.schedule-actions { display: flex; gap: 14rpx; }.schedule-actions t-button:last-child { flex: 1; }.assignment-list { padding: 0 24rpx; }.assignment { display: flex; align-items: center; gap: 18rpx; padding: 24rpx 0; border-bottom: 1rpx solid var(--line); }.date-badge { width: 72rpx; height: 72rpx; border-radius: 14rpx; background: var(--brand-soft); color: var(--brand); display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 19rpx; }.date-badge text:first-child { font-size: 28rpx; font-weight: 700; }.assignment-copy { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }.confirmed { background: #eef2ef; color: var(--subtle); }
.calendar-board { padding: 20rpx; margin-bottom: 18rpx; }.calendar-title { margin-bottom: 18rpx; text-align: center; font-size: 27rpx; font-weight: 650; }.calendar-week,.calendar-grid { display: grid; grid-template-columns: repeat(7,1fr); }.calendar-week text { padding: 10rpx 0; color: var(--muted); text-align: center; font-size: 20rpx; }.calendar-cell { position: relative; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 8rpx; color: var(--ink); font-size: 22rpx; }.calendar-cell.outside { color: #c3cbc6; }.calendar-cell.selected { background: var(--brand); color: #fff; }.shift-dot { position: absolute; bottom: 7rpx; width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--brand); }.calendar-cell.selected .shift-dot { background: #fff; }.calendar-empty { padding: 36rpx 0; color: var(--muted); text-align: center; font-size: 22rpx; }
