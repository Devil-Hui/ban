<view class="page schedule-page"><view class="topbar"><view><view class="eyebrow">MY SCHEDULE</view><view class="title">我的日程</view><view class="subtitle">只显示已发布且分配给你的班次</view></view><view class="month-switch"><t-icon name="calendar" size="34rpx" color="#1e9e5a" /><text>{{assignments.length}} 人次</text></view></view><view class="mode-switch"><view class="mode {{mode === 'list' ? 'active' : ''}}" data-mode="list" bindtap="setMode"><t-icon name="view-list" size="28rpx" />列表</view><view class="mode {{mode === 'calendar' ? 'active' : ''}}" data-mode="calendar" bindtap="setMode"><t-icon name="calendar" size="28rpx" />日历</view></view><view wx:if="{{loading}}" class="state-box">正在加载我的班次...</view><view wx:elif="{{!assignments.length}}" class="state-box surface"><t-icon name="calendar" size="64rpx" color="#9ba79f" /><text>暂无已发布班次</text><text class="mini-label">完成可用时间填写后，发布结果会显示在这里</text></view><block wx:else><block wx:if="{{mode === 'list'}}"><view wx:for="{{grouped}}" wx:key="date" class="assignment-list surface"><view class="section-head"><text class="section-title">{{item.label}}</text><text class="mini-label">{{item.items.length}} 人次</text></view><view wx:for="{{item.items}}" wx:key="id" class="assignment" data-task-id="{{item.taskId}}" bindtap="openTask"><view class="date-badge"><text>{{item.startTime}}</text><text>班次</text></view><view class="assignment-copy"><text class="task-name">{{item.taskTitle}}</text><text class="mini-label">{{item.groupName}} · {{item.startTime}} - {{item.endTime}}</text></view><t-icon name="chevron-right" size="28rpx" color="#9ba79f" /></view></view></block><block wx:else><view class="calendar-board surface"><view class="calendar-title">{{monthLabel}}</view><view class="calendar-week"><text wx:for="{{weekdays}}" wx:key="*this">{{item}}</text></view><view class="calendar-grid"><view wx:for="{{calendarDays}}" wx:key="date" class="calendar-cell {{item.inMonth ? '' : 'outside'}} {{selectedDate === item.date ? 'selected' : ''}}" data-date="{{item.date}}" bindtap="selectDate"><text>{{item.day}}</text><view wx:if="{{item.items.length}}" class="shift-dot"></view></view></view></view><view class="assignment-list surface"><view class="section-head"><text class="section-title">{{selectedDate || '选择日期'}}</text><text class="mini-label">{{selectedItems.length}} 人次</text></view><view wx:if="{{!selectedItems.length}}" class="calendar-empty">当天没有班次</view><view wx:for="{{selectedItems}}" wx:key="id" class="assignment" data-task-id="{{item.taskId}}" bindtap="openTask"><view class="date-badge"><text>{{item.startTime}}</text><text>班次</text></view><view class="assignment-copy"><text class="task-name">{{item.taskTitle}}</text><text class="mini-label">{{item.groupName}} · {{item.startTime}} - {{item.endTime}}</text></view><t-icon name="chevron-right" size="28rpx" color="#9ba79f" /></view></view></block></block></view>
