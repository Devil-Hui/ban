/* ===== me-page 企业级「我的」===== */
.me-page { padding-bottom: calc(48rpx + env(safe-area-inset-bottom)); }

/* ===== 头部信息卡 ===== */
.profile-card { margin: 0 20rpx 20rpx; padding: 32rpx 28rpx 20rpx; border-radius: 20rpx; }
.profile-top { display: flex; align-items: center; gap: 24rpx; }
.profile-avatar { position: relative; flex: none; padding: 5rpx; border-radius: 50%; background: linear-gradient(145deg,#e6f6eb,#f0faf3); }
.avatar-badge { position: absolute; right: -4rpx; top: -4rpx; min-width: 36rpx; height: 36rpx; line-height: 36rpx; border-radius: 18rpx; background: #df5c4c; color: #fff; font-size: 20rpx; font-weight: 700; text-align: center; padding: 0 8rpx; box-sizing: border-box; border: 3rpx solid #fff; }
.profile-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }
.greeting { font-size: 34rpx; font-weight: 700; color: var(--ink); line-height: 1.3; }
.profile-meta { display: flex; align-items: center; gap: 14rpx; }
.role-tag { display: inline-flex; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; color: var(--brand); background: #e6f6eb; }
.uid { font-size: 22rpx; color: var(--muted); font-variant-numeric: tabular-nums; }

/* 数据看板（头像下方通栏） */
.stats-row { display: flex; margin-top: 26rpx; padding: 22rpx 8rpx 4rpx; border-top: 1rpx solid var(--line); }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.stat-num { font-size: 40rpx; font-weight: 800; color: var(--ink); line-height: 1.1; font-variant-numeric: tabular-nums; }
.stat-num.brand { color: var(--brand); }
.stat-num.warn { color: #df5c4c; }
.stat-num.muted { color: var(--muted); }
.stat-label { font-size: 20rpx; color: var(--muted); font-weight: 500; }

/* ===== 快捷功能 4 列网格 ===== */
.section-label { margin: 32rpx 28rpx 14rpx; font-size: 24rpx; font-weight: 700; color: var(--ink); letter-spacing: .5rpx; display: flex; align-items: center; gap: 8rpx; }
.label-count { font-size: 20rpx; font-weight: 600; color: var(--brand); background: #e6f6eb; padding: 2rpx 12rpx; border-radius: 10rpx; }
.quick-grid { display: grid; grid-template-columns: repeat(4,1fr); margin: 0 20rpx; padding: 28rpx 8rpx; border-radius: 20rpx; }
.quick-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 8rpx 4rpx; }
.quick-item text { font-size: 22rpx; color: var(--ink); font-weight: 500; }
.q-icon { width: 84rpx; height: 84rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; }

/* ===== 今日班次 ===== */
.today-empty { display: flex; flex-direction: column; align-items: center; gap: 14rpx; padding: 48rpx 32rpx; border-radius: 20rpx; margin: 0 20rpx; text-align: center; color: var(--muted); font-size: 27rpx; }
.today-empty .t-icon { margin-bottom: 4rpx; }
.today-list { margin: 0 20rpx; border-radius: 20rpx; overflow: hidden; }
.today-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 26rpx; border-bottom: 1rpx solid var(--line); }
.today-item:last-child { border-bottom: 0; }
.today-time { flex: none; width: 110rpx; display: flex; flex-direction: column; gap: 2rpx; }
.time-num { font-size: 26rpx; font-weight: 700; color: var(--brand); font-variant-numeric: tabular-nums; }
.today-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.today-name { font-size: 28rpx; font-weight: 600; color: var(--ink); }
.today-meta { font-size: 22rpx; color: var(--muted); }

/* ===== 分组头像 ===== */
.group-avatar { width: 68rpx; height: 68rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; flex: none; }

/* ===== 菜单卡片 ===== */
.menu-card { margin: 0 20rpx; border-radius: 20rpx; overflow: hidden; }
.menu-row { display: flex; align-items: center; gap: 20rpx; padding: 26rpx 26rpx; background: #fff; }
.menu-row:active { background: #f5f7f5; }
.menu-divider { height: 1rpx; background: var(--line); margin: 0 26rpx 0 80rpx; }
.menu-icon { width: 68rpx; height: 68rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; flex: none; }
.icon-green  { background: #e6f6eb; } .icon-blue { background: #e6f0fc; } .icon-orange { background: #fff3e5; }
.icon-red    { background: #fde9e6; } .icon-gray  { background: #eef2ef; }
.menu-title { font-size: 29rpx; font-weight: 600; color: var(--ink); flex: 1; min-width: 0; }
.muted-text { color: var(--muted) !important; }
.menu-value { font-size: 24rpx; color: var(--subtle); max-width: 220rpx; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.menu-value.mono { font-variant-numeric: tabular-nums; }

/* ===== 帮助面板 ===== */
.sheet-mask { position: fixed; left:0;right:0;top:0;bottom:0; background:rgba(15,23,42,.45); z-index:999; display:flex; align-items:flex-end; }
.help-sheet { width:100%; max-height:75vh; overflow-y:auto; padding:0 32rpx calc(32rpx+env(safe-area-inset-bottom)); border-radius:24rpx 24rpx 0 0; background:#fff; box-sizing:border-box; }
.sheet-handle { display:flex; justify-content:center; padding:16rpx 0 8rpx; }
.handle-bar { width:64rpx; height:8rpx; border-radius:4rpx; background:#dde1de; }
.help-header { display:flex; align-items:center; justify-content:space-between; padding:12rpx 0 24rpx; }
.help-title { font-size:34rpx; font-weight:700; color:var(--ink); }
.help-section { margin-top:28rpx; }
.help-section-title { display:block; font-size:22rpx; font-weight:650; color:var(--muted); margin-bottom:14rpx; letter-spacing:1rpx; }
.help-contact-row { display:flex; align-items:center; justify-content:space-between; padding:22rpx 20rpx; background:#f8faf8; border-radius:14rpx; }
.help-contact-left { display:flex; align-items:center; gap:14rpx; }
.help-email { font-size:26rpx; color:var(--ink); }
.help-copy-btn { flex:none; padding:12rpx 28rpx; font-size:24rpx; color:var(--brand); background:#e6f6eb; border:0; border-radius:10rpx; line-height:1; }
.help-faq-item { padding:18rpx 0; border-bottom:1rpx solid var(--line); }
.help-faq-item:last-child { border-bottom:0; }
.help-faq-q,.help-faq-a { display:flex; align-items:flex-start; gap:12rpx; }
.help-faq-q { margin-bottom:8rpx; }
.help-faq-q text { font-size:26rpx; font-weight:600; color:var(--ink); line-height:1.5; }
.help-faq-a text { font-size:24rpx; color:var(--subtle); line-height:1.6; }
.faq-dot { flex:none; width:36rpx; height:36rpx; border-radius:8rpx; display:flex; align-items:center; justify-content:center; font-size:22rpx; font-weight:800; color:#fff; background:var(--brand); }
.faq-dot.answer { background:#e6f6eb; color:var(--brand); }
.help-footer { margin-top:32rpx; padding:20rpx 0; text-align:center; }
.help-footer text { display:block; font-size:22rpx; color:var(--muted); line-height:1.7; }

.version { margin-top:44rpx; text-align:center; color:var(--muted); font-size:20rpx; line-height:1.6; padding:16rpx; }

/* ===== 开发者面板 ===== */
.dev-mask { position:fixed; left:0;right:0;top:0;bottom:0; background:rgba(15,23,42,.45); z-index:1000; display:flex; align-items:flex-end; }
.dev-sheet { width:100%; padding:28rpx 28rpx calc(28rpx+env(safe-area-inset-bottom)); border-radius:24rpx 24rpx 0 0; background:#fff; box-sizing:border-box; }
.dev-title { font-size:32rpx; font-weight:700; margin-bottom:8rpx; }
.dev-row { display:flex; justify-content:space-between; gap:16rpx; padding:16rpx 0; border-bottom:1rpx solid var(--line); font-size:26rpx; }
.dev-value { color:var(--subtle); max-width:60%; text-align:right; }
.dev-value.api { font-size:20rpx; word-break:break-all; }
.dev-actions { display:flex; flex-wrap:wrap; gap:12rpx; margin-top:20rpx; }
.dev-actions .ui-btn { flex:1 1 40%; min-width:40%; width:auto; }
.ui-btn { margin:0; padding:0 20rpx; min-height:72rpx; line-height:72rpx; border-radius:14rpx; font-size:26rpx; font-weight:600; border:0; }
.ui-btn::after { border:0; } .ui-btn-primary { background:#1d4ed8; color:#fff; } .ui-btn-light { background:#eef2ff; color:#1e293b; } .ui-btn-sm { min-height:64rpx; line-height:64rpx; font-size:24rpx; }
