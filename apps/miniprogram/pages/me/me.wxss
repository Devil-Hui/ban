/* ===== me-page — 阿里/Ant Design 规范 ===== */
.me-page {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 头部形象区 ===== */
.header-banner {
  position: relative;
  margin: 0 0 24rpx;
  padding: 48rpx 32rpx 64rpx;
  background: linear-gradient(160deg, #1a8a52 0%, #20a95d 40%, #1e9e5a 100%);
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
}
.header-banner::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -24rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.header-inner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 1;
}
.profile-avatar {
  flex: none;
  padding: 5rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
}
.profile-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.greeting {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}
.profile-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.role-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.18);
}
.user-id {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  font-variant-numeric: tabular-nums;
}

/* ===== 数据看板（4 列）===== */
.stats-row {
  display: flex;
  margin: -32rpx 24rpx 28rpx;
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  padding: 24rpx 4rpx;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 4rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 20rpx;
  color: var(--muted);
  font-weight: 500;
}

/* ===== 区块标题 ===== */
.section-label {
  margin: 32rpx 28rpx 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 0.5rpx;
}

/* ===== 菜单卡片 ===== */
.menu-card {
  margin: 0 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 26rpx;
  background: #fff;
  transition: background 0.15s;
}
.menu-row:active {
  background: #f5f7f5;
}
.menu-divider {
  height: 1rpx;
  background: var(--line);
  margin: 0 26rpx 0 80rpx;
}

/* 左边彩色图标 */
.menu-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}
.icon-green  { background: #e6f6eb; }
.icon-blue   { background: #e6f0fc; }
.icon-orange { background: #fff3e5; }
.icon-red    { background: #fde9e6; }
.icon-gray   { background: #eef2ef; }

/* 中间文字 */
.menu-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--ink);
  flex: 1;
  min-width: 0;
}
.danger-text { color: #df5c4c !important; }

.menu-hint {
  font-size: 22rpx;
  color: var(--muted);
  flex: 1;
  min-width: 0;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.menu-value {
  font-size: 26rpx;
  color: var(--subtle);
  max-width: 220rpx;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.menu-value.mono {
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.5rpx;
}

/* ===== 版本号 ===== */
.version {
  margin-top: 44rpx;
  text-align: center;
  color: var(--muted);
  font-size: 20rpx;
  line-height: 1.6;
  padding: 16rpx;
}

/* ===== 开发者面板（不变）===== */
.dev-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.dev-sheet {
  width: 100%;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
  box-sizing: border-box;
}
.dev-title { font-size: 32rpx; font-weight: 700; margin-bottom: 8rpx; }
.dev-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--line); font-size: 26rpx; }
.dev-value { color: var(--subtle); max-width: 60%; text-align: right; }
.dev-value.api { font-size: 20rpx; word-break: break-all; }
.dev-actions { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.dev-actions .ui-btn { flex: 1 1 40%; min-width: 40%; width: auto; }
.ui-btn { margin: 0; padding: 0 20rpx; min-height: 72rpx; line-height: 72rpx; border-radius: 14rpx; font-size: 26rpx; font-weight: 600; border: 0; }
.ui-btn::after { border: 0; }
.ui-btn-primary { background: #1d4ed8; color: #fff; }
.ui-btn-light { background: #eef2ff; color: #1e293b; }
.ui-btn-sm { min-height: 64rpx; line-height: 64rpx; font-size: 24rpx; }
