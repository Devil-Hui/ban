/* ===== me-page -- 与首页画风一致的卡片式布局 ===== */
.me-page {
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 头部信息卡（白底卡片，不用彩色 banner）===== */
.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 28rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
}
.profile-avatar {
  flex: none;
  padding: 5rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #e6f6eb, #f0faf3);
}
.profile-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.greeting {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
}
.profile-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.role-tag {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--brand);
  background: #e6f6eb;
}
.user-id {
  font-size: 22rpx;
  color: var(--muted);
  font-variant-numeric: tabular-nums;
}

/* ===== 数据看板（4 列）===== */
.stats-row {
  display: flex;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 28rpx 8rpx;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx;
}
.stat-num {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 20rpx;
  color: var(--muted);
  font-weight: 500;
}

/* ===== 预填写快捷卡片 ===== */
.prefill-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 20rpx 28rpx;
  padding: 26rpx 26rpx;
  border-radius: 20rpx;
  border-left: 8rpx solid var(--brand);
}
.prefill-card:active {
  background: #f6f9f7;
}
.prefill-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}
.prefill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #e6f6eb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}
.prefill-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.prefill-title {
  font-size: 29rpx;
  font-weight: 650;
  color: var(--ink);
}
.prefill-sub {
  font-size: 22rpx;
  color: var(--muted);
  line-height: 1.4;
}

/* ===== 区块标题 ===== */
.section-label {
  margin: 28rpx 28rpx 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 0.5rpx;
}

/* ===== 菜单卡片 ===== */
.menu-card {
  margin: 0 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 26rpx;
  background: #fff;
}
.menu-row:active {
  background: #f5f7f5;
}
.menu-divider {
  height: 1rpx;
  background: var(--line);
  margin: 0 26rpx 0 80rpx;
}

/* 左边彩色图标 */
.menu-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}
.icon-green  { background: #e6f6eb; }
.icon-blue   { background: #e6f0fc; }
.icon-orange { background: #fff3e5; }
.icon-red    { background: #fde9e6; }
.icon-gray   { background: #eef2ef; }

/* 中间文字 */
.menu-title {
  font-size: 29rpx;
  font-weight: 600;
  color: var(--ink);
  flex: 1;
  min-width: 0;
}
.muted-text { color: var(--muted) !important; }

.menu-hint {
  font-size: 22rpx;
  color: var(--muted);
  flex: 1;
  min-width: 0;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.menu-value {
  font-size: 24rpx;
  color: var(--subtle);
  max-width: 280rpx;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.menu-value.mono {
  font-variant-numeric: tabular-nums;
}

/* ===== 版本号 ===== */
.version {
  margin-top: 44rpx;
  text-align: center;
  color: var(--muted);
  font-size: 20rpx;
  line-height: 1.6;
  padding: 16rpx;
}

/* ===== 开发者面板 ===== */
.dev-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(15,23,42,0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.dev-sheet {
  width: 100%;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fff;
  box-sizing: border-box;
}
.dev-title { font-size: 32rpx; font-weight: 700; margin-bottom: 8rpx; }
.dev-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--line); font-size: 26rpx; }
.dev-value { color: var(--subtle); max-width: 60%; text-align: right; }
.dev-value.api { font-size: 20rpx; word-break: break-all; }
.dev-actions { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.dev-actions .ui-btn { flex: 1 1 40%; min-width: 40%; width: auto; }
.ui-btn { margin: 0; padding: 0 20rpx; min-height: 72rpx; line-height: 72rpx; border-radius: 14rpx; font-size: 26rpx; font-weight: 600; border: 0; }
.ui-btn::after { border: 0; }
.ui-btn-primary { background: #1d4ed8; color: #fff; }
.ui-btn-light { background: #eef2ff; color: #1e293b; }
.ui-btn-sm { min-height: 64rpx; line-height: 64rpx; font-size: 24rpx; }
