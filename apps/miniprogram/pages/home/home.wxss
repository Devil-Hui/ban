.home-page { padding-top: 24rpx; }
.notice-button { width: 72rpx; height: 72rpx; border-radius: 50%; background: #fff; border: 1rpx solid var(--line); display: flex; align-items: center; justify-content: center; }
.focus { min-height: 240rpx; padding: 28rpx; display: flex; justify-content: space-between; align-items: center; background: #e9f7ee; border-color: transparent; }
.focus-number { margin: 16rpx 0 12rpx; color: var(--ink); font-size: 64rpx; font-weight: 750; line-height: 1; }
.focus-number text { font-size: 25rpx; font-weight: 500; color: var(--subtle); }
.focus-meta { color: var(--subtle); font-size: 23rpx; }
.dot { display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--warning); margin-right: 6rpx; }
.ring { width: 132rpx; height: 132rpx; border-radius: 50%; border: 12rpx solid var(--brand); background: #e9f7ee; display: flex; align-items: center; justify-content: center; }
.ring-inner { width: 124rpx; height: 124rpx; border-radius: 50%; background: #e9f7ee; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--brand); font-size: 30rpx; font-weight: 700; }
.ring-inner .mini-label { margin-top: 8rpx; font-weight: 400; }
.quick-actions { display: flex; gap: 14rpx; margin-top: 20rpx; }
.quick-action { flex: 1; min-height: 142rpx; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 12rpx; background: #fff; border: 1rpx solid var(--line); border-radius: 16rpx; color: var(--ink); font-size: 23rpx; }
.quick-icon { width: 66rpx; height: 66rpx; border-radius: 18rpx; background: var(--brand-soft); display: flex; align-items: center; justify-content: center; }
.group-card { padding: 24rpx; margin-bottom: 16rpx; }
.group-mark { width: 68rpx; height: 68rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; }
.group-mark.green { background: #2db66a; }.group-mark.blue { background: #4f8dd8; }
.card-title { font-size: 29rpx; font-weight: 650; }.role { padding: 7rpx 14rpx; border-radius: 8rpx; font-size: 21rpx; }.role.green { color: #1e9e5a; background: #e4f6e9; }.role.blue { color: #3977bf; background: #e9f1fc; }
.progress-row { display: flex; justify-content: space-between; margin: 26rpx 0 10rpx; }.progress-value { color: var(--brand); font-size: 23rpx; font-weight: 650; }.card-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 18rpx; }
.activity { padding: 4rpx 24rpx; }.activity-item { display: flex; gap: 16rpx; padding: 22rpx 0; }.activity-icon { width: 56rpx; height: 56rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; flex: none; }.activity-icon.green { background: #e4f6e9; }.activity-icon.orange { background: #fff3d8; }.activity-copy { display: flex; flex-direction: column; gap: 9rpx; line-height: 1.5; font-size: 24rpx; }.strong { font-weight: 650; }
