.detail-page { padding-top: 20rpx; }.group-hero { display: flex; align-items: center; gap: 18rpx; padding: 26rpx; }.hero-mark { width: 82rpx; height: 82rpx; border-radius: 20rpx; background: var(--brand); display: flex; align-items: center; justify-content: center; }.hero-copy { flex: 1; }.title-small { font-size: 36rpx; font-weight: 700; }.group-summary { display: flex; justify-content: space-around; padding: 26rpx 0; }.group-summary view { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }.task-card { padding: 24rpx; margin-bottom: 16rpx; }.task-title { font-size: 29rpx; font-weight: 650; margin-bottom: 9rpx; }.status { padding: 6rpx 12rpx; border-radius: 8rpx; background: #eef2ef; color: var(--subtle); font-size: 20rpx; }.status.collecting { background: #fff3d8; color: #c88a0d; }.status.published { background: var(--brand-soft); color: var(--brand); }.task-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 22rpx; padding-top: 17rpx; border-top: 1rpx solid var(--line); }.state-box { min-height: 250rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx; color: var(--muted); }.member-list { padding: 0 24rpx; }.member { min-height: 104rpx; display: flex; align-items: center; gap: 16rpx; border-bottom: 1rpx solid var(--line); }.member:last-child { border-bottom: 0; }.member-copy { flex: 1; display: flex; flex-direction: column; gap: 7rpx; }.fixed-action { position: fixed; z-index: 3; left: 0; right: 0; bottom: 0; padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid var(--line); }
.ui-btn { margin: 0; padding: 0 28rpx; min-height: 84rpx; line-height: 84rpx; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; border: 0; width: 100%; }
.ui-btn::after { border: 0; }
.ui-btn-primary { background: #1d4ed8; color: #fff; }
.ui-btn-light { background: #eef2ff; color: #1e293b; }
.group-tools { display: flex; align-items: center; gap: 12rpx; padding: 18rpx 22rpx; margin-bottom: 18rpx; }.group-tools > view { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }.invite-code { color: var(--brand); font-size: 30rpx; font-weight: 700; letter-spacing: 2rpx; }.member-actions { margin-top: 18rpx; }
