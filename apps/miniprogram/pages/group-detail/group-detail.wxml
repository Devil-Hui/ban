<view class="page detail-page">
  <view class="group-hero surface"><view class="hero-mark"><t-icon name="usergroup" size="44rpx" color="#fff" /></view><view class="hero-copy"><view class="title-small">{{name}}</view><view class="subtitle">{{members.length}} 位成员 · <text class="green">{{role}}</text></view></view></view>
  <view wx:if="{{canManage}}" class="group-tools surface"><view><text class="mini-label">分组邀请码</text><text class="invite-code">{{inviteCode || '加载中'}}</text></view><t-button theme="light" size="small" icon="copy" bindtap="copyInvite">复制</t-button><t-button theme="light" size="small" icon="share" open-type="share">分享</t-button><t-button wx:if="{{isOwner}}" theme="light" size="small" bindtap="transfer">转移组主</t-button><t-button wx:if="{{isOwner}}" theme="light" size="small" bindtap="dissolve">解散</t-button></view>
  <view class="group-summary"><view><text class="number">{{tasks.length}}</text><text class="mini-label">排班任务</text></view><view><text class="number green">{{members.length}}</text><text class="mini-label">活跃成员</text></view></view>
  <view class="section-head"><text class="section-title">排班任务</text><text class="section-link" wx:if="{{canManage}}" bindtap="createTask">+ 新建任务</text></view>
  <view wx:if="{{loading}}" class="state-box">正在加载...</view><view wx:elif="{{!tasks.length}}" class="state-box surface"><t-icon name="calendar" size="64rpx" color="#9ba79f" /><text>暂无排班任务</text><t-button wx:if="{{canManage}}" theme="primary" bindtap="createTask">创建第一个任务</t-button></view>
  <view wx:for="{{tasks}}" wx:key="id" class="task-card surface" data-index="{{index}}" bindtap="openTask"><view class="between"><view><view class="task-title">{{item.title}}</view><view class="mini-label">{{item.dateRangeText}}</view></view><view class="status {{item.status}}">{{item.statusLabel}}</view></view><view class="task-foot"><text class="mini-label">截止 {{item.deadlineText}}</text><t-icon name="chevron-right" size="30rpx" color="#9ba79f" /></view></view>
  <view class="section-head"><text class="section-title">成员</text><text class="mini-label">{{members.length}} 人</text></view>
  <view class="member-list surface"><view wx:for="{{members}}" wx:key="id" class="member"><t-avatar size="64rpx">{{item.displayName}}</t-avatar><view class="member-copy"><text>{{item.displayName}}</text><text class="mini-label">{{item.blacklisted ? '黑名单' : item.role === 'owner' ? '发布者' : item.role === 'admin' ? '管理员' : '成员'}}</text></view><view class="pill" wx:if="{{item.role !== 'member' || item.blacklisted}}">{{item.blacklisted ? '已拉黑' : item.role === 'owner' ? '组主' : '管理员'}}</view><t-icon wx:if="{{canManage && item.role !== 'owner'}}" name="more" size="30rpx" color="#6d7a71" data-index="{{index}}" catchtap="manageMember" /></view></view>
  <view class="member-actions" wx:if="{{!isOwner}}"><button class="ui-btn ui-btn-light" bindtap="leave">退出分组</button></view><view class="fixed-action" wx:if="{{canManage}}"><button class="ui-btn ui-btn-primary" bindtap="createTask">+ 新建排班任务</button></view>
</view>
