@import '../../common-styles.wxss';
.task-page {
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.head-main { flex: 1; min-width: 0; }

.block {
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.block-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8rpx;
}
.block-head .block-title { margin-bottom: 0; }

.task-status {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #eef2ef;
  color: var(--subtle);
  font-size: 22rpx;
  white-space: nowrap;
  flex: none;
}
.task-status.collecting { background: #fff3d8; color: #c88a0d; }
.task-status.published { background: var(--brand-soft); color: var(--brand); }
.task-status.ready { background: #e8f0ff; color: #3b6fd8; }
.task-status.failed { background: #fdecea; color: #c0392b; }

.grid-wrap { overflow-x: auto; }
.grid-hint {
  margin-top: 12rpx;
  display: block;
  text-align: center;
}
.empty-hint {
  color: var(--muted);
  font-size: 24rpx;
  padding: 24rpx 0;
  text-align: center;
}

.invite-code-block {
  margin: 12rpx 0;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f3f6f4;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.invite-code {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: var(--ink);
}

.row-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.row-actions .ui-btn {
  width: auto;
  flex: 1 1 30%;
  min-width: 160rpx;
}

.objection-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.objection-item:last-child { border-bottom: 0; }

.fixed-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--line);
}

.ui-btn {
  margin: 0;
  padding: 0 24rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 0;
}
.ui-btn::after { border: 0; }
.ui-btn-primary { background: #1d4ed8; color: #fff; }
.ui-btn-light { background: #eef2ff; color: #1e293b; }
.ui-btn-sm {
  min-height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  padding: 0 18rpx;
}
.ui-btn[disabled] { opacity: 0.55; }

/* 选人弹层 */
.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}
.sheet {
  width: 100%;
  max-height: 72vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.sheet-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.sheet-body {
  max-height: 48vh;
  min-height: 200rpx;
}
.sheet-foot {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}
.sheet-foot .ui-btn { flex: 1; width: auto; }

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid var(--line);
}
.member-row.on { background: #f0f7f3; }
.member-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}
.check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}
.check.on {
  background: #1e9e5a;
  border-color: #1e9e5a;
}
