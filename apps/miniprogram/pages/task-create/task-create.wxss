.create-page {
  padding-top: 24rpx;
}

.stepper {
  display: flex;
  align-items: center;
  margin: 10rpx 0 36rpx;
  overflow-x: auto;
}

.step {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.step text {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e9efeb;
  font-size: 20rpx;
}

.step.active {
  color: var(--brand);
  font-weight: 600;
}

.step.active text {
  color: #fff;
  background: var(--brand);
}

.step.done {
  color: var(--brand);
}

.step.done text {
  color: var(--brand);
  background: var(--brand-soft);
}

.line {
  flex: 1;
  min-width: 16rpx;
  height: 2rpx;
  margin: 0 10rpx;
  background: #dce7df;
}

.line.done {
  background: var(--brand);
}

.form {
  padding: 4rpx 24rpx;
  margin: 28rpx 0;
}

.field {
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 13rpx;
  border-bottom: 1rpx solid var(--line);
}

.field:last-child {
  border-bottom: 0;
}

.field > text {
  color: var(--subtle);
  font-size: 23rpx;
}

.field input,
.picker-value {
  color: var(--ink);
  font-size: 29rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-row-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.field-row-main > text:first-child {
  color: var(--ink);
  font-size: 28rpx;
}

.field-textarea {
  min-height: 180rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.reserved-textarea {
  width: 100%;
  min-height: 140rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.5;
}

.reserved-box {
  margin-top: 8rpx;
}

.reserved-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 8rpx;
}

.reserved-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 8rpx 0 20rpx;
}

.reserved-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
}

.reserved-del {
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(30, 158, 90, 0.15);
  color: var(--brand);
  font-size: 26rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--subtle);
  font-size: 25rpx;
}

.chip.active {
  border-color: var(--brand);
  background: var(--brand-soft);
  color: var(--brand);
  font-weight: 600;
}

.mode-hint {
  margin-bottom: 8rpx;
}

.tweak-form {
  margin-top: 8rpx;
}

.period-preview {
  margin: 24rpx 0;
  padding: 22rpx;
}

.period-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
}

.period-line:last-child {
  border-bottom: 0;
}

.period-code {
  min-width: 48rpx;
  color: var(--brand);
  font-weight: 600;
}

.period-label {
  color: var(--ink);
  flex: 1;
}

.empty-hint {
  margin: 20rpx 0 8rpx;
  text-align: center;
}

.summary-row {
  margin: 20rpx 0 16rpx;
  padding: 18rpx 22rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx 18rpx;
}

.grid-wrap {
  margin: 0 0 8rpx;
  padding: 12rpx;
  overflow-x: auto;
}

.paint-bar {
  padding: 20rpx 22rpx;
  margin-bottom: 8rpx;
}

.paint-cap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cap-input {
  width: 140rpx;
  text-align: right;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
}

.paint-tools {
  margin-bottom: 8rpx;
}

.tool-chip {
  min-width: 72rpx;
  text-align: center;
}

.tool-chip.erase {
  border-style: dashed;
}

.paint-hint {
  display: block;
}

.bottom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.bottom-actions .ui-btn-primary {
  flex: 1;
}

.ui-btn {
  margin: 0;
  padding: 0 28rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 0;
}

.ui-btn::after {
  border: 0;
}

.ui-btn-primary {
  width: 100%;
  margin-top: 22rpx;
  background: #1d4ed8;
  color: #fff;
}

.ui-btn-light {
  background: #eef2ff;
  color: #1e293b;
  min-width: 180rpx;
}

.ui-btn-sm {
  min-height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  width: auto;
  margin-top: 0;
}

.ui-btn[disabled] {
  opacity: 0.55;
}
