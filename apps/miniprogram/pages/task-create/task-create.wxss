.create-page {
  padding-top: 24rpx;
}

.stepper {
  display: flex;
  align-items: center;
  margin: 10rpx 0 36rpx;
  overflow-x: auto;
}

.step {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.step text {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e9efeb;
  font-size: 20rpx;
}

.step.active {
  color: var(--brand);
  font-weight: 600;
}

.step.active text {
  color: #fff;
  background: var(--brand);
}

.step.done {
  color: var(--brand);
}

.step.done text {
  color: var(--brand);
  background: var(--brand-soft);
}

.line {
  flex: 1;
  min-width: 16rpx;
  height: 2rpx;
  margin: 0 10rpx;
  background: #dce7df;
}

.line.done {
  background: var(--brand);
}

.form {
  padding: 4rpx 24rpx;
  margin: 28rpx 0;
}

.field {
  min-height: 116rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 13rpx;
  border-bottom: 1rpx solid var(--line);
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  color: var(--subtle);
  font-size: 23rpx;
}

.field-label.required::after {
  content: ' *';
  color: #df5c4c;
}

.field input,
.picker-value {
  color: var(--ink);
  font-size: 29rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-row {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.field-row-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.field-row-main .fm-title {
  color: var(--ink);
  font-size: 28rpx;
}

.field-textarea {
  min-height: 180rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.reserved-textarea {
  width: 100%;
  min-height: 140rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.5;
}

.reserved-box {
  margin-top: 8rpx;
}

.reserved-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 8rpx;
}

.reserved-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 8rpx 0 20rpx;
}

.reserved-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: var(--brand-soft);
  color: var(--brand);
  font-size: 24rpx;
}

.reserved-del {
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(30, 158, 90, 0.15);
  color: var(--brand);
  font-size: 26rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--subtle);
  font-size: 25rpx;
}

.chip.active {
  border-color: var(--brand);
  background: var(--brand-soft);
  color: var(--brand);
  font-weight: 600;
}

/* 展示模式差异色 */
.chip.mode-range.active {
  border-color: #3b82f6;
  background: #eff6ff;
  color: #3b82f6;
}

.chip.mode-section.active {
  border-color: #1e9e5a;
  background: #e8f7ef;
  color: #1e9e5a;
}

.chip.mode-custom.active {
  border-color: #e6a21a;
  background: #fef9ee;
  color: #e6a21a;
}

.mode-hint {
  margin-bottom: 8rpx;
}

.tweak-form {
  margin-top: 8rpx;
}

.tweak-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 24rpx;
}

.tweak-col {
  display: flex;
  flex-direction: column;
}

/* 时间区间选择器 */
.time-range {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.time-range .range-sep {
  color: var(--muted);
  font-size: 24rpx;
  flex-shrink: 0;
}

.picker-value-sm {
  color: var(--ink);
  font-size: 26rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: var(--canvas);
}

/* 午休+晚饭同行 */
.field-break-row {
  flex-direction: row;
  justify-content: space-between;
  gap: 0;
  min-height: auto;
  padding: 16rpx 0;
}

.break-inline {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.break-inline .field-label {
  font-size: 22rpx;
}


/* 字段头部（标签 + 开关） */
.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-head .field-label {
  color: var(--subtle);
  font-size: 23rpx;
}

/* 午休/晚饭排班开关胶囊行 */
.break-toggle-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.break-toggle {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  padding: 4rpx 8rpx 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--line);
  background: #f5f7f6;
}

.break-toggle.lunch.open {
  background: #e8f7ef;
  border-color: #1e9e5a;
}

.break-toggle.dinner.open {
  background: #fef6e8;
  border-color: #e6a21a;
}

.break-toggle .break-text {
  font-size: 22rpx;
  color: var(--subtle);
  line-height: 1;
}

.break-toggle.lunch.open .break-text { color: #1e9e5a; font-weight: 600; }
.break-toggle.dinner.open .break-text { color: #e6a21a; font-weight: 600; }

/* 午休/晚饭确认弹窗 */
.modal-mask {
  position: fixed;
  z-index: 100;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 27, 20, 0.42);
}

.break-confirm-modal {
  width: 560rpx;
  padding: 36rpx 32rpx;
  border-radius: 20rpx;
  text-align: center;
}

.confirm-title {
  font-size: 32rpx;
  font-weight: 650;
  color: var(--ink);
}

.confirm-desc {
  display: block;
  margin-top: 16rpx;
  color: var(--subtle);
  font-size: 25rpx;
  line-height: 1.5;
}

.confirm-buttons {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 28rpx;
}

.confirm-buttons .ui-btn {
  flex: 1;
  margin: 0;
  width: auto;
  min-height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 28rpx;
  border: 0;
}

.confirm-buttons .ui-btn::after {
  border: 0;
}

.confirm-buttons .ui-btn-light {
  background: #f2f3f5;
  color: #4e5969;
}

.confirm-buttons .ui-btn-primary {
  background: #1d4ed8;
  color: #fff;
}

.period-preview {
  margin: 24rpx 0;
  padding: 22rpx;
}

.period-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--line);
  font-size: 26rpx;
}

.period-line:last-child {
  border-bottom: 0;
}

.period-code {
  min-width: 48rpx;
  color: var(--brand);
  font-weight: 600;
}

.period-label {
  color: var(--ink);
  flex: 1;
}

.empty-hint {
  margin: 20rpx 0 8rpx;
  text-align: center;
}

.summary-row {
  margin: 20rpx 0 16rpx;
  padding: 18rpx 22rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx 18rpx;
}

.grid-wrap {
  margin: 0 0 8rpx;
  padding: 12rpx;
  overflow-x: auto;
}

.paint-bar {
  padding: 20rpx 22rpx;
  margin-bottom: 8rpx;
}

.paint-cap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.cap-input {
  width: 140rpx;
  text-align: right;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
}

.paint-tools {
  margin-bottom: 8rpx;
}

.tool-chip {
  min-width: 72rpx;
  text-align: center;
}

.tool-chip.erase {
  border-style: dashed;
}

.paint-hint {
  display: block;
}

.bottom-actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 22rpx;
}

.bottom-actions .ui-btn {
  flex: 1;
}

.ui-btn {
  margin: 0;
  padding: 0 28rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: 0;
}

.ui-btn::after {
  border: 0;
}

.ui-btn-primary {
  background: #1d4ed8;
  color: #fff;
}

.ui-btn-full {
  width: 100%;
  margin-top: 22rpx;
}

.ui-btn-light {
  background: #f2f3f5;
  color: #4e5969;
}

.ui-btn-sm {
  min-height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  width: auto;
  margin-top: 0;
}


/* 本周/下周 快捷按钮 (E5) */
.quick-week {
  display: flex;
  gap: 16rpx;
  margin: 8rpx 0 4rpx;
}

.quick-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--brand);
  font-size: 26rpx;
}

.quick-btn:active {
  background: var(--brand-soft);
}

/* 时段规则 两列网格 (E10) */
.period-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 14rpx;
}

.period-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  text-align: center;
}

.period-card .period-code {
  color: var(--brand);
  font-weight: 600;
  font-size: 26rpx;
}

.period-card .period-time {
  color: var(--ink);
  font-size: 22rpx;
}

/* 休息时段卡片（午休/晚饭） */
.period-card.rest {
  background: var(--canvas);
  border: 1rpx dashed var(--line);
}

.period-card.rest .period-time {
  color: var(--subtle);
  font-size: 20rpx;
}

/* 课间标签解释图标 */
.info-dot {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: var(--brand);
}

.break-inline-label {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.hint {
  display: block;
  margin-top: 6rpx;
  line-height: 1.4;
}

/* 收起/设置按钮 */
.add-toggle {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--line);
  font-size: 22rpx;
  color: var(--subtle);
}

.add-toggle.open {
  border-color: var(--brand);
  background: var(--brand-soft);
  color: var(--brand);
}

/* 晚上课时区域 */
.evening-section {
  margin-top: 8rpx;
}

/* 晚上课时两列布局 */
.evening-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.evening-cell {
  flex: 0 0 calc(50% - 6rpx);
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: var(--canvas);
  box-sizing: border-box;
}

.evening-head {
  margin-bottom: 6rpx;
}

.del-btn {
  font-size: 24rpx;
  color: #df5c4c;
  padding: 2rpx 8rpx;
}

/* 大小课间标签 */
.period-break {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  margin-top: 2rpx;
}

.period-break.normal {
  background: #fef6e8;
  color: #e6a21a;
}

.period-break.session {
  background: #e8f0fe;
  color: #5b8def;
}

/* 自定义必填项输入行 (E6) */
.custom-field-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 12rpx 0 4rpx;
}

.custom-input {
  flex: 1;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--ink);
  font-size: 27rpx;
}
