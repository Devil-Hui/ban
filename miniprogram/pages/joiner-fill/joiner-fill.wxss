/* pages/joiner-fill/joiner-fill.wxss */
.page-jf {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 200rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* 任务 Hero */
.task-hero {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}
.task-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #B8DDE9 0%, #7EC8E3 100%);
}
.hero-icon {
  width: 76rpx; height: 76rpx;
  border-radius: var(--r-md);
  background: linear-gradient(135deg, #7EC8E3 0%, #5BAFDA 100%);
  color: var(--c-text-inv);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.hero-body { flex: 1; min-width: 0; }
.hero-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
}
.hero-meta {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.dot-sep { margin: 0 8rpx; }
.hero-deadline { text-align: right; flex-shrink: 0; }
.hd-label {
  font-size: 20rpx;
  color: var(--c-text-3);
}
.hd-time {
  font-size: 22rpx;
  color: var(--c-primary-dark);
  font-weight: 600;
  margin-top: 4rpx;
}

/* 提示 */
.tip-bar {
  background: rgba(126, 200, 227, 0.10);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.tip-ico {
  width: 28rpx; height: 28rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  font-size: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-style: italic;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.tip-text {
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.55;
  flex: 1;
}
.hl { color: var(--c-primary-dark); font-weight: 600; }

/* 周历卡片 */
.cal-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 16rpx;
  margin-bottom: 12rpx;
}
/* 周切换器 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 16rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname {
  text-align: center;
  padding: 8rpx 0;
}
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
}
.cw-today { color: var(--c-primary-dark); font-weight: 600; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}

.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 100rpx;
}
.row-label-col {
  position: absolute;
  left: 0;
  top: 0;
  width: 100rpx;
  display: flex;
  flex-direction: column;
}
.row-label {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text-3);
  border-right: 1rpx solid var(--c-divider);
}
.cal-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  height: 80rpx;
  margin-bottom: 4rpx;
}
.cell {
  background: var(--c-primary-lightest);
  border: 2rpx solid transparent;
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.cell:active { transform: scale(0.95); }
.cell-disabled {
  background: var(--c-divider);
  opacity: 0.55;
}
.cell-selected {
  background: var(--c-primary);
  border-color: var(--c-primary-dark);
  box-shadow: 0 2rpx 8rpx rgba(126, 200, 227, 0.35);
}
.cell-check {
  color: var(--c-text-inv);
  font-size: 28rpx;
  font-weight: 600;
}

/* 图例 */
.legend-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 24rpx;
  background: var(--c-card);
  border-radius: var(--r-md);
  margin-bottom: 16rpx;
}
.lg-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--c-text-2);
}
.lg-swatch {
  width: 24rpx; height: 24rpx;
  border-radius: 6rpx;
}
.lg-avail { background: var(--c-primary-lightest); }
.lg-sel { background: var(--c-primary); }
.lg-dis { background: var(--c-divider); }

/* 摘要 */
.summary-card {
  background: linear-gradient(135deg, rgba(126, 200, 227, 0.08) 0%, rgba(184, 221, 233, 0.18) 100%);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.sc-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 24rpx;
}
.sc-label { color: var(--c-text-2); }
.sc-value { color: var(--c-text); font-weight: 600; }
.sc-pending { color: #8A6644; }
.sc-submitted { color: var(--c-primary-dark); }

/* 二次编辑提示 */
.edit-notice {
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-left: 6rpx solid var(--c-primary);
  margin-bottom: 16rpx;
}
.en-ico {
  font-size: 24rpx;
  color: var(--c-primary);
}
.en-body { flex: 1; }
.en-title {
  font-size: 24rpx;
  color: var(--c-text);
  font-weight: 600;
}
.en-desc {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
  line-height: 1.4;
}
.en-del {
  font-size: 22rpx;
  color: #C77;
  background: rgba(232, 139, 139, 0.12);
  padding: 8rpx 18rpx;
  border-radius: var(--r-pill);
}

/* 底部 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--c-card);
  box-shadow: 0 -2rpx 16rpx rgba(126, 200, 227, 0.10);
  z-index: 50;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--r-md);
  font-size: var(--f-sm);
  font-weight: 600;
}
.btn-outline {
  background: var(--c-bg);
  color: var(--c-text);
  border: 2rpx solid var(--c-border);
}
.btn-primary {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.bottom-spacer { height: 40rpx; }
