<!-- pages/auth/auth.wxml —— 微信授权登录页 -->
<view class="page-auth">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- 顶部品牌区 -->
  <view class="brand-area">
    <view class="brand-logo">
      <view class="logo-ring"></view>
      <view class="logo-inner">排</view>
    </view>
    <view class="brand-title">排班协同</view>
    <view class="brand-slogan">轻量协同 · 时间可视</view>
  </view>

  <!-- 大型展示卡（3 款不同样式，魔术贴式切换） -->
  <view class="showcase">
    <!-- 切换箭头 -->
    <view class="sc-arrow sc-arrow-l" bindtap="prevCard">‹</view>
    <view class="sc-arrow sc-arrow-r" bindtap="nextCard">›</view>

    <!-- 卡片 1：日历视图 -->
    <view wx:if="{{activeCardIdx === 0}}" class="big-card bc-calendar">
      <view class="bc-tag">日历视图</view>
      <view class="bc-title">一眼看清本周排班</view>
      <view class="bc-desc">周一到周日横向展示，时段按创建原貌呈现</view>
      <!-- 模拟日历 -->
      <view class="bc-mock-cal">
        <view class="bcmc-head">
          <view wx:for="{{showcaseCards[0].mockDays}}" wx:key="*this" class="bcmc-h-day">周{{item}}</view>
        </view>
        <view class="bcmc-row">
          <view
            wx:for="{{showcaseCards[0].mockCells}}"
            wx:key="*this"
            class="bcmc-cell {{item === 1 ? 'bcmc-cell-on' : ''}}"
          >{{item === 1 ? '✓' : ''}}</view>
        </view>
        <view class="bcmc-row">
          <view
            wx:for="{{showcaseCards[0].mockCells}}"
            wx:key="*this"
            class="bcmc-cell {{item === 1 ? 'bcmc-cell-on2' : ''}}"
          >{{item === 1 ? '✓' : ''}}</view>
        </view>
      </view>
    </view>

    <!-- 卡片 2：实时值班 -->
    <view wx:elif="{{activeCardIdx === 1}}" class="big-card bc-duty">
      <view class="bc-tag bc-tag-soft">实时值班</view>
      <view class="bc-title">当前值班人即刻可见</view>
      <view class="bc-desc">获取当前时间，自动定位正在值班的姓名与手机号</view>
      <!-- 模拟值班 -->
      <view class="bc-mock-duty">
        <view class="bmd-row bmd-current">
          <view class="bmd-label">正在</view>
          <view class="bmd-body">
            <view class="bmd-name">{{showcaseCards[1].mockCurrent.name}}</view>
            <view class="bmd-phone">{{showcaseCards[1].mockCurrent.phone}}</view>
          </view>
          <view class="bmd-period">{{showcaseCards[1].mockCurrent.period}}</view>
        </view>
        <view class="bmd-row bmd-next">
          <view class="bmd-label">即将</view>
          <view class="bmd-body">
            <view class="bmd-name">{{showcaseCards[1].mockNext.name}}</view>
            <view class="bmd-phone">{{showcaseCards[1].mockNext.phone}}</view>
          </view>
          <view class="bmd-period">{{showcaseCards[1].mockNext.period}}</view>
        </view>
      </view>
    </view>

    <!-- 卡片 3：一键分享 -->
    <view wx:else class="big-card bc-share">
      <view class="bc-tag bc-tag-warm">一键分享</view>
      <view class="bc-title">分享名单给成员确认</view>
      <view class="bc-desc">选定人员后分享，加入者按名单确认时间表</view>
      <!-- 模拟成员名单 -->
      <view class="bc-mock-members">
        <view wx:for="{{showcaseCards[2].mockMembers}}" wx:key="*this" class="bcmm-avatar">{{item}}</view>
        <view class="bcmm-more">+3</view>
      </view>
    </view>

    <!-- 指示点 -->
    <view class="sc-dots">
      <view class="sc-dot {{activeCardIdx === 0 ? 'sc-dot-active' : ''}}" bindtap="switchCard" data-idx="0"></view>
      <view class="sc-dot {{activeCardIdx === 1 ? 'sc-dot-active' : ''}}" bindtap="switchCard" data-idx="1"></view>
      <view class="sc-dot {{activeCardIdx === 2 ? 'sc-dot-active' : ''}}" bindtap="switchCard" data-idx="2"></view>
    </view>
  </view>

  <!-- 底部授权区 -->
  <view class="auth-bottom">
    <button class="auth-btn {{logging ? 'auth-btn-loading' : ''}}" bindtap="onAuth">
      <view class="auth-btn-inner">
        <text class="wechat-icon">微</text>
        <text>{{logging ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </button>
    <view class="auth-protocol">
      登录即代表同意 <text class="protocol-link">《用户协议》</text> 与 <text class="protocol-link">《隐私政策》</text>
    </view>
  </view>
</view>
