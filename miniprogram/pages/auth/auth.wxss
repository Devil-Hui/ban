/* pages/auth/auth.wxss —— 微信授权登录页 */
.page-auth {
  min-height: 100vh;
  padding: 0 48rpx calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  background:
    radial-gradient(80% 40% at 50% 0%, rgba(126, 200, 227, 0.25) 0%, transparent 60%),
    radial-gradient(60% 30% at 100% 100%, rgba(126, 200, 227, 0.12) 0%, transparent 60%),
    var(--c-bg);
  display: flex;
  flex-direction: column;
}

/* 品牌区 */
.brand-area {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.brand-logo {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.logo-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-lighter) 100%);
  opacity: 0.4;
  animation: pulse 2.4s ease-in-out infinite;
}
.logo-inner {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text-inv);
  font-size: 56rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(126, 200, 227, 0.35);
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.08); opacity: 0.2; }
}
.brand-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.brand-slogan {
  font-size: 24rpx;
  color: var(--c-text-3);
  letter-spacing: 2rpx;
}

/* —— 大型展示卡（3 款不同样式） —— */
.showcase {
  margin-top: 56rpx;
  position: relative;
  padding: 0 16rpx;
}
.sc-arrow {
  position: absolute;
  top: 50%;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-card);
  box-shadow: 0 4rpx 16rpx rgba(126, 200, 227, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
  z-index: 5;
  transform: translateY(-50%);
}
.sc-arrow:active { transform: translateY(-50%) scale(0.9); }
.sc-arrow-l { left: -8rpx; }
.sc-arrow-r { right: -8rpx; }

.big-card {
  background: var(--c-card);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(126, 200, 227, 0.18);
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  animation: cardIn .35s ease;
}
@keyframes cardIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.bc-tag {
  display: inline-block;
  align-self: flex-start;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--c-text-inv);
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  padding: 6rpx 18rpx;
  border-radius: var(--r-pill);
  margin-bottom: 20rpx;
}
.bc-tag-soft {
  background: linear-gradient(135deg, var(--c-primary-light) 0%, var(--c-primary) 100%);
}
.bc-tag-warm {
  background: linear-gradient(135deg, #F5B97A 0%, #E89B4F 100%);
}
.bc-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--c-text);
  line-height: 1.3;
  margin-bottom: 10rpx;
}
.bc-desc {
  font-size: 24rpx;
  color: var(--c-text-3);
  line-height: 1.5;
  margin-bottom: 28rpx;
}

/* 卡片 1：日历视图模拟 */
.bc-calendar {
  background: linear-gradient(160deg, var(--c-card) 0%, #F5FBFD 100%);
}
.bc-mock-cal {
  margin-top: auto;
  background: var(--c-bg);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
}
.bcmc-head {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  margin-bottom: 8rpx;
}
.bcmc-h-day {
  text-align: center;
  font-size: 20rpx;
  color: var(--c-text-3);
  font-weight: 500;
}
.bcmc-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  margin-bottom: 6rpx;
}
.bcmc-cell {
  height: 48rpx;
  border-radius: 8rpx;
  background: var(--c-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: transparent;
}
.bcmc-cell-on {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.bcmc-cell-on2 {
  background: var(--c-primary-light);
  color: var(--c-primary-dark);
}

/* 卡片 2：实时值班模拟 */
.bc-duty {
  background: linear-gradient(160deg, var(--c-card) 0%, #F8FBFD 100%);
}
.bc-mock-duty {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.bmd-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}
.bmd-current {
  background: linear-gradient(135deg, rgba(126, 200, 227, 0.16) 0%, rgba(184, 221, 233, 0.24) 100%);
  border: 1rpx solid rgba(126, 200, 227, 0.4);
}
.bmd-next {
  background: var(--c-bg);
  border: 1rpx dashed var(--c-border);
}
.bmd-label {
  width: 64rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--c-primary-dark);
  flex-shrink: 0;
}
.bmd-next .bmd-label { color: var(--c-text-3); }
.bmd-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.bmd-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}
.bmd-next .bmd-name { font-size: 28rpx; font-weight: 600; }
.bmd-phone {
  font-size: 24rpx;
  color: var(--c-primary-dark);
  letter-spacing: 1rpx;
}
.bmd-next .bmd-phone { color: var(--c-text-3); }
.bmd-period {
  font-size: 22rpx;
  color: var(--c-text-2);
  background: var(--c-card);
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
}

/* 卡片 3：分享名单模拟 */
.bc-share {
  background: linear-gradient(160deg, var(--c-card) 0%, #FFFBF5 100%);
}
.bc-mock-members {
  margin-top: auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0 8rpx;
}
.bcmm-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--c-primary-light) 0%, var(--c-primary) 100%);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(126, 200, 227, 0.25);
}
.bcmm-more {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--c-bg);
  border: 2rpx dashed var(--c-border);
  color: var(--c-text-3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

/* 指示点 */
.sc-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}
.sc-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-divider);
  transition: all .2s;
}
.sc-dot-active {
  width: 36rpx;
  border-radius: 6rpx;
  background: var(--c-primary);
}

/* 底部授权 */
.auth-bottom {
  margin-top: auto;
  padding-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.auth-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  border-radius: var(--r-pill);
  color: var(--c-text-inv);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(126, 200, 227, 0.4);
}
.auth-btn::after { border: none; }
.auth-btn-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.auth-protocol {
  font-size: 22rpx;
  color: var(--c-text-3);
}
.protocol-link {
  color: var(--c-primary-dark);
}
