/* pages/task-mark/task-mark.wxss —— 时段标记页样式 */

.page-tm {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 240rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* —— Hero —— */
.tm-hero {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: var(--s-sm);
}
.hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
.hero-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.hero-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 6rpx;
}
.hero-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
}
.hero-progress {
  margin-top: 20rpx;
}
.progress-bar {
  height: 8rpx;
  background: var(--c-divider);
  border-radius: var(--r-pill);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--c-primary-light) 0%, var(--c-primary) 100%);
  border-radius: var(--r-pill);
}
.hero-progress-text {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 10rpx;
  display: block;
}

/* —— 工具栏 —— */
.tm-tools {
  display: flex;
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 12rpx;
  margin-bottom: var(--s-sm);
}
.tool-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 4rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  border-radius: var(--r-sm);
  transition: background .15s;
}
.tool-cell:active { background: var(--c-primary-lightest); }
.tool-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
}
.tool-icon {
  font-size: 24rpx;
  color: var(--c-primary-dark);
}
.tool-import {
  color: var(--c-primary-dark);
  font-weight: 500;
}

/* —— 周次切换 —— */
.week-switcher {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 12rpx 16rpx;
  margin-bottom: var(--s-sm);
}
.ws-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-text-2);
}
.ws-title {
  text-align: center;
  display: flex;
  flex-direction: column;
}
.ws-title text:first-child {
  font-size: var(--f-cap);
  font-weight: 600;
  color: var(--c-text);
}
.ws-sub {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 2rpx;
}

/* —— 网格 —— */
.grid-scroll {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--s-sm);
}
.grid-wrap {
  min-width: 100%;
  padding: 8rpx;
}
.grid-row {
  display: flex;
  align-items: stretch;
}
.grid-row + .grid-row {
  border-top: 1rpx solid var(--c-divider);
}
.grid-head {
  border-bottom: 2rpx solid var(--c-divider);
  padding-bottom: 8rpx;
}
.grid-corner {
  width: 140rpx;
  flex-shrink: 0;
  padding: 16rpx 12rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  font-weight: 500;
  display: flex;
  align-items: center;
}
.grid-day {
  flex: 1;
  min-width: 80rpx;
  text-align: center;
  padding: 8rpx 4rpx;
}
.gd-weekday {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.gd-date {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 600;
  margin-top: 4rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 50%;
  margin: 4rpx auto 0;
}
.gd-today {
  background: var(--c-primary);
  color: var(--c-text-inv);
}

.grid-period {
  width: 140rpx;
  flex-shrink: 0;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.gp-label {
  font-size: var(--f-tiny);
  color: var(--c-text);
  font-weight: 500;
}
.gp-time {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}

.grid-cell {
  flex: 1;
  min-width: 80rpx;
  min-height: 72rpx;
  margin: 4rpx;
  border-radius: var(--r-sm);
  background: var(--c-primary-lightest);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
}
.grid-cell:active { transform: scale(0.95); }
.cell-available {
  background: rgba(107, 199, 133, 0.18);
}
.cell-busy {
  background: rgba(232, 139, 139, 0.16);
}
.cell-mark {
  color: var(--c-success);
  font-size: 28rpx;
  font-weight: 600;
}
.cell-mark-busy { color: var(--c-danger); }

/* —— 图例 —— */
.legend-row {
  display: flex;
  justify-content: space-around;
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 16rpx;
  margin-bottom: var(--s-sm);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
}
.legend-cell {
  width: 28rpx;
  height: 28rpx;
  border-radius: 6rpx;
}
.legend-avail { background: rgba(107, 199, 133, 0.4); border: 1rpx solid var(--c-success); }
.legend-busy { background: rgba(232, 139, 139, 0.35); border: 1rpx solid var(--c-danger); }
.legend-none { background: var(--c-primary-lightest); border: 1rpx solid var(--c-border); }

/* —— 统计 —— */
.stat-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
  margin-bottom: var(--s-sm);
}
.stat-block {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  text-align: center;
}
.sb-num {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}
.sb-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.stat-avail .sb-num { color: var(--c-success); }
.stat-busy .sb-num { color: var(--c-danger); }
.stat-total .sb-num { color: var(--c-text); }

/* —— 隐私提示 —— */
.privacy-note {
  display: flex;
  gap: 12rpx;
  background: rgba(126, 200, 227, 0.08);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: var(--s-sm);
}
.pn-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}
.pn-title {
  font-size: var(--f-cap);
  font-weight: 600;
  color: var(--c-text);
}
.pn-desc {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 4rpx;
}

/* —— 底部 —— */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 16rpx);
  background: var(--c-card);
  box-shadow: 0 -4rpx 20rpx rgba(126, 200, 227, 0.12);
  z-index: 50;
}
