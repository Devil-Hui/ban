<!-- pages/task-mark/task-mark.wxml —— 时段标记页 -->
<view class="page-tm">
  <!-- 任务摘要 -->
  <view class="tm-hero">
    <view class="hero-row">
      <view>
        <view class="hero-title">{{task.title}}</view>
        <view class="hero-meta">{{task.groupName}} · {{timeModeLabel}} · 截止 {{task.deadline}}</view>
      </view>
      <view class="hero-status">
        <view class="dot dot-brand"></view>
        <text>{{task.stateLabel}}</text>
      </view>
    </view>
    <view class="hero-progress">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{task.progress}}%"></view>
      </view>
      <text class="hero-progress-text">已提交 {{task.submitted}}/{{task.total}} · 你的提交：{{myStatus}}</text>
    </view>
  </view>

  <!-- 工具栏 -->
  <view class="tm-tools">
    <view class="tool-cell" bindtap="setMode" data-mode="available">
      <view class="tool-dot dot-success"></view>
      <text>标记空闲</text>
    </view>
    <view class="tool-cell" bindtap="setMode" data-mode="busy">
      <view class="tool-dot dot-danger"></view>
      <text>标记忙碌</text>
    </view>
    <view class="tool-cell" bindtap="clearAll">
      <view class="tool-dot dot-neutral"></view>
      <text>清空</text>
    </view>
    <view class="tool-cell tool-import" bindtap="importCalendar">
      <view class="tool-icon">⇪</view>
      <text>从日历导入</text>
    </view>
  </view>

  <!-- 周次切换 -->
  <view class="week-switcher">
    <view class="ws-arrow" bindtap="prevWeek">‹</view>
    <view class="ws-title">
      <text>{{weekLabel}}</text>
      <text class="ws-sub">{{dateRangeLabel}}</text>
    </view>
    <view class="ws-arrow" bindtap="nextWeek">›</view>
  </view>

  <!-- 时段网格 -->
  <scroll-view scroll-x class="grid-scroll" enhanced show-scrollbar="{{false}}">
    <view class="grid-wrap">
      <!-- 表头 -->
      <view class="grid-row grid-head">
        <view class="grid-corner">时段</view>
        <view wx:for="{{dates}}" wx:key="dateStr" class="grid-day">
          <view class="gd-weekday">{{item.weekday}}</view>
          <view class="gd-date {{item.isToday ? 'gd-today' : ''}}">{{item.day}}</view>
        </view>
      </view>

      <!-- 各时段行 -->
      <view wx:for="{{periods}}" wx:for-item="period" wx:key="id" class="grid-row">
        <view class="grid-period">
          <view class="gp-label">{{period.label}}</view>
          <view class="gp-time">{{period.start}}-{{period.end}}</view>
        </view>
        <view
          wx:for="{{dates}}"
          wx:for-item="date"
          wx:key="dateStr"
          class="grid-cell cell-{{grid[period.id][date.dateStr] || 'none'}}"
          bindtap="toggleCell"
          bindlongpress="toggleCell"
          data-period="{{period.id}}"
          data-date="{{date.dateStr}}"
        >
          <view wx:if="{{grid[period.id][date.dateStr] === 'available'}}" class="cell-mark">✓</view>
          <view wx:elif="{{grid[period.id][date.dateStr] === 'busy'}}" class="cell-mark cell-mark-busy">✕</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 图例 -->
  <view class="legend-row">
    <view class="legend-item">
      <view class="legend-cell legend-avail"></view>
      <text>空闲（可值班）</text>
    </view>
    <view class="legend-item">
      <view class="legend-cell legend-busy"></view>
      <text>忙碌</text>
    </view>
    <view class="legend-item">
      <view class="legend-cell legend-none"></view>
      <text>未标记</text>
    </view>
  </view>

  <!-- 统计卡 -->
  <view class="stat-row">
    <view class="stat-block stat-avail">
      <view class="sb-num">{{stats.available}}</view>
      <view class="sb-label">空闲时段</view>
    </view>
    <view class="stat-block stat-busy">
      <view class="sb-num">{{stats.busy}}</view>
      <view class="sb-label">忙碌时段</view>
    </view>
    <view class="stat-block stat-total">
      <view class="sb-num">{{stats.total}}</view>
      <view class="sb-label">总时段</view>
    </view>
  </view>

  <!-- 提交提示 -->
  <view class="privacy-note">
    <view class="pn-icon">⛨</view>
    <view class="pn-body">
      <view class="pn-title">隐私提示</view>
      <view class="pn-desc">你的空闲标记仅发布者可见，其他成员无法查看</view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <view class="btn btn-outline" bindtap="saveDraft">暂存</view>
    <view class="btn btn-primary btn-block" bindtap="onSubmit">提交空闲时间</view>
  </view>
</view>
