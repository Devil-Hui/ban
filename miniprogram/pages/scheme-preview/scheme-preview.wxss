/* pages/scheme-preview/scheme-preview.wxss —— 方案预览样式 */

.page-sp {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* —— Hero —— */
.sp-hero {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: var(--s-sm);
}
.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.hero-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.hero-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 6rpx;
}
.hero-mode {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  flex-shrink: 0;
}
.mode-icon { font-size: 22rpx; }

/* —— 方案切换 —— */
.scheme-switcher {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--s-sm);
  overflow-x: auto;
}
.ss-card {
  flex: 1;
  min-width: 220rpx;
  background: var(--c-card);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 16rpx;
  position: relative;
  transition: all .15s;
}
.ss-active {
  border-color: var(--c-primary);
  background: linear-gradient(135deg, rgba(126, 200, 227, 0.06) 0%, rgba(184, 221, 233, 0.14) 100%);
}
.ss-num {
  font-size: var(--f-cap);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 12rpx;
}
.ss-active .ss-num { color: var(--c-primary-dark); }
.ss-stats {
  display: flex;
  justify-content: space-between;
}
.ss-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.ss-stat-num {
  font-size: var(--f-body);
  font-weight: 700;
  color: var(--c-text);
  line-height: 1;
}
.ss-stat-label {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.ss-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* —— 当前方案 —— */
.current-scheme-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: var(--s-sm);
}
.csc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.csc-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.csc-action {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
}
.csc-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.csc-cell {
  flex: 1;
  text-align: center;
}
.csc-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.csc-value {
  font-size: var(--f-sub);
  font-weight: 700;
  color: var(--c-primary-dark);
  margin-top: 4rpx;
}
.csc-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--c-divider);
}

/* —— 警告 —— */
.warnings {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.warn-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(242, 185, 98, 0.10);
  border-radius: var(--r-md);
  padding: 12rpx 16rpx;
  font-size: var(--f-tiny);
}
.warn-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--c-warning);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.warn-text { flex: 1; color: var(--c-text); }
.warn-action {
  color: var(--c-warning);
  font-weight: 500;
}

/* —— 段落标题 —— */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 32rpx 4rpx 16rpx;
}
.section-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.section-action {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.section-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-primary);
}

/* —— 人员负荷 —— */
.load-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: var(--s-md);
  margin-bottom: var(--s-sm);
}
.load-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}
.load-row + .load-row { border-top: 1rpx solid var(--c-divider); }
.load-body { flex: 1; min-width: 0; }
.load-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.load-name {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
}
.load-count {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  font-weight: 600;
}
.load-bar {
  height: 8rpx;
  background: var(--c-divider);
  border-radius: var(--r-pill);
  overflow: hidden;
}
.load-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--c-primary-light) 0%, var(--c-primary) 100%);
  border-radius: var(--r-pill);
}

/* —— 按周日历卡片 —— */
.week-cal-card {
  background: linear-gradient(180deg, var(--c-card) 0%, #FAFCFE 100%);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx 20rpx 20rpx;
  margin-bottom: var(--s-sm);
}
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 20rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}
.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname { text-align: center; padding: 4rpx 0; }
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
  line-height: 1.2;
}
.cw-today { color: var(--c-primary-dark); font-weight: 700; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cw-today + .cw-date { color: var(--c-primary); }

/* 时段行 × 7 天单元格 */
.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  min-width: 100%;
}
.row-label-col {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}
.row-label {
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--c-bg);
  border-radius: var(--r-sm);
  margin-bottom: 8rpx;
}
.rl-time {
  font-size: 22rpx;
  color: var(--c-text);
  font-weight: 600;
  line-height: 1.2;
}
.rl-time-end {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cal-row {
  display: flex;
  flex: 1;
}
.sp-cell {
  flex: 1;
  min-width: 80rpx;
  height: 96rpx;
  margin: 0 4rpx 8rpx;
  background: var(--c-bg);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  position: relative;
  transition: transform .15s, background .15s;
}
.sp-cell:active { transform: scale(0.94); }
.sp-cell-filled {
  background: var(--c-primary-lighter);
  border: 1rpx solid rgba(126, 200, 227, 0.5);
}
.sp-cell-urgent {
  background: rgba(232, 139, 139, 0.10);
  border: 1rpx dashed var(--c-danger);
}
.spc-members {
  display: flex;
  gap: 2rpx;
}
.spc-avatar {
  width: 36rpx;
  height: 36rpx;
  font-size: 18rpx;
}
.spc-empty {
  font-size: 28rpx;
  color: var(--c-text-3);
  font-weight: 300;
}
.spc-count {
  font-size: 18rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
  line-height: 1;
}
.sp-cell-urgent .spc-count { color: var(--c-danger); }
.wc-tip {
  margin-top: 16rpx;
  font-size: 20rpx;
  color: var(--c-text-3);
  text-align: center;
  line-height: 1.5;
}

/* —— 底部 —— */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 16rpx);
  background: var(--c-card);
  box-shadow: 0 -4rpx 20rpx rgba(126, 200, 227, 0.12);
  z-index: 50;
}

/* —— 调整弹层 —— */
.adjust-mask {
  position: fixed;
  inset: 0;
  background: rgba(26, 43, 60, 0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.adjust-sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-xl) var(--r-xl) 0 0;
  padding: 24rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp .25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.as-handle {
  width: 64rpx;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: var(--r-pill);
  margin: 0 auto 16rpx;
}
.as-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.as-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.as-sub {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.as-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-divider);
  color: var(--c-text-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.as-section-title {
  font-size: var(--f-cap);
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 12rpx;
}
.as-list {
  margin-bottom: 24rpx;
}
.as-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-divider);
}
.as-row-selected {
  background: var(--c-primary-lightest);
  margin: 0 -16rpx;
  padding: 16rpx;
}
.as-body { flex: 1; min-width: 0; }
.as-name {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
}
.as-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.as-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}
.as-check-on {
  background: var(--c-primary);
  color: var(--c-text-inv);
  border-color: var(--c-primary);
}
.as-actions {
  display: flex;
  gap: 12rpx;
}
