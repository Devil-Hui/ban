<!-- pages/cal-edit-time/cal-edit-time.wxml —— 时间段日历编辑页（增强版） -->
<view class="page-cet">
  <!-- 顶部设置卡 -->
  <view class="setup-card">
    <view class="setup-title">基础设置</view>

    <!-- 时间范围 -->
    <view class="setup-row">
      <view class="sr-label">开始时间</view>
      <picker mode="time" value="{{startTime}}" bindchange="onStartChange">
        <view class="sr-value">{{startTime}} ▾</view>
      </picker>
    </view>
    <view class="setup-row">
      <view class="sr-label">结束时间</view>
      <picker mode="time" value="{{endTime}}" bindchange="onEndChange">
        <view class="sr-value">{{endTime}} ▾</view>
      </picker>
    </view>

    <!-- 结束时间快捷选择（基于开始时间的时长） -->
    <view class="setup-row setup-row-block">
      <view class="sr-label">结束时间快捷选择</view>
      <view class="sr-hint">选择时长后自动计算结束时间，选"自定义"可手动指定</view>
      <view class="interval-chips">
        <view wx:for="{{endDurationOptions}}" wx:key="value"
          class="ic-chip {{endDuration === item.value ? 'ic-active' : ''}}"
          bindtap="pickEndDuration"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 时间间隔 -->
    <view class="setup-row setup-row-block">
      <view class="sr-label">时间间隔（每时段时长）</view>
      <view class="interval-chips">
        <view wx:for="{{intervalOptions}}" wx:key="value"
          class="ic-chip {{interval === item.value ? 'ic-active' : ''}}"
          bindtap="pickInterval"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 人员约束 -->
    <view class="setup-row setup-row-block">
      <view class="sr-label">每时段最少人数</view>
      <view class="counter">
        <view class="counter-btn" bindtap="decMinPeople">−</view>
        <view class="counter-value">{{minPeople}}</view>
        <view class="counter-btn counter-btn-plus" bindtap="incMinPeople">＋</view>
        <view class="counter-unit">人</view>
      </view>
    </view>

    <view class="setup-row setup-row-block">
      <view class="sr-label">每人每周最大值班次数</view>
      <view class="sr-hint">限制每人每周最多被排几次班，避免过度排班</view>
      <view class="counter">
        <view class="counter-btn {{maxPerWeek === null ? 'disabled' : ''}}" bindtap="decMaxWeek">−</view>
        <view class="counter-value">{{maxPerWeek === null ? '不限' : maxPerWeek}}</view>
        <view class="counter-btn counter-btn-plus {{maxPerWeek === null ? 'disabled' : ''}}" bindtap="incMaxWeek">＋</view>
        <view class="counter-unit">次/周</view>
        <view class="counter-clear" bindtap="toggleMaxWeek">{{maxPerWeek === null ? '设置限制' : '取消限制'}}</view>
      </view>
    </view>

    <!-- 排班持续周数（原"排班周期"，重命名） -->
    <view class="setup-row setup-row-block">
      <view class="sr-label">排班持续周数</view>
      <view class="sr-hint">本次排班覆盖的周数，例如选 4 周则生成 4 周的排班表</view>
      <view class="cycle-row">
        <view wx:for="{{durationOptions}}" wx:key="key"
          class="cycle-chip {{durationWeeks === item.value ? 'cycle-active' : ''}}"
          bindtap="pickDuration"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 连续值班与休息 -->
    <view class="setup-row">
      <view class="sr-label">允许同一人连续值班</view>
      <view class="sr-hint">相邻时段是否允许同一人值守</view>
      <switch checked="{{allowContinuous}}" color="#7EC8E3" bindchange="toggleContinuous" />
    </view>

    <view class="setup-row setup-row-block">
      <view class="sr-label">班次间最短休息时间</view>
      <view class="interval-chips">
        <view wx:for="{{minRestOptions}}" wx:key="value"
          class="ic-chip {{minRestHours === item.value ? 'ic-active' : ''}}"
          bindtap="pickMinRest"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <!-- 日期范围 -->
    <view class="setup-row setup-row-block">
      <view class="sr-label">日期范围</view>
      <view class="date-row">
        <picker mode="date" value="{{dateStart}}" bindchange="onDateStart">
          <view class="date-picker">{{dateStart}}</view>
        </picker>
        <text class="date-sep">—</text>
        <picker mode="date" value="{{dateEnd}}" bindchange="onDateEnd">
          <view class="date-picker">{{dateEnd}}</view>
        </picker>
      </view>
    </view>

    <!-- 含周末开关 -->
    <view class="setup-row">
      <view class="sr-label">包含周末</view>
      <switch checked="{{includeWeekend}}" color="#7EC8E3" bindchange="toggleWeekend" />
    </view>

    <view class="setup-action" bindtap="generateGrid">
      <view class="ga-btn">生成周历</view>
    </view>
  </view>

  <!-- 摘要预览 -->
  <view wx:if="{{rows.length > 0}}" class="summary-bar">
    <view class="sb-cell">
      <view class="sb-num">{{rows.length}}</view>
      <view class="sb-label">时段</view>
    </view>
    <view class="sb-divider"></view>
    <view class="sb-cell">
      <view class="sb-num">{{selectedCount}}</view>
      <view class="sb-label">已选</view>
    </view>
    <view class="sb-divider"></view>
    <view class="sb-cell">
      <view class="sb-num">{{minPeople}}</view>
      <view class="sb-label">人/时段</view>
    </view>
    <view class="sb-divider"></view>
    <view class="sb-cell">
      <view class="sb-num">{{durationWeeks}}</view>
      <view class="sb-label">周</view>
    </view>
  </view>

  <!-- 周历网格 -->
  <view wx:if="{{rows.length > 0}}" class="cal-wrap">
    <view class="cal-info">
      <view class="ci-title">本周排班</view>
      <view class="ci-meta">已选 {{selectedCount}} / {{totalCells}} 格</view>
    </view>

    <!-- 日期表头（横向滚动） -->
    <scroll-view scroll-x class="cal-scroll" enable-flex>
      <view class="cal-table">
        <!-- 表头：时段列 + 7 天 -->
        <view class="cal-header">
          <view class="ch-cell ch-time">时段</view>
          <view wx:for="{{weekDays}}" wx:key="key" class="ch-cell ch-day {{item.isToday ? 'ch-today' : ''}} {{!includeWeekend && (item.idx === 5 || item.idx === 6) ? 'ch-cell-hidden' : ''}}">
            <view class="chd-weekday">{{item.weekday}}</view>
            <view class="chd-date">{{item.dateShort}}</view>
          </view>
        </view>

        <!-- 时段行 -->
        <view wx:for="{{rows}}" wx:key="rowIdx" class="cal-row">
          <view class="ch-cell ch-time">
            <view class="ct-start">{{item.start}}</view>
            <view class="ct-end">{{item.end}}</view>
          </view>
          <view wx:for="{{weekDays}}" wx:for-item="day" wx:key="key"
            class="cal-cell {{item.cells[day.idx].active ? 'cell-active' : 'cell-gray'}} {{!includeWeekend && (day.idx === 5 || day.idx === 6) ? 'cell-hidden' : ''}}"
            bindtap="toggleCell"
            data-row="{{item.rowIdx}}"
            data-day="{{day.idx}}"
          >
            <view wx:if="{{item.cells[day.idx].active}}" class="cell-check">✓</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 操作工具栏 -->
    <view class="toolbar">
      <view class="tb-item" bindtap="onClearAll">
        <view class="tb-icon tb-clear">清</view>
        <view class="tb-label">清空</view>
      </view>
      <view class="tb-item" bindtap="onFillAll">
        <view class="tb-icon tb-fill">填</view>
        <view class="tb-label">全选</view>
      </view>
      <view class="tb-item" bindtap="onSwipeDown">
        <view class="tb-icon tb-swipe">↓</view>
        <view class="tb-label">下滑排版</view>
      </view>
      <view class="tb-item" bindtap="onRandomFill">
        <view class="tb-icon tb-random">随机</view>
        <view class="tb-label">随机</view>
      </view>
      <view class="tb-item" bindtap="onInvert">
        <view class="tb-icon tb-invert">反</view>
        <view class="tb-label">反选</view>
      </view>
    </view>

    <view class="swipe-tip">提示：点击格子切换可选 · 灰色为不可选 · 下滑快速排版</view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="es-icon">📅</view>
    <view class="es-title">设置时间后点击"生成周历"</view>
    <view class="es-desc">将自动生成周一到周日的时间段网格</view>
  </view>

  <!-- 底部操作 -->
  <view wx:if="{{rows.length > 0}}" class="bottom-bar">
    <view class="btn btn-outline" bindtap="onSaveDraft">保存草稿</view>
    <view class="btn btn-primary" bindtap="onNext">下一步 · 设置排班规则</view>
  </view>

  <!-- 下滑排版说明弹层 -->
  <view wx:if="{{swipeGuide}}" class="mask" bindtap="closeSwipeGuide">
    <view class="guide-sheet" catchtap>
      <view class="gs-title">下滑排版说明</view>
      <view class="gs-item">
        <view class="gs-num">1</view>
        <view class="gs-text">手指从顶部时段向下拖动到末尾时段</view>
      </view>
      <view class="gs-item">
        <view class="gs-num">2</view>
        <view class="gs-text">系统自动将该列（当天）全部时段标记为空闲</view>
      </view>
      <view class="gs-item">
        <view class="gs-num">3</view>
        <view class="gs-text">再次点击已选格可取消</view>
      </view>
      <view class="gs-btn" bindtap="closeSwipeGuide">我知道了</view>
    </view>
  </view>
</view>
