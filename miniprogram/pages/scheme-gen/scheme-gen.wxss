/* pages/scheme-gen/scheme-gen.wxss */
.page-sg {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 200rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* 步骤 */
.steps {
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 16rpx;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.st-dot {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  color: var(--c-text-3);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}
.st-text { font-size: 20rpx; color: var(--c-text-3); }
.st-done .st-dot {
  background: var(--c-primary);
  border-color: var(--c-primary-dark);
  color: var(--c-text-inv);
}
.st-current .st-dot {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
}
.st-current .st-text { color: var(--c-primary-dark); font-weight: 600; }
.step-line {
  flex: 1;
  height: 4rpx;
  background: var(--c-border);
  margin: 0 8rpx;
  margin-bottom: 20rpx;
}
.st-line-done { background: var(--c-primary); }

/* 卡片 */
.card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}
.card-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.card-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
}
.card-badge-soft {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}
.card-desc {
  font-size: 22rpx;
  color: var(--c-text-3);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

/* 生成方式 */
.gen-modes {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}
.gm-item {
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20rpx 12rpx;
  text-align: center;
  transition: all 0.15s;
}
.gm-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
}
.gm-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.gm-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--c-text);
}
.gm-desc {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}

/* 限制条件 */
.cons-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.cons-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--c-primary-lightest);
  border-left: 6rpx solid var(--c-primary);
  border-radius: var(--r-md);
}
.cons-body { flex: 1; }
.cons-type {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--c-primary-dark);
}
.cons-detail {
  font-size: 22rpx;
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.cons-del {
  width: 44rpx; height: 44rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(232, 139, 139, 0.15);
  color: #C77;
  font-size: 28rpx;
}

.add-cons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border: 2rpx dashed var(--c-border);
  border-radius: var(--r-md);
  color: var(--c-primary-dark);
}
.ac-icon {
  font-size: 28rpx;
  font-weight: 600;
}
.ac-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 周切换器 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 16rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 周历表 */
.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname { text-align: center; padding: 4rpx 0; }
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
}
.cw-today { color: var(--c-primary-dark); font-weight: 600; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 100rpx;
}
.row-label-col {
  position: absolute;
  left: 0; top: 0;
  width: 100rpx;
}
.row-label {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text-3);
  border-right: 1rpx solid var(--c-divider);
}
.cal-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  height: 96rpx;
  margin-bottom: 4rpx;
}
.scell {
  background: var(--c-bg);
  border: 2rpx dashed var(--c-border);
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.scell:active { transform: scale(0.95); }
.scell-assigned {
  background: var(--c-primary);
  border: 2rpx solid var(--c-primary-dark);
  color: var(--c-text-inv);
}
.scell-locked {
  background: var(--c-divider);
  border-style: solid;
  opacity: 0.6;
}
.scell-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--c-text-inv);
}
.scell-lock { font-size: 24rpx; }
.scell-plus {
  font-size: 32rpx;
  color: var(--c-text-3);
}

/* 底部 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--c-card);
  box-shadow: 0 -2rpx 16rpx rgba(126, 200, 227, 0.10);
  z-index: 50;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--r-md);
  font-size: var(--f-sm);
  font-weight: 600;
}
.btn-outline {
  background: var(--c-bg);
  color: var(--c-text);
  border: 2rpx solid var(--c-border);
}
.btn-primary {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.bottom-spacer { height: 40rpx; }

/* 弹层通用 */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: 3rpx;
  margin: 0 auto 16rpx;
}
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.sheet-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
}
.sheet-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.sheet-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
  color: var(--c-text-3);
}
.sheet-tip {
  font-size: 20rpx;
  color: var(--c-text-3);
  background: var(--c-bg);
  padding: 12rpx 16rpx;
  border-radius: var(--r-sm);
  margin-bottom: 16rpx;
}

/* 头像 */
.pi-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 成员选择 */
.sheet-members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.sm-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
  background: var(--c-bg);
  border-radius: var(--r-pill);
  border: 2rpx solid transparent;
}
.sm-item .pi-avatar {
  width: 40rpx; height: 40rpx;
  font-size: 20rpx;
}
.sm-name {
  font-size: 22rpx;
  color: var(--c-text);
}
.sm-check {
  color: var(--c-primary-dark);
  font-size: 24rpx;
  font-weight: 600;
}
.sm-assigned {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
}

.sheet-actions {
  display: flex;
  gap: 12rpx;
}
.sa-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--r-md);
  font-size: var(--f-sm);
  font-weight: 600;
}
.sa-clear {
  background: var(--c-bg);
  color: #C77;
  border: 2rpx solid rgba(232, 139, 139, 0.3);
}
.sa-confirm {
  background: var(--c-primary);
  color: var(--c-text-inv);
}

/* 条件类型选择 */
.cons-types {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.ct-item {
  padding: 12rpx 24rpx;
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-pill);
  font-size: 22rpx;
  color: var(--c-text-2);
}
.ct-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
  font-weight: 600;
}

.cons-config {
  background: var(--c-bg);
  padding: 24rpx;
  border-radius: var(--r-md);
  margin-bottom: 16rpx;
}
.cc-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
  flex-wrap: wrap;
}
.counter {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--c-card);
  border-radius: var(--r-sm);
  padding: 4rpx;
}
.cb {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  border-radius: var(--r-sm);
  font-size: 32rpx;
  font-weight: 600;
}
.cv {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
}
