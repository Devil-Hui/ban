<!-- pages/scheme-gen/scheme-gen.wxml —— 排班方案生成页 -->
<view class="page-sg">
  <!-- 步骤指示器 -->
  <view class="steps">
    <view class="step-item st-done"><view class="st-dot">✓</view><view class="st-text">样式</view></view>
    <view class="step-line st-line-done"></view>
    <view class="step-item st-done"><view class="st-dot">✓</view><view class="st-text">人员</view></view>
    <view class="step-line st-line-done"></view>
    <view class="step-item st-done"><view class="st-dot">✓</view><view class="st-text">收集</view></view>
    <view class="step-line st-line-done"></view>
    <view class="step-item st-current"><view class="st-dot">4</view><view class="st-text">发布</view></view>
  </view>

  <!-- 生成方式 -->
  <view class="card">
    <view class="card-title">生成方式</view>
    <view class="gen-modes">
      <view class="gm-item {{mode === 'manual' ? 'gm-active' : ''}}" bindtap="pickMode" data-mode="manual">
        <view class="gm-icon">✎</view>
        <view class="gm-name">手动指派</view>
        <view class="gm-desc">逐格点击指派</view>
      </view>
      <view class="gm-item {{mode === 'random' ? 'gm-active' : ''}}" bindtap="pickMode" data-mode="random">
        <view class="gm-icon">🎲</view>
        <view class="gm-name">随机生成</view>
        <view class="gm-desc">按条件随机分配</view>
      </view>
      <view class="gm-item {{mode === 'smart' ? 'gm-active' : ''}}" bindtap="pickMode" data-mode="smart">
        <view class="gm-icon">✦</view>
        <view class="gm-name">智能推荐</view>
        <view class="gm-desc">依据历史偏好</view>
      </view>
    </view>
  </view>

  <!-- 限制条件 -->
  <view class="card">
    <view class="card-title">限制条件 <text class="card-badge card-badge-soft">{{constraints.length}}</text></view>
    <view class="card-desc">可选，用于约束生成方案</view>

    <view class="cons-list">
      <view wx:for="{{constraints}}" wx:key="id" class="cons-item">
        <view class="cons-body">
          <view class="cons-type">{{item.typeLabel}}</view>
          <view class="cons-detail">{{item.detail}}</view>
        </view>
        <view class="cons-del" bindtap="removeConstraint" data-id="{{item.id}}">×</view>
      </view>
    </view>

    <view class="add-cons" bindtap="onAddConstraint">
      <view class="ac-icon">＋</view>
      <view class="ac-text">添加限制条件</view>
    </view>
  </view>

  <!-- 生成的方案表格 -->
  <view class="card">
    <view class="card-title">
      排班方案 <text class="card-badge card-badge-soft">{{assignedCount}}/{{totalCells}}</text>
    </view>
    <view class="card-desc">点击空格可手动指派成员</view>

    <!-- 周切换器 -->
    <view class="week-nav">
      <view class="wn-arrow" bindtap="prevWeek">‹</view>
      <view class="wn-label">{{calWeekLabel}}</view>
      <view class="wn-arrow" bindtap="nextWeek">›</view>
    </view>

    <view class="cal-headrow">
      <view class="cal-weekname" wx:for="{{weekDays}}" wx:key="key">
        <view class="cw-day {{item.isToday ? 'cw-today' : ''}}">{{item.weekday}}</view>
        <view class="cw-date">{{item.dateShort}}</view>
      </view>
    </view>

    <scroll-view scroll-x class="cal-scroll" enhanced show-scrollbar="{{false}}">
      <view class="cal-table">
        <view class="row-label-col">
          <view wx:for="{{rows}}" wx:key="rowIdx" class="row-label">{{item.start}}</view>
        </view>
        <view wx:for="{{rows}}" wx:key="rowIdx" class="cal-row">
          <view
            wx:for="{{item.cells}}"
            wx:for-item="cell"
            wx:for-index="dIdx"
            wx:key="dIdx"
            class="scell {{cell.assigned ? 'scell-assigned' : ''}} {{cell.locked ? 'scell-locked' : ''}}"
            data-row="{{item.rowIdx}}"
            data-day="{{dIdx}}"
            bindtap="onCellTap"
          >
            <view wx:if="{{cell.assigned}}" class="scell-name">{{cell.memberName}}</view>
            <view wx:elif="{{cell.locked}}" class="scell-lock">🔒</view>
            <view wx:else class="scell-plus">＋</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部 -->
  <view class="bottom-bar">
    <view class="btn btn-outline" bindtap="onReGen">{{mode === 'manual' ? '清空' : '重新生成'}}</view>
    <view class="btn btn-primary {{publishing ? 'btn-disabled' : ''}}" bindtap="onPublish">{{publishing ? '发布中…' : '发布公示'}}</view>
  </view>

  <view class="bottom-spacer"></view>
</view>

<!-- 指派成员弹层 -->
<view wx:if="{{assignSheet}}" class="sheet-mask" bindtap="closeAssign">
  <view class="sheet" catchtap="">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-title">{{assignInfo.timeLabel}}</view>
        <view class="sheet-sub">{{assignInfo.dayLabel}} · {{assignInfo.availableCount}} 人可选</view>
      </view>
      <view class="sheet-close" bindtap="closeAssign">✕</view>
    </view>
    <view class="sheet-tip">仅可指派在该时段标记为可用的成员</view>
    <view class="sheet-members">
      <view
        wx:for="{{assignInfo.members}}"
 wx:key="id"
        class="sm-item {{item.assigned ? 'sm-assigned' : ''}}"
        bindtap="onPickMember"
        data-id="{{item.id}}"
      >
        <view class="pi-avatar">{{item.initial}}</view>
        <view class="sm-name">{{item.name}}</view>
        <view wx:if="{{item.assigned}}" class="sm-check">✓</view>
      </view>
    </view>
    <view class="sheet-actions">
      <view class="sa-btn sa-clear" bindtap="onClearCell">清空该格</view>
      <view class="sa-btn sa-confirm" bindtap="closeAssign">完成</view>
    </view>
  </view>
</view>

<!-- 添加条件弹层 -->
<view wx:if="{{consSheet}}" class="sheet-mask" bindtap="closeCons">
  <view class="sheet" catchtap="">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-title">添加限制条件</view>
        <view class="sheet-sub">选择条件类型并设置</view>
      </view>
      <view class="sheet-close" bindtap="closeCons">✕</view>
    </view>
    <view class="cons-types">
      <view
        wx:for="{{consTypes}}"
        wx:key="key"
        class="ct-item {{consType === item.key ? 'ct-active' : ''}}"
        bindtap="pickConsType"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </view>
    <view class="cons-config">
      <view wx:if="{{consType === 'limit-one'}}" class="cc-row">
        <text>在风险区域每个时段仅限</text>
        <view class="counter">
          <view class="cb" bindtap="decLimit">-</view>
          <view class="cv">{{limitValue}}</view>
          <view class="cb" bindtap="incLimit">+</view>
        </view>
        <text>人</text>
      </view>
      <view wx:elif="{{consType === 'max-day'}}" class="cc-row">
        <text>每人每天最多</text>
        <view class="counter">
          <view class="cb" bindtap="decLimit">-</view>
          <view class="cv">{{limitValue}}</view>
          <view class="cb" bindtap="incLimit">+</view>
        </view>
        <text>个时段</text>
      </view>
      <view wx:elif="{{consType === 'max-week'}}" class="cc-row">
        <text>每人每周最多</text>
        <view class="counter">
          <view class="cb" bindtap="decLimit">-</view>
          <view class="cv">{{limitValue}}</view>
          <view class="cb" bindtap="incLimit">+</view>
        </view>
        <text>个时段</text>
      </view>
      <view wx:elif="{{consType === 'fair'}}" class="cc-row">
        <text>尽量平均分配，差异不超过</text>
        <view class="counter">
          <view class="cb" bindtap="decLimit">-</view>
          <view class="cv">{{limitValue}}</view>
          <view class="cb" bindtap="incLimit">+</view>
        </view>
        <text>个</text>
      </view>
    </view>
    <view class="sheet-actions">
      <view class="sa-btn sa-confirm" bindtap="confirmAddCons">添加条件</view>
    </view>
  </view>
</view>
