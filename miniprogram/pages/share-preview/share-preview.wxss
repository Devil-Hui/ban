/* pages/share-preview/share-preview.wxss —— 分享预览页样式 */

.page-share {
  min-height: 100vh;
  padding: var(--s-md);
  /* 底部留足 bottom-bar 高度 + safe-area */
  padding-bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* —— 顶部 banner —— */
.share-banner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: var(--c-primary-lighter);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: var(--s-md);
}
.share-banner-joiner {
  background: linear-gradient(135deg, rgba(245, 185, 122, 0.18) 0%, rgba(232, 155, 79, 0.12) 100%);
}
.sb-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.share-banner-joiner .sb-icon {
  background: linear-gradient(135deg, #F5B97A 0%, #E89B4F 100%);
}
.sb-body { flex: 1; min-width: 0; }
.sb-title {
  font-size: 28rpx;
  color: var(--c-primary-dark);
  font-weight: 600;
}
.share-banner-joiner .sb-title { color: #8C5A1F; }
.sb-desc {
  font-size: 22rpx;
  color: var(--c-primary-dark);
  opacity: 0.8;
  margin-top: 4rpx;
}
.share-banner-joiner .sb-desc { color: #8C5A1F; }

/* —— 分组信息卡 —— */
.group-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #F5FBFD 100%);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: var(--s-md);
}
.gc-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--c-divider);
}
.gc-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--r-md);
  background: linear-gradient(135deg, #B8DDE9 0%, #7EC8E3 100%);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}
.gc-info { flex: 1; min-width: 0; }
.gc-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}
.gc-meta {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dot-sep { color: var(--c-divider); }
.tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
  flex-shrink: 0;
}
.tag-primary {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}

.gc-task {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.gct-label {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-bottom: 6rpx;
}
.gct-title {
  font-size: 30rpx;
  color: var(--c-text);
  font-weight: 600;
}
.gct-meta {
  font-size: 22rpx;
  color: var(--c-text-2);
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}
.gct-remark {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  background: var(--c-primary-lighter);
  border-left: 4rpx solid var(--c-primary);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: var(--c-primary-dark);
  line-height: 1.5;
}

/* —— 段落标题 —— */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 8rpx 4rpx 16rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
  letter-spacing: 0.5rpx;
}
.section-tip {
  font-size: 22rpx;
  color: var(--c-text-3);
}

/* —— 分享名单卡片 —— */
.names-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: var(--s-md);
}
.names-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.name-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx 12rpx 12rpx;
  background: var(--c-primary-lighter);
  border-radius: var(--r-pill);
  min-width: 140rpx;
}
.nc-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--c-primary-light) 0%, var(--c-primary) 100%);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.nc-name {
  font-size: 26rpx;
  color: var(--c-text);
  font-weight: 500;
}
.names-empty {
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.ne-icon {
  font-size: 56rpx;
  opacity: 0.4;
}
.ne-text {
  font-size: 22rpx;
  color: var(--c-text-3);
}

/* —— 按周日历卡片 —— */
.week-cal-card {
  background: linear-gradient(180deg, var(--c-card) 0%, #FAFCFE 100%);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx 20rpx 20rpx;
  margin-bottom: var(--s-md);
}
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 20rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 周表头：周一到周日 */
.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname { text-align: center; padding: 4rpx 0; }
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
  line-height: 1.2;
}
.cw-today { color: var(--c-primary-dark); font-weight: 700; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cw-today + .cw-date { color: var(--c-primary); }

/* 时段行 × 7 天单元格 */
.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  min-width: 100%;
}
.row-label-col {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
}
.row-label {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--c-bg);
  border-radius: var(--r-sm);
  margin-bottom: 8rpx;
  padding: 4rpx;
}
.rl-time {
  font-size: 22rpx;
  color: var(--c-text);
  font-weight: 600;
  text-align: center;
  line-height: 1.3;
  word-break: break-all;
}
.cal-row {
  display: flex;
  flex: 1;
}
.sh-cell {
  flex: 1;
  min-width: 88rpx;
  height: 120rpx;
  margin: 0 4rpx 8rpx;
  background: var(--c-bg);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 6rpx 4rpx;
  box-sizing: border-box;
}
.sh-cell-filled {
  background: var(--c-primary-lighter);
  border: 1rpx solid rgba(126, 200, 227, 0.5);
}
.sh-empty {
  font-size: 28rpx;
  color: var(--c-text-3);
  font-weight: 300;
}

/* 指派信息（脱敏姓名 + 脱敏手机号） */
.assignee-chip {
  background: var(--c-card);
  border-radius: var(--r-sm);
  padding: 4rpx 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  width: 100%;
  box-sizing: border-box;
}
.ac-name {
  font-size: 20rpx;
  color: var(--c-text);
  font-weight: 600;
  line-height: 1.2;
}
.ac-phone {
  font-size: 16rpx;
  color: var(--c-text-3);
  letter-spacing: 0.3rpx;
  line-height: 1.2;
}

.wc-tip {
  margin-top: 16rpx;
  font-size: 20rpx;
  color: var(--c-text-3);
  text-align: center;
  line-height: 1.5;
}

/* —— 隐私说明 —— */
.privacy-card {
  display: flex;
  gap: 14rpx;
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: 18rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: var(--s-md);
}
.pc-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}
.pc-body { flex: 1; min-width: 0; }
.pc-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 6rpx;
}
.pc-desc {
  font-size: 22rpx;
  color: var(--c-text-2);
  line-height: 1.7;
}

/* —— 底部操作栏 —— */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--c-card);
  box-shadow: 0 -2rpx 16rpx rgba(126, 200, 227, 0.10);
  z-index: 50;
}
.bb-info { flex: 1; min-width: 0; }
.bb-title {
  font-size: 26rpx;
  color: var(--c-text);
  font-weight: 600;
}
.bb-desc {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}

/* —— 通用按钮 —— */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
  border-radius: var(--r-pill);
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}
.btn::after { border: none; }
.btn-primary {
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  color: var(--c-text-inv);
  box-shadow: 0 4rpx 12rpx rgba(126, 200, 227, 0.35);
}
.btn-outline-disabled {
  background: var(--c-bg);
  color: var(--c-text-3);
  border: 1rpx solid var(--c-border);
  pointer-events: none;
}
