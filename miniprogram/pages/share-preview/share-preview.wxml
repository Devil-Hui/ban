<!-- pages/share-preview/share-preview.wxml —— 分享预览页（API 脱敏 / 本地兼容） -->
<view class="page-share">
  <view wx:if="{{loading}}" class="share-banner">
    <view class="sb-body">
      <view class="sb-title">加载预览…</view>
      <view class="sb-desc">正在校验分享凭证</view>
    </view>
  </view>
  <view wx:elif="{{error}}" class="share-banner share-banner-joiner">
    <view class="sb-icon">!</view>
    <view class="sb-body">
      <view class="sb-title">无法打开预览</view>
      <view class="sb-desc">{{error}}</view>
    </view>
  </view>

  <!-- 顶部说明条：根据 role 显示不同文案 -->
  <view class="share-banner" wx:if="{{!loading && !error && role === 'publisher'}}">
    <view class="sb-icon">📤</view>
    <view class="sb-body">
      <view class="sb-title">已选定 {{names.length}} 名成员</view>
      <view class="sb-desc">分享给成员后，他们将确认自己的可用时间表</view>
    </view>
  </view>
  <view class="share-banner share-banner-joiner" wx:else>
    <view class="sb-icon">📩</view>
    <view class="sb-body">
      <view class="sb-title">{{groupInfo.name}} 邀请你确认时间表</view>
      <view class="sb-desc">查看排班后点击「我已确认」即可填写可用时间</view>
    </view>
  </view>

  <!-- 分组信息卡 -->
  <view class="group-card">
    <view class="gc-head">
      <view class="gc-avatar">{{groupInfo.initial}}</view>
      <view class="gc-info">
        <view class="gc-name">{{groupInfo.name}}</view>
        <view class="gc-meta">
          <text>{{groupInfo.memberCount}} 人参与</text>
          <text class="dot-sep">·</text>
          <text>{{groupInfo.taskCount}} 个任务</text>
        </view>
      </view>
      <view class="tag tag-primary">{{groupInfo.cycleLabel}}</view>
    </view>

    <!-- 任务摘要 -->
    <view class="gc-task">
      <view class="gct-label">本任务</view>
      <view class="gct-title">{{task.title}}</view>
      <view class="gct-meta">
        <text>{{task.dateRange}}</text>
        <text class="dot-sep">·</text>
        <text>{{task.periodCount}} 时段/天</text>
        <text class="dot-sep">·</text>
        <text>已发布 {{task.publishedAt}}</text>
      </view>
      <view wx:if="{{task.remark}}" class="gct-remark">备注：{{task.remark}}</view>
    </view>
  </view>

  <!-- 分享名单（发布者选定的成员） -->
  <view class="section-head">
    <text class="section-title">分享名单（{{names.length}} 人）</text>
    <text class="section-tip">发布者已选定</text>
  </view>
  <view class="names-card">
    <view wx:if="{{names.length > 0}}" class="names-grid">
      <view wx:for="{{names}}" wx:key="id" class="name-chip">
        <view class="nc-avatar">{{item.initial}}</view>
        <view class="nc-name">{{item.name}}</view>
      </view>
    </view>
    <view wx:else class="names-empty">
      <view class="ne-icon">👥</view>
      <view class="ne-text">暂无选定名单</view>
    </view>
  </view>

  <!-- 排班表（按周横向展示，脱敏） -->
  <view class="section-head">
    <text class="section-title">排班表（按周）</text>
    <text class="section-tip">姓名 + 脱敏手机号</text>
  </view>

  <view class="week-cal-card">
    <!-- 周切换器 -->
    <view class="week-nav">
      <view class="wn-arrow" bindtap="prevWeek">‹</view>
      <view class="wn-label">{{calWeekLabel}}</view>
      <view class="wn-arrow" bindtap="nextWeek">›</view>
    </view>

    <!-- 周表头：周一到周日 -->
    <view class="cal-headrow">
      <view class="cal-weekname" wx:for="{{weekDays}}" wx:key="key">
        <view class="cw-day {{item.isToday ? 'cw-today' : ''}}">{{item.weekday}}</view>
        <view class="cw-date">{{item.dateShort}}</view>
      </view>
    </view>

    <!-- 时段行 × 7 天单元格 -->
    <scroll-view scroll-x class="cal-scroll" enhanced show-scrollbar="{{false}}">
      <view class="cal-table">
        <!-- 左侧时段标签列 -->
        <view class="row-label-col">
          <view wx:for="{{rows}}" wx:key="rowIdx" class="row-label">
            <view class="rl-time">{{item.label}}</view>
          </view>
        </view>
        <!-- 7 天单元格 -->
        <view wx:for="{{rows}}" wx:key="rowIdx" class="cal-row">
          <view
            wx:for="{{item.cells}}"
            wx:for-item="cell"
            wx:for-index="dIdx"
            wx:key="dIdx"
            class="sh-cell {{cell.assignees.length > 0 ? 'sh-cell-filled' : ''}}"
          >
            <block wx:if="{{cell.assignees.length > 0}}">
              <view wx:for="{{cell.assignees}}" wx:for-item="a" wx:key="maskedPhone" class="assignee-chip">
                <view class="ac-name">{{a.maskedName}}</view>
                <view class="ac-phone">{{a.maskedPhone}}</view>
              </view>
            </block>
            <view wx:else class="sh-empty">—</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="wc-tip">横向为周一到周日 · 时段按创建时原貌显示</view>
  </view>

  <!-- 隐私说明 -->
  <view class="privacy-card">
    <view class="pc-icon">🔒</view>
    <view class="pc-body">
      <view class="pc-title">隐私保护</view>
      <view class="pc-desc">
        · 姓名仅显示首字 + 「同学」，如「小同学」<br/>
        · 手机号中间 4 位已脱敏，如 138****1234<br/>
        · 微信号永不展示，无法添加好友<br/>
        · 加入分组并登录后可见完整信息
      </view>
    </view>
  </view>

  <!-- 底部操作：根据角色显示 -->
  <view class="bottom-bar" wx:if="{{role === 'publisher'}}">
    <view class="bb-info">
      <view class="bb-title">分享给成员确认</view>
      <view class="bb-desc">成员查看后可确认自己的可用时间</view>
    </view>
    <button class="btn btn-primary" open-type="share">立即分享</button>
  </view>

  <view class="bottom-bar" wx:else>
    <view class="bb-info">
      <view class="bb-title" wx:if="{{!confirmed}}">请确认时间表</view>
      <view class="bb-title" wx:else>已确认 · {{confirmedAt}}</view>
      <view class="bb-desc" wx:if="{{!confirmed}}">确认后可填写自己的可用时间</view>
      <view class="bb-desc" wx:else>正在跳转到可用时间填写…</view>
    </view>
    <view
      class="btn {{confirmed ? 'btn-outline-disabled' : 'btn-primary'}}"
      bindtap="onConfirm"
    >{{confirmed ? '已确认 ✓' : '我已确认'}}</view>
  </view>
</view>
