<!-- pages/cal-edit-custom/cal-edit-custom.wxml —— 自定义日历编辑页（兼具时间段+节次） -->
<view class="page-cec">
  <!-- 顶部设置卡 -->
  <view class="setup-card">
    <view class="setup-title">自定义设置</view>

    <view class="setup-row">
      <view class="sr-label">起始时间</view>
      <picker mode="time" value="{{startTime}}" bindchange="onStartChange">
        <view class="sr-value">{{startTime}}</view>
      </picker>
    </view>

    <view class="setup-row">
      <view class="sr-label">节次数</view>
      <view class="stepper">
        <view class="sp-btn" bindtap="decPeriod">−</view>
        <view class="sp-val">{{periodCount}}</view>
        <view class="sp-btn" bindtap="incPeriod">＋</view>
      </view>
    </view>

    <view class="setup-row">
      <view class="sr-label">每节时长</view>
      <picker mode="selector" range="{{durationOptions}}" range-key="label" value="{{durationIdx}}" bindchange="onDurationChange">
        <view class="sr-value">{{durationOptions[durationIdx].label}}</view>
      </picker>
    </view>

    <!-- 双标签预览 -->
    <view class="dual-preview">
      <view wx:for="{{rows}}" wx:key="rowIdx" class="dp-item">
        <view class="dp-period">第{{item.cnIdx}}节</view>
        <view class="dp-time">{{item.start}} — {{item.end}}</view>
      </view>
    </view>

    <view class="setup-action" bindtap="generateGrid">
      <view class="ga-btn">生成周历</view>
    </view>
  </view>

  <!-- 周历网格（左侧同时显示节次+时间） -->
  <view wx:if="{{rows.length > 0}}" class="cal-wrap">
    <view class="cal-info">
      <view class="ci-title">本周排班（节次+时间）</view>
      <view class="ci-meta">已选 {{selectedCount}} 格 · 共 {{totalCells}} 格</view>
    </view>

    <scroll-view scroll-x class="cal-scroll" enable-flex>
      <view class="cal-table">
        <view class="cal-header">
          <view class="ch-cell ch-time ch-time-wide">节次 / 时间</view>
          <view wx:for="{{weekDays}}" wx:key="key" class="ch-cell ch-day {{item.isToday ? 'ch-today' : ''}}">
            <view class="chd-weekday">{{item.weekday}}</view>
            <view class="chd-date">{{item.dateShort}}</view>
          </view>
        </view>

        <view wx:for="{{rows}}" wx:key="rowIdx" class="cal-row">
          <view class="ch-cell ch-time ch-time-wide">
            <view class="ct-period">第{{item.cnIdx}}节</view>
            <view class="ct-time">{{item.start}}-{{item.end}}</view>
          </view>
          <view wx:for="{{weekDays}}" wx:for-item="day" wx:key="key"
            class="cal-cell {{item.cells[day.idx].active ? 'cell-active' : 'cell-gray'}}"
            bindtap="toggleCell"
            data-row="{{item.rowIdx}}"
            data-day="{{day.idx}}"
          >
            <view wx:if="{{item.cells[day.idx].active}}" class="cell-check">✓</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="toolbar">
      <view class="tb-item" bindtap="onClearAll">
        <view class="tb-icon tb-clear">清</view>
        <view class="tb-label">清空</view>
      </view>
      <view class="tb-item" bindtap="onFillAll">
        <view class="tb-icon tb-fill">填</view>
        <view class="tb-label">全选</view>
      </view>
      <view class="tb-item" bindtap="onSwipeDown">
        <view class="tb-icon tb-swipe">↓</view>
        <view class="tb-label">下滑排版</view>
      </view>
      <view class="tb-item" bindtap="onRandomFill">
        <view class="tb-icon tb-random">随机</view>
        <view class="tb-label">随机</view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="es-icon">✦</view>
    <view class="es-title">自定义样式</view>
    <view class="es-desc">同时显示节次和时间，灵活组合</view>
  </view>

  <view wx:if="{{rows.length > 0}}" class="bottom-bar">
    <view class="btn btn-outline" bindtap="onSaveDraft">保存草稿</view>
    <view class="btn btn-primary" bindtap="onNext">下一步 · 设置人员</view>
  </view>

  <view wx:if="{{swipeGuide}}" class="mask" bindtap="closeSwipeGuide">
    <view class="guide-sheet" catchtap>
      <view class="gs-title">下滑排版</view>
      <view class="gs-item">
        <view class="gs-num">1</view>
        <view class="gs-text">从首行向末行拖动</view>
      </view>
      <view class="gs-item">
        <view class="gs-num">2</view>
        <view class="gs-text">当天所有节次+时段标记为空闲</view>
      </view>
      <view class="gs-btn" bindtap="closeSwipeGuide">我知道了</view>
    </view>
  </view>
</view>
