/* pages/cal-edit-custom/cal-edit-custom.wxss */
@import "/pages/cal-edit-time/cal-edit-time.wxss";

/* 自定义：左侧加宽显示节次+时间 */
.ch-time-wide {
  width: 180rpx !important;
}

.ct-period {
  font-size: 22rpx;
  color: var(--c-text);
  font-weight: 600;
}
.ct-time {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-pill);
  padding: 4rpx 8rpx;
}
.sp-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.sp-val {
  font-size: var(--f-sm);
  color: var(--c-text);
  font-weight: 600;
  min-width: 40rpx;
  text-align: center;
}

.dual-preview {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.dp-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.dp-period {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 600;
}
.dp-time {
  font-size: 22rpx;
  color: var(--c-text-3);
  font-family: monospace;
}
