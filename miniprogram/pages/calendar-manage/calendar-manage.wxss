/* pages/calendar-manage/calendar-manage.wxss —— 个人日历管理样式 */

.page-cal {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: 80rpx;
  background: var(--c-bg);
}

/* —— Hero —— */
.cal-hero {
  background: linear-gradient(135deg, #E8F4F8 0%, #C5E5F0 100%);
  border-radius: var(--r-lg);
  box-shadow: 0 4rpx 20rpx rgba(126, 200, 227, 0.18);
  padding: 32rpx 28rpx;
  margin-bottom: var(--s-md);
}
.hero-top { margin-bottom: 22rpx; }
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C5872;
  letter-spacing: 1rpx;
}
.hero-sub {
  font-size: var(--f-small);
  color: #5A8BA5;
  margin-top: 8rpx;
}
.hero-stats {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(91, 175, 218, 0.2);
}
.hs-cell { flex: 1; text-align: center; }
.hs-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C5872;
  line-height: 1;
}
.hs-label {
  font-size: var(--f-tiny);
  color: #5A8BA5;
  margin-top: 6rpx;
}
.hs-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(91, 175, 218, 0.25);
}

/* —— 新建日历入口 —— */
.create-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: var(--s-md);
}
.create-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.15s;
}
.create-card:active { transform: scale(0.98); }
.cc-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--r-md);
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}
.cc-icon-ai {
  background: linear-gradient(135deg, #E5F0FA 0%, #C8DFFF 100%);
  color: #4A6FA5;
}
.cc-body { flex: 1; min-width: 0; }
.cc-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.cc-tag {
  background: linear-gradient(135deg, #7EC8E3 0%, #5BAFDA 100%);
  color: #FFF;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.cc-desc {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.cc-arrow {
  color: var(--c-text-3);
  font-size: 36rpx;
  line-height: 1;
}

/* —— 段落标题 —— */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 8rpx 4rpx 16rpx;
}
.section-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  letter-spacing: 0.5rpx;
}
.section-tip {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}

/* —— 日历列表 —— */
.cal-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.cal-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 22rpx 24rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.cal-card:active { transform: scale(0.98); }
.cal-card-active {
  border-color: var(--c-primary);
  background: linear-gradient(180deg, #F5FBFD 0%, var(--c-card) 100%);
}
.cal-card-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cal-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}
.cal-icon-manual {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}
.cal-icon-ai {
  background: linear-gradient(135deg, #E5F0FA 0%, #C8DFFF 100%);
  color: #4A6FA5;
}
.cal-info { flex: 1; min-width: 0; }
.cal-name {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cal-active-tag {
  background: var(--c-primary);
  color: var(--c-text-inv);
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
}
.cal-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dot-sep { color: var(--c-divider); }
.cal-arrow {
  color: var(--c-text-3);
  font-size: 36rpx;
  line-height: 1;
}

.cal-ai-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
  padding: 10rpx 14rpx;
  background: #F0F6FB;
  border-radius: var(--r-sm);
}
.ai-badge {
  background: linear-gradient(135deg, #7EC8E3 0%, #5BAFDA 100%);
  color: #FFF;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
}
.ai-text {
  font-size: var(--f-tiny);
  color: #4A6FA5;
}
.ai-warn {
  font-size: var(--f-tiny);
  color: #C97A3A;
  margin-left: auto;
}

.cal-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--c-divider);
}
.preview-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--c-bg);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}
.pc-day {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  font-weight: 600;
}
.pc-time {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
}
.preview-more {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  padding: 6rpx 10rpx;
}

/* —— 空状态 —— */
.empty-state {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 60rpx 32rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}
.empty-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 16rpx;
  font-weight: 700;
}
.empty-title {
  font-size: var(--f-body);
  color: var(--c-text);
  font-weight: 600;
}
.empty-desc {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 6rpx;
  margin-bottom: 24rpx;
}

/* —— 使用提示 —— */
.tip-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-top: var(--s-md);
  box-shadow: var(--shadow-card);
}
.tip-title {
  font-size: var(--f-small);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 14rpx;
}
.tip-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  line-height: 1.6;
  margin-bottom: 10rpx;
}
.tip-num {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.footer-note {
  text-align: center;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 32rpx;
}

/* —— 弹层通用 —— */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(20, 40, 60, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.sheet {
  width: 100%;
  max-height: 88vh;
  overflow-y: auto;
  background: var(--c-card);
  border-radius: 28rpx 28rpx 0 0;
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 36rpx);
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.sheet-title {
  font-size: var(--f-title);
  font-weight: 700;
  color: var(--c-text);
}
.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text-2);
  font-size: 28rpx;
}
.sheet-body { padding-bottom: 12rpx; }

.sheet-section { margin-bottom: 18rpx; }
.ss-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-bottom: 8rpx;
}
.ss-input {
  width: 100%;
  background: var(--c-bg);
  border-radius: var(--r-md);
  padding: 18rpx 20rpx;
  font-size: var(--f-body);
  color: var(--c-text);
  box-sizing: border-box;
  border: 1rpx solid var(--c-divider);
}
.ph { color: var(--c-text-3); }

.cycle-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.cycle-chip {
  padding: 12rpx 24rpx;
  background: var(--c-bg);
  color: var(--c-text-2);
  font-size: var(--f-small);
  border-radius: 999rpx;
  border: 1rpx solid var(--c-divider);
}
.cycle-active {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  border-color: var(--c-primary);
  font-weight: 600;
}

.slots-tip {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-bottom: 12rpx;
}
.slots-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.slots-grid-day {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.sgd-label {
  width: 60rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  flex-shrink: 0;
}
.sgd-cells {
  flex: 1;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.sgd-cell {
  flex: 1;
  min-width: 100rpx;
  text-align: center;
  padding: 12rpx 0;
  background: var(--c-bg);
  color: var(--c-text-2);
  font-size: var(--f-tiny);
  border-radius: var(--r-sm);
  border: 1rpx solid var(--c-divider);
}
.sgd-cell-active {
  background: var(--c-primary);
  color: var(--c-text-inv);
  border-color: var(--c-primary);
  font-weight: 600;
}

.sheet-warn {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #FFF5E8;
  border-radius: var(--r-md);
  padding: 14rpx 18rpx;
  font-size: var(--f-tiny);
  color: #8A6644;
  line-height: 1.5;
  margin-top: 12rpx;
}

/* —— 自定义时段 —— */
.custom-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  flex-wrap: nowrap;
}
.custom-day,
.custom-time {
  flex: 0 0 auto;
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  padding: 0 16rpx;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  border-radius: var(--r-sm);
  font-size: var(--f-cap);
  box-sizing: border-box;
}
.custom-time { min-width: 130rpx; }
.custom-sep {
  color: var(--c-text-3);
  font-size: var(--f-cap);
}
.custom-add {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  font-size: var(--f-cap);
}

.custom-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 12rpx;
}
.custom-slot-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-sm);
  border: 1rpx solid var(--c-border);
}
.csi-day {
  font-size: var(--f-cap);
  color: var(--c-text-2);
  min-width: 90rpx;
}
.csi-time {
  flex: 1;
  font-size: var(--f-cap);
  color: var(--c-text);
  font-family: monospace;
}
.csi-del {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(232, 139, 139, 0.15);
  color: #C77;
  font-size: 28rpx;
}
.sheet-warn-neutral {
  background: var(--c-bg);
  color: var(--c-text-2);
}
.sw-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #F5C46B;
  color: #FFF;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.sheet-warn-neutral .sw-icon { background: var(--c-text-3); }

.sheet-foot {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
}
.btn-block {
  width: 100%;
  padding: 22rpx 0;
  font-size: var(--f-body);
  border-radius: var(--r-md);
}
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* —— AI 上传 —— */
.ai-upload {
  background: var(--c-bg);
  border-radius: var(--r-md);
  padding: 60rpx 24rpx;
  text-align: center;
  margin-bottom: 18rpx;
  border: 2rpx dashed var(--c-primary);
}
.ai-upload-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}
.ai-upload-text {
  font-size: var(--f-body);
  color: var(--c-text);
  font-weight: 600;
}
.ai-upload-tip {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.ai-preview {
  width: 100%;
  max-height: 400rpx;
  border-radius: var(--r-sm);
}
.ai-reupload {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  margin-top: 12rpx;
}

.ai-progress {
  margin: 20rpx 0;
}
.ai-progress-bar {
  height: 6rpx;
  background: var(--c-divider);
  border-radius: 999rpx;
  overflow: hidden;
}
.ai-progress-inner {
  height: 100%;
  width: 60%;
  background: linear-gradient(90deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  border-radius: 999rpx;
  animation: progress 1.2s ease-in-out infinite;
}
@keyframes progress {
  0% { width: 20%; }
  50% { width: 80%; }
  100% { width: 20%; }
}
.ai-progress-text {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 10rpx;
  text-align: center;
}

.ai-result {
  background: var(--c-bg);
  border-radius: var(--r-md);
  padding: 18rpx;
  margin-bottom: 18rpx;
}
.ai-result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.ai-result-title {
  font-size: var(--f-small);
  font-weight: 600;
  color: var(--c-text);
}
.ai-result-confidence {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}
.ai-result-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 0;
}
.arr-day {
  width: 60rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  flex-shrink: 0;
  padding-top: 6rpx;
}
.arr-cells {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.arr-chip {
  background: var(--c-card);
  border: 1rpx solid var(--c-divider);
  border-radius: var(--r-sm);
  padding: 6rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}
.arr-time {
  font-size: var(--f-tiny);
  color: var(--c-text);
  font-weight: 600;
}
.arr-label {
  font-size: 18rpx;
  color: var(--c-text-3);
}

/* —— 长按菜单 —— */
.action-sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 36rpx);
  animation: slideUp 0.25s ease;
}
.as-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  text-align: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-divider);
  margin-bottom: 8rpx;
}
.as-item {
  padding: 24rpx 0;
  font-size: var(--f-body);
  color: var(--c-text);
  text-align: center;
  border-bottom: 1rpx solid var(--c-divider);
}
.as-danger { color: #E57373; }
.as-cancel {
  margin-top: 12rpx;
  padding: 24rpx 0;
  font-size: var(--f-body);
  color: var(--c-text-2);
  text-align: center;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
