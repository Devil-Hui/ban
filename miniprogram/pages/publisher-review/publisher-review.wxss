/* pages/publisher-review/publisher-review.wxss */
.page-pr {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 200rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* 顶部统计 */
.stat-hero {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 16rpx;
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--c-primary-dark);
  line-height: 1;
}
.stat-num-warn { color: #C77; }
.stat-label {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 8rpx;
}
.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--c-divider);
}

/* 步骤 */
.steps {
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 16rpx;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.st-dot {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  color: var(--c-text-3);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}
.st-text {
  font-size: 20rpx;
  color: var(--c-text-3);
}
.st-done .st-dot {
  background: var(--c-primary);
  border-color: var(--c-primary-dark);
  color: var(--c-text-inv);
}
.st-current .st-dot {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
}
.st-current .st-text { color: var(--c-primary-dark); font-weight: 600; }
.step-line {
  flex: 1;
  height: 4rpx;
  background: var(--c-border);
  margin: 0 8rpx;
  margin-bottom: 20rpx;
}
.st-line-done { background: var(--c-primary); }

/* 卡片 */
.card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}
.card-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.card-badge {
  font-size: 20rpx;
  color: var(--c-text-inv);
  background: #E88B8B;
  padding: 2rpx 10rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
}
.card-badge-soft {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}
.card-desc {
  font-size: 22rpx;
  color: var(--c-text-3);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

/* 头像 */
.pi-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 未提交 */
.ns-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.ns-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.ns-name {
  flex: 1;
  font-size: var(--f-sm);
  color: var(--c-text);
}
.ns-cta {
  font-size: 22rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 8rpx 18rpx;
  border-radius: var(--r-pill);
  font-weight: 500;
}

/* 周切换器 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 16rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 周历 */
.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname { text-align: center; padding: 4rpx 0; }
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
}
.cw-today { color: var(--c-primary-dark); font-weight: 600; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 100rpx;
}
.row-label-col {
  position: absolute;
  left: 0; top: 0;
  width: 100rpx;
}
.row-label {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text-3);
  border-right: 1rpx solid var(--c-divider);
}
.cal-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  height: 92rpx;
  margin-bottom: 4rpx;
}
.cell {
  border-radius: var(--r-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  transition: all 0.15s;
  background: var(--c-divider);
}
.cell:active { transform: scale(0.95); }
.heat-0 { background: #F2F4F6; }
.heat-1 { background: #D5EBF3; }
.heat-2 { background: #A6D8EA; }
.heat-3 { background: #7EC8E3; color: var(--c-text-inv); }
.cell-num {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--c-text);
}
.heat-3 .cell-num { color: var(--c-text-inv); }
.cell-avatars {
  display: flex;
  gap: 2rpx;
}
.ca-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: var(--c-card);
  color: var(--c-primary-dark);
  font-size: 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600;
}
.heat-3 .ca-dot {
  background: rgba(255,255,255,0.3);
  color: var(--c-text-inv);
}

/* 热力图例 */
.heat-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.hl-label {
  font-size: 20rpx;
  color: var(--c-text-3);
}
.hl-swatch {
  width: 32rpx; height: 24rpx;
  border-radius: 4rpx;
}
.hl-swatch.heat-0 { background: #F2F4F6; }
.hl-swatch.heat-1 { background: #D5EBF3; }
.hl-swatch.heat-2 { background: #A6D8EA; }
.hl-swatch.heat-3 { background: #7EC8E3; }

/* 已提交列表 */
.sub-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.sub-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.sub-body { flex: 1; min-width: 0; }
.sub-name {
  font-size: var(--f-sm);
  color: var(--c-text);
  font-weight: 500;
}
.sub-meta {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.sub-arrow {
  font-size: 36rpx;
  color: var(--c-text-3);
}

/* 底部 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--c-card);
  box-shadow: 0 -2rpx 16rpx rgba(126, 200, 227, 0.10);
  z-index: 50;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--r-md);
  font-size: var(--f-sm);
  font-weight: 600;
}
.btn-outline {
  background: var(--c-bg);
  color: var(--c-text);
  border: 2rpx solid var(--c-border);
}
.btn-primary {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.bottom-spacer { height: 40rpx; }

/* 弹层 */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.detail-sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: 3rpx;
  margin: 0 auto 16rpx;
}
.ds-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.ds-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
}
.ds-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.ds-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
  color: var(--c-text-3);
}
.ds-members {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.ds-member {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
  background: var(--c-primary-lighter);
  border-radius: var(--r-pill);
}
.ds-member .pi-avatar {
  width: 40rpx; height: 40rpx;
  font-size: 20rpx;
}
.dsm-name {
  font-size: 22rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
