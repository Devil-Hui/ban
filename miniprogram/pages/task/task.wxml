<!-- pages/task/task.wxml —— 任务页：发布者/成员任务列表 -->
<view class="page-task page-with-tab">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- 顶部标题 + 筛选 -->
  <view class="task-header">
    <view class="task-title-row">
      <view>
        <view class="page-title">任务</view>
        <view class="page-subtitle">{{filteredTasks.length}} 个任务 · 按{{sortLabel}}排序</view>
      </view>
      <view class="task-sort" bindtap="toggleSort">
        <text>{{sortLabel}}</text>
        <text class="sort-arrow">⇅</text>
      </view>
    </view>

    <!-- 分段控制 -->
    <view class="seg">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="seg-item {{currentTab === item.key ? 'seg-active' : ''}}"
        bindtap="switchTab"
        data-key="{{item.key}}"
      >
        <text>{{item.label}}</text>
        <text class="seg-count">{{item.count}}</text>
      </view>
    </view>

    <!-- 状态筛选 -->
    <scroll-view scroll-x class="filter-row" enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{currentFilter === item.key ? 'filter-active' : ''}}"
        bindtap="switchFilter"
        data-key="{{item.key}}"
      >
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <!-- 任务列表 -->
  <view wx:if="{{filteredTasks.length > 0}}" class="task-list">
    <view
      wx:for="{{filteredTasks}}"
      wx:key="id"
      class="task-card"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <!-- 状态条 -->
      <view class="task-card-bar task-bar-{{item.stateClass}}"></view>

      <view class="task-card-body">
        <view class="task-card-head">
          <view class="task-card-title-wrap">
            <text class="task-card-title">{{item.title}}</text>
            <view class="tag tag-{{item.tagClass}}">{{item.stateLabel}}</view>
          </view>
          <text class="task-card-group">{{item.groupName}}</text>
        </view>

        <view class="task-card-meta">
          <view class="meta-cell">
            <text class="meta-label">我的角色</text>
            <text class="meta-value">{{item.roleLabel}}</text>
          </view>
          <view class="meta-cell">
            <text class="meta-label">日期</text>
            <text class="meta-value">{{item.dateRange}}</text>
          </view>
          <view class="meta-cell">
            <text class="meta-label">时段</text>
            <text class="meta-value">{{item.periodsCount}} 个</text>
          </view>
        </view>

        <view wx:if="{{item.progress !== null}}" class="task-card-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progress}}%"></view>
          </view>
          <view class="progress-info">
            <text>{{item.progressText}}</text>
            <text class="progress-deadline">截止 {{item.deadline}}</text>
          </view>
        </view>

        <view wx:if="{{item.actions.length > 0}}" class="task-card-actions">
          <view
            wx:for="{{item.actions}}"
            wx:for-item="act"
            wx:key="key"
            class="action-btn action-{{act.type}}"
            catchtap="onAction"
            data-action="{{act.key}}"
            data-task-id="{{item.id}}"
          >{{act.label}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-card">
    <view class="empty-icon">⌧</view>
    <view class="empty-title">暂无{{currentTabLabel}}任务</view>
    <view class="empty-desc">{{emptyHint}}</view>
  </view>

  <view class="bottom-spacer"></view>
</view>
