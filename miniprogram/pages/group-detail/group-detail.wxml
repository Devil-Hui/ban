<!-- pages/group-detail/group-detail.wxml —— 分组详情 -->
<view class="page-gdetail">
  <!-- 分组头部 -->
  <view class="gdetail-hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="hero-row">
        <view class="hero-icon" style="background: rgba(255,255,255,0.85); color: #4A8FA8">{{group.abbr}}</view>
        <view class="hero-info">
          <view class="hero-name">{{group.name}}</view>
          <view class="hero-meta">
            <text class="tag tag-brand">{{group.role === 'publisher' ? '发布者' : '成员'}}</text>
            <text class="hero-code">邀请码 {{group.inviteCode}}</text>
          </view>
        </view>
        <view class="hero-copy" bindtap="copyCode" data-code="{{group.inviteCode}}">复制</view>
      </view>

      <view class="hero-stats">
        <view class="hs-cell">
          <view class="hs-num">{{group.memberCount}}</view>
          <view class="hs-label">成员</view>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-cell">
          <view class="hs-num">{{group.activeTasks}}</view>
          <view class="hs-label">进行中</view>
        </view>
        <view class="hs-divider"></view>
        <view class="hs-cell">
          <view class="hs-num">{{group.totalTasks}}</view>
          <view class="hs-label">累计任务</view>
        </view>
      </view>

      <!-- 身份切换：一人可同时拥有发布者/加入者身份 -->
      <view class="role-switcher">
        <view class="rs-label">我的身份</view>
        <view class="rs-tabs">
          <view
            class="rs-tab {{currentRole === 'publisher' ? 'rs-active' : ''}}"
            bindtap="switchRole"
            data-role="publisher"
          >发布者</view>
          <view
            class="rs-tab {{currentRole === 'member' ? 'rs-active' : ''}}"
            bindtap="switchRole"
            data-role="member"
          >加入者</view>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="gdetail-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="gdetail-tab {{currentTab === item.key ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-key="{{item.key}}"
    >
      {{item.label}}
      <text class="tab-count">{{item.count}}</text>
    </view>
  </view>

  <!-- 任务列表 -->
  <view wx:if="{{currentTab === 'tasks'}}" class="tab-content">
    <view wx:if="{{currentRole === 'publisher'}}" class="create-task-card" bindtap="goCreateTask">
      <view class="ctc-icon">＋</view>
      <view class="ctc-body">
        <view class="ctc-title">新建排班任务</view>
        <view class="ctc-desc">配置时段与约束，邀请成员标记空闲</view>
      </view>
      <text class="ctc-arrow">›</text>
    </view>

    <view wx:if="{{currentRole === 'member'}}" class="create-task-card" bindtap="goFillTime">
      <view class="ctc-icon">✎</view>
      <view class="ctc-body">
        <view class="ctc-title">填写我的可用时间</view>
        <view class="ctc-desc">在发布者勾选的区域内多选时段</view>
      </view>
      <text class="ctc-arrow">›</text>
    </view>

    <view wx:for="{{tasks}}" wx:key="id" class="gtask-card" bindtap="goTaskDetail" data-id="{{item.id}}">
      <view class="gtask-bar gtask-bar-{{item.stateClass}}"></view>
      <view class="gtask-body">
        <view class="gtask-head">
          <view class="gtask-title-wrap">
            <text class="gtask-title">{{item.title}}</text>
            <view class="tag tag-{{item.tagClass}}">{{item.stateLabel}}</view>
          </view>
          <text class="gtask-date">{{item.dateRange}}</text>
        </view>
        <view class="gtask-meta">
          <view class="gm-cell">
            <text class="gm-label">时段</text>
            <text class="gm-value">{{item.periodsCount}} 个</text>
          </view>
          <view class="gm-cell">
            <text class="gm-label">最少人数</text>
            <text class="gm-value">{{item.minPeople}} 人/时段</text>
          </view>
          <view class="gm-cell">
            <text class="gm-label">截止</text>
            <text class="gm-value">{{item.deadline}}</text>
          </view>
        </view>
        <view wx:if="{{item.progress !== null}}" class="gtask-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progress}}%"></view>
          </view>
          <text class="gtask-progress-text">{{item.progressText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 成员列表 -->
  <view wx:elif="{{currentTab === 'members'}}" class="tab-content">
    <view class="members-search">
      <view class="ms-icon">⌕</view>
      <input class="ms-input" placeholder="搜索成员名称" bindinput="onSearch" value="{{keyword}}" />
    </view>

    <view wx:if="{{currentRole === 'publisher'}}" class="members-tip">
      <view class="tip-icon">ⓘ</view>
      <text>成员手机号已脱敏显示，点击成员卡片可查看更多操作</text>
    </view>

    <view wx:for="{{filteredMembers}}" wx:key="id" class="member-card" bindtap="onMemberTap" data-id="{{item.id}}">
      <view class="member-avatar avatar {{item.status !== 'active' ? 'avatar-inactive' : ''}}">{{item.initial}}</view>
      <view class="member-body">
        <view class="member-name-row">
          <text class="member-name {{item.status !== 'active' ? 'text-tertiary' : ''}}">{{item.displayName}}</text>
          <view wx:if="{{item.role === 'publisher'}}" class="tag tag-brand">发布者</view>
          <view wx:elif="{{item.status === 'kicked'}}" class="tag tag-danger">已踢出</view>
          <view wx:elif="{{item.status === 'left'}}" class="tag tag-neutral">已退出</view>
        </view>
        <view class="member-meta">
          <text wx:if="{{item.className}}">{{item.className}}</text>
          <text wx:if="{{item.className}}" class="dot-sep">·</text>
          <text wx:if="{{item.phoneMasked}}">{{item.phoneMasked}}</text>
          <text wx:elif="{{isPublisher}}" class="text-tertiary">未提供手机号</text>
          <text wx:if="{{item.submittedCount > 0}}" class="dot-sep">·</text>
          <text wx:if="{{item.submittedCount > 0}}">已提交 {{item.submittedCount}} 次</text>
        </view>
      </view>
      <view wx:if="{{currentRole === 'publisher' && item.role !== 'publisher' && item.status === 'active'}}" class="member-action">
        <text class="ma-text">管理</text>
        <text class="ma-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view wx:elif="{{currentTab === 'settings'}}" class="tab-content">
    <view wx:if="{{currentRole === 'publisher'}}" class="settings-card">
      <view class="setting-row" bindtap="editTemplate">
        <view class="sr-icon sr-icon-template">▦</view>
        <view class="sr-body">
          <view class="sr-title">时段模板</view>
          <view class="sr-desc">{{group.templateName}}</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
      <view class="setting-row" bindtap="editCycle">
        <view class="sr-icon sr-icon-cycle">↻</view>
        <view class="sr-body">
          <view class="sr-title">循环规则</view>
          <view class="sr-desc">{{group.cycleRuleLabel}}</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
      <view class="setting-row" bindtap="regenCode">
        <view class="sr-icon sr-icon-code">⌗</view>
        <view class="sr-body">
          <view class="sr-title">重置邀请码</view>
          <view class="sr-desc">旧邀请码立即失效</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
      <view class="setting-row" bindtap="archiveGroup">
        <view class="sr-icon sr-icon-archive">⊠</view>
        <view class="sr-body">
          <view class="sr-title">归档分组</view>
          <view class="sr-desc">归档后无法新建任务，历史可查</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{currentRole === 'member'}}" class="settings-card">
      <view class="setting-row" bindtap="goFillTime">
        <view class="sr-icon sr-icon-template">✎</view>
        <view class="sr-body">
          <view class="sr-title">查看 / 修改我的可用时间</view>
          <view class="sr-desc">收集阶段内可编辑，发布后不可改</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
      <view class="setting-row" bindtap="switchToPublisher">
        <view class="sr-icon sr-icon-cycle">⇄</view>
        <view class="sr-body">
          <view class="sr-title">切换为发布者身份</view>
          <view class="sr-desc">创建自己的排班任务</view>
        </view>
        <text class="sr-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{currentRole === 'member'}}" class="leave-block">
      <view class="btn btn-danger btn-block" bindtap="confirmLeave">退出分组</view>
      <view class="leave-hint">退出后历史保留，可再次通过邀请码加入</view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
