<!-- pages/objection/objection.wxml —— 异议处理（发布者视角） -->
<view class="page-obj">
  <!-- Hero：任务摘要 -->
  <view class="obj-hero">
    <view class="hero-tag-row">
      <view class="tag tag-warning">异议待处理</view>
      <text class="hero-task-id">任务 #{{task.id}}</text>
    </view>
    <view class="hero-title">{{task.title}}</view>
    <view class="hero-meta-row">
      <text class="hero-meta-item">{{task.groupName}}</text>
      <text class="dot-sep">·</text>
      <text class="hero-meta-item">{{task.dateRange}}</text>
      <text class="dot-sep">·</text>
      <text class="hero-meta-item">{{task.periodCount}} 个时段</text>
    </view>

    <view class="hero-stats">
      <view class="hs-cell">
        <view class="hs-num">{{objectionStats.pending}}</view>
        <view class="hs-label">待处理</view>
      </view>
      <view class="hs-divider"></view>
      <view class="hs-cell">
        <view class="hs-num">{{objectionStats.resolved}}</view>
        <view class="hs-label">已处理</view>
      </view>
      <view class="hs-divider"></view>
      <view class="hs-cell">
        <view class="hs-num">{{objectionStats.total}}</view>
        <view class="hs-label">总异议</view>
      </view>
    </view>
  </view>

  <!-- 段落标题：异议列表 -->
  <view class="section-head">
    <text class="section-title">异议申请</text>
    <view class="seg-control">
      <view class="seg-item {{filter === 'pending' ? 'seg-active' : ''}}" bindtap="switchFilter" data-filter="pending">待处理</view>
      <view class="seg-item {{filter === 'resolved' ? 'seg-active' : ''}}" bindtap="switchFilter" data-filter="resolved">已处理</view>
      <view class="seg-item {{filter === 'all' ? 'seg-active' : ''}}" bindtap="switchFilter" data-filter="all">全部</view>
    </view>
  </view>

  <!-- 异议列表 -->
  <view wx:if="{{filteredObjections.length}}" class="obj-list">
    <view wx:for="{{filteredObjections}}" wx:key="id" class="obj-card {{item.status === 'pending' ? 'obj-card-pending' : 'obj-card-resolved'}}">
      <view class="obj-card-head">
        <view class="avatar avatar-sm obj-avatar">{{item.initial}}</view>
        <view class="obj-card-info">
          <view class="obj-name">{{item.displayName}}</view>
          <view class="obj-time">{{item.submittedAt}}</view>
        </view>
        <view class="tag {{item.status === 'pending' ? 'tag-warning' : item.resolvedType === 'accepted' ? 'tag-success' : 'tag-neutral'}}">
          {{item.statusLabel}}
        </view>
      </view>

      <view class="obj-reason">
        <view class="obj-reason-label">异议原因</view>
        <view class="obj-reason-text">{{item.reason}}</view>
      </view>

      <view class="obj-shifts">
        <view class="obj-shifts-label">涉及时段</view>
        <view class="obj-shifts-chips">
          <view wx:for="{{item.involvedShifts}}" wx:for-item="shift" wx:key="key" class="period-chip period-chip-warn">
            {{shift.date}} · {{shift.period}}
          </view>
        </view>
      </view>

      <!-- 已处理：显示处理结果 -->
      <view wx:if="{{item.status === 'resolved'}}" class="obj-resolved-info">
        <view class="ori-row">
          <text class="ori-label">处理结果</text>
          <text class="ori-value {{item.resolvedType === 'accepted' ? 'text-success' : 'text-muted'}}">{{item.resolvedLabel}}</text>
        </view>
        <view class="ori-row" wx:if="{{item.resolvedAt}}">
          <text class="ori-label">处理时间</text>
          <text class="ori-value">{{item.resolvedAt}}</text>
        </view>
        <view class="ori-row" wx:if="{{item.resolveNote}}">
          <text class="ori-label">备注</text>
          <text class="ori-value">{{item.resolveNote}}</text>
        </view>
      </view>

      <!-- 待处理：操作按钮 -->
      <view wx:if="{{item.status === 'pending'}}" class="obj-actions">
        <view class="btn btn-outline btn-sm" bindtap="rejectObjection" data-id="{{item.id}}">驳回</view>
        <view class="btn btn-primary btn-sm" bindtap="acceptObjection" data-id="{{item.id}}">接受并调整</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="empty-icon">✓</view>
    <view class="empty-title">{{filter === 'pending' ? '暂无待处理异议' : '暂无异议记录'}}</view>
    <view class="empty-desc">{{filter === 'pending' ? '当前没有需要处理的异议申请' : '所有异议处理记录将在此显示'}}</view>
  </view>

  <!-- 历史版本回溯 -->
  <view wx:if="{{previousSchemes.length}}" class="section-head">
    <text class="section-title">方案版本回溯</text>
    <text class="section-tip">{{previousSchemes.length}} 个版本</text>
  </view>
  <view wx:if="{{previousSchemes.length}}" class="version-list">
    <view wx:for="{{previousSchemes}}" wx:key="version" class="version-card">
      <view class="ver-row">
        <view class="ver-badge">v{{item.version}}</view>
        <view class="ver-info">
          <view class="ver-title">{{item.title}}</view>
          <view class="ver-meta">{{item.publishedAt}} · {{item.shiftsCount}} 人次</view>
        </view>
        <view class="ver-link" bindtap="viewVersion" data-version="{{item.version}}">查看</view>
      </view>
      <view class="ver-reason" wx:if="{{item.reason}}">触发原因：{{item.reason}}</view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view wx:if="{{hasPending}}" class="bottom-bar">
    <view class="bb-info">
      <view class="bb-title">{{objectionStats.pending}} 条异议待处理</view>
      <view class="bb-desc">接受任意一条异议后将进入调整模式</view>
    </view>
    <view class="btn btn-outline" bindtap="rejectAll">全部驳回</view>
  </view>

  <!-- 接受异议弹层 -->
  <view wx:if="{{acceptSheet}}" class="mask" bindtap="closeAcceptSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">接受异议并调整</text>
        <view class="sheet-close" bindtap="closeAcceptSheet">✕</view>
      </view>
      <view class="sheet-body">
        <view class="sheet-tip">
          接受异议后任务将进入「调整中」状态，原排班方案会保留至版本历史，你可以在方案预览页手动调整后重新发布。
        </view>

        <view class="sheet-section">
          <view class="ss-label">异议来自</view>
          <view class="ss-value">{{currentObjection.displayName}}</view>
        </view>
        <view class="sheet-section">
          <view class="ss-label">涉及时段</view>
          <view class="ss-chips">
            <view wx:for="{{currentObjection.involvedShifts}}" wx:for-item="shift" wx:key="key" class="period-chip">
              {{shift.date}} · {{shift.period}}
            </view>
          </view>
        </view>

        <view class="sheet-section">
          <view class="ss-label">处理备注（可选）</view>
          <textarea class="ss-textarea" placeholder="给成员的说明，如「已为您调整」" placeholder-class="ph" bindinput="onNoteInput" value="{{resolveNote}}" maxlength="100" />
        </view>

        <view class="sheet-warn">
          <text class="sw-icon">!</text>
          <text>接受后所有成员的查收状态将重置，需重新查收确认。</text>
        </view>
      </view>
      <view class="sheet-foot">
        <view class="btn btn-block btn-outline" bindtap="closeAcceptSheet">取消</view>
        <view class="btn btn-block btn-primary" bindtap="confirmAccept">确认接受并进入调整</view>
      </view>
    </view>
  </view>

  <!-- 驳回异议弹层 -->
  <view wx:if="{{rejectSheet}}" class="mask" bindtap="closeRejectSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">驳回异议</text>
        <view class="sheet-close" bindtap="closeRejectSheet">✕</view>
      </view>
      <view class="sheet-body">
        <view class="sheet-section">
          <view class="ss-label">驳回理由（必填）</view>
          <textarea class="ss-textarea" placeholder="请填写驳回理由，将通知该成员" placeholder-class="ph" bindinput="onRejectReasonInput" value="{{rejectReason}}" maxlength="100" />
          <view class="ss-counter">{{rejectReason.length}}/100</view>
        </view>

        <view class="sheet-warn sheet-warn-neutral">
          <text class="sw-icon">i</text>
          <text>驳回后该成员的异议将标记为「已驳回」，原排班方案不受影响。</text>
        </view>
      </view>
      <view class="sheet-foot">
        <view class="btn btn-block btn-outline" bindtap="closeRejectSheet">取消</view>
        <view class="btn btn-block btn-danger" bindtap="confirmReject">确认驳回</view>
      </view>
    </view>
  </view>
</view>
