/* pages/style-select/style-select.wxss */
.page-ss {
  min-height: 100vh;
  padding: 32rpx var(--s-md) calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}
.ss-head { margin-bottom: 24rpx; }
.ss-title {
  font-size: var(--f-lg);
  font-weight: 700;
  color: var(--c-text);
}
.ss-sub {
  font-size: var(--f-cap);
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.ss-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.ss-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--c-primary);
}
.ssc-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-text-inv);
  flex-shrink: 0;
}
.ssc-body { flex: 1; min-width: 0; }
.ssc-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 4rpx;
}
.ssc-desc {
  font-size: 22rpx;
  color: var(--c-text-3);
  line-height: 1.4;
}
.ssc-arrow {
  font-size: 36rpx;
  color: var(--c-text-3);
}
.ss-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 32rpx;
}
