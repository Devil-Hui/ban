<!-- pages/style-select/style-select.wxml —— 样式选择页 -->
<view class="page-ss">
  <view class="ss-head">
    <view class="ss-title">选择排班样式</view>
    <view class="ss-sub">三种样式覆盖不同排班场景</view>
  </view>

  <view class="ss-list">
    <view wx:for="{{styleList}}" wx:key="key"
      class="ss-card ss-{{item.key}}"
      bindtap="onPick"
      data-key="{{item.key}}"
    >
      <view class="ssc-icon">{{item.icon}}</view>
      <view class="ssc-body">
        <view class="ssc-title">{{item.title}}</view>
        <view class="ssc-desc">{{item.desc}}</view>
      </view>
      <view class="ssc-arrow">›</view>
    </view>
  </view>

  <view class="ss-tip">点击进入创建向导：模式 → 基础模板 → 日期与约束 → 发布</view>
</view>
