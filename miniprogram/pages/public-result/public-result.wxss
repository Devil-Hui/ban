/* pages/public-result/public-result.wxss */
.page-pb {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 200rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* Hero */
.pb-hero {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}
.pb-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #B8DDE9 0%, #7EC8E3 100%);
}
.pb-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  padding: 6rpx 16rpx;
  border-radius: var(--r-pill);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.pb-status-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--c-primary);
  box-shadow: 0 0 0 4rpx rgba(126, 200, 227, 0.25);
}
.pb-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text);
}
.pb-meta {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 8rpx;
}
.dot-sep { margin: 0 8rpx; }
.pb-notice {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: var(--c-primary-dark);
  background: var(--c-primary-lightest);
  padding: 8rpx 16rpx;
  border-radius: var(--r-sm);
  display: inline-block;
}
.pb-notice-member {
  color: var(--c-text-3);
  background: var(--c-bg);
}

/* 卡片 */
.card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}
.card-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.card-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: var(--r-pill);
  font-weight: 600;
}
.card-badge-soft {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}

/* 周切换器 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 8rpx 0 16rpx;
}
.wn-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary-dark);
  font-weight: 500;
}
.wn-arrow:active { transform: scale(0.92); background: var(--c-primary-light); }
.wn-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* 周历表 */
.cal-headrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-left: 100rpx;
  margin-bottom: 8rpx;
}
.cal-weekname { text-align: center; padding: 4rpx 0; }
.cw-day {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 500;
}
.cw-today { color: var(--c-primary-dark); font-weight: 600; }
.cw-date {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}
.cal-scroll { width: 100%; }
.cal-table {
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 100rpx;
}
.row-label-col {
  position: absolute;
  left: 0; top: 0;
  width: 100rpx;
}
.row-label {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--c-text-3);
  border-right: 1rpx solid var(--c-divider);
}
.cal-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  height: 92rpx;
  margin-bottom: 4rpx;
}
.pcell {
  background: var(--c-bg);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}
.pcell-assigned {
  background: var(--c-primary);
  border-color: var(--c-primary-dark);
  color: var(--c-text-inv);
}
.pcell-assigned.risk-high {
  background: #F5B97A;
  border-color: #E89B4F;
}
.pcell-locked {
  background: var(--c-divider);
  opacity: 0.4;
}
.pcell-name {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--c-text-inv);
}
.pcell-lock {
  font-size: 24rpx;
  color: var(--c-text-3);
}

/* 风险图例 */
.risk-legend {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-sm);
}
.rl-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--c-text-2);
}
.rl-dot {
  width: 24rpx; height: 24rpx;
  border-radius: 6rpx;
}
.rl-risk { background: #F5B97A; }
.rl-normal { background: var(--c-primary); }

/* 个人概览 */
.person-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.person-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.pi-avatar {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.pp-body { flex: 1; min-width: 0; }
.pp-name {
  font-size: var(--f-sm);
  color: var(--c-text);
  font-weight: 500;
}
.pp-meta {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.pp-bar {
  width: 120rpx;
  height: 8rpx;
  background: var(--c-divider);
  border-radius: 4rpx;
  overflow: hidden;
}
.pp-fill {
  height: 100%;
  background: linear-gradient(90deg, #B8DDE9 0%, #7EC8E3 100%);
  border-radius: 4rpx;
}

/* 底部 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 24rpx);
  background: var(--c-card);
  box-shadow: 0 -2rpx 16rpx rgba(126, 200, 227, 0.10);
  z-index: 50;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--r-md);
  font-size: var(--f-sm);
  font-weight: 600;
}
.btn-outline {
  background: var(--c-bg);
  color: var(--c-text);
  border: 2rpx solid var(--c-border);
}
.btn-primary {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.bottom-spacer { height: 40rpx; }

/* 弹层 */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.detail-sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  animation: slideUp 0.25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: 3rpx;
  margin: 0 auto 16rpx;
}
.ds-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.ds-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
}
.ds-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.ds-close {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx;
  color: var(--c-text-3);
}
.ds-info {
  background: var(--c-bg);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
}
.dsi-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 24rpx;
  border-bottom: 1rpx solid var(--c-divider);
}
.dsi-row:last-child { border-bottom: none; }
.dsi-label { color: var(--c-text-3); }
.dsi-value { color: var(--c-text); font-weight: 500; }
.ds-empty {
  padding: 40rpx 0;
  text-align: center;
}
.ds-empty-ico {
  font-size: 56rpx;
  color: var(--c-text-3);
  opacity: 0.5;
}
.ds-empty-text {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 8rpx;
}
