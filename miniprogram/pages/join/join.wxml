<!-- pages/join/join.wxml —— 加入/创建分组 -->
<view class="page-join">
  <!-- 顶部模式切换 -->
  <view class="join-hero">
    <view class="join-hero-bg"></view>
    <view class="join-hero-content">
      <view class="join-hero-icon">⌗</view>
      <view class="join-hero-title">{{mode === 'create' ? '创建新分组' : '加入协同排班'}}</view>
      <view class="join-hero-desc">
        {{mode === 'create' ? '建立你的排班分组，邀请伙伴一起协作' : '输入 6 位邀请码，立即加入分组'}}
      </view>
    </view>
  </view>

  <!-- 模式切换 Tab -->
  <view class="mode-switch">
    <view class="mode-tab {{mode === 'join' ? 'mode-active' : ''}}" bindtap="switchMode" data-mode="join">
      <text class="mode-icon">⌗</text>
      <text>邀请码加入</text>
    </view>
    <view class="mode-tab {{mode === 'create' ? 'mode-active' : ''}}" bindtap="switchMode" data-mode="create">
      <text class="mode-icon">＋</text>
      <text>创建分组</text>
    </view>
  </view>

  <!-- 加入分组表单 -->
  <view wx:if="{{mode === 'join'}}" class="form-card">
    <view class="form-section">
      <view class="form-label">邀请码</view>
      <view class="code-input-row" bindtap="onCodeRowTap">
        <view
          wx:for="{{codeDigits}}"
          wx:key="index"
          class="code-cell {{item.value ? 'code-filled' : ''}} {{index === activeIndex ? 'code-active' : ''}}"
        >{{item.value}}</view>
        <input
          class="code-hidden-input"
          type="text"
          maxlength="6"
          value="{{codeRaw}}"
          focus="{{codeInputFocus}}"
          bindinput="onCodeInput"
          bindblur="onCodeBlur"
          confirm-type="done"
          adjust-position="{{true}}"
        />
      </view>
      <view class="form-hint">6 位邀请码不区分大小写，可向分组发布者索取</view>
    </view>

    <view class="form-section">
      <view class="form-label">显示名 <text class="form-optional">（可选）</text></view>
      <view class="input-wrap">
        <input class="input" placeholder="使用微信昵称「测试用户」" value="{{displayName}}" bindinput="onNameInput" />
      </view>
      <view class="form-hint">该名称将在此分组内展示，可随时修改</view>
    </view>

    <view wx:if="{{previewGroup}}" class="preview-card">
      <view class="preview-label">即将加入</view>
      <view class="preview-body">
        <view class="preview-icon" style="background: rgba(126,200,227,0.18); color: #4A8FA8">值</view>
        <view class="preview-info">
          <view class="preview-name">{{previewGroup.name}}</view>
          <view class="preview-meta">{{previewGroup.memberCount}} 位成员 · 由 {{previewGroup.publisher}} 创建</view>
        </view>
      </view>
    </view>

    <view class="btn btn-primary btn-lg btn-block join-submit" bindtap="onJoinSubmit">加入分组</view>
  </view>

  <!-- 创建分组表单 -->
  <view wx:else class="form-card">
    <view class="form-section">
      <view class="form-label">分组名称 <text class="form-required">*</text></view>
      <view class="input-wrap">
        <input class="input" placeholder="如：计科202值班群" value="{{groupName}}" bindinput="onGroupNameInput" maxlength="20" />
      </view>
      <view class="form-hint">{{groupName.length}}/20 字 · 建议使用团队或场景名称</view>
    </view>

    <view class="form-section">
      <view class="form-label">分组简称 <text class="form-optional">（可选）</text></view>
      <view class="abbr-row">
        <view
          wx:for="{{abbrOptions}}"
          wx:key="*this"
          class="abbr-cell {{groupNameAbbr === item ? 'abbr-active' : ''}}"
          bindtap="pickAbbr"
          data-abbr="{{item}}"
        >{{item}}</view>
      </view>
      <view class="form-hint">用于在卡片图标位置展示，最多 2 个字</view>
    </view>

    <view class="form-section">
      <view class="form-label">循环规则</view>
      <view class="rule-grid">
        <view
          wx:for="{{cycleRules}}"
          wx:key="key"
          class="rule-cell {{cycleRule === item.key ? 'rule-active' : ''}}"
          bindtap="pickCycle"
          data-key="{{item.key}}"
        >
          <view class="rule-title">{{item.title}}</view>
          <view class="rule-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="form-label">默认时段模板</view>
      <view class="template-list">
        <view
          wx:for="{{templates}}"
          wx:key="id"
          class="template-card {{templateId === item.id ? 'template-active' : ''}}"
          bindtap="pickTemplate"
          data-id="{{item.id}}"
        >
          <view class="template-head">
            <text class="template-name">{{item.name}}</text>
            <text class="template-check" wx:if="{{templateId === item.id}}">✓</text>
          </view>
          <view class="template-periods">
            <text wx:for="{{item.periods}}" wx:for-item="p" wx:key="*this" class="period-chip">{{p}}</text>
          </view>
          <view class="template-meta">{{item.periods.length}} 个时段 · {{item.tag}}</view>
        </view>
      </view>
    </view>

    <view class="btn btn-primary btn-lg btn-block join-submit" bindtap="onCreateSubmit">创建分组</view>
  </view>

  <!-- 我已加入的分组（管理视图） -->
  <view wx:if="{{mode === 'join' && myGroups.length > 0}}" class="my-groups-section">
    <view class="divider-text">我已加入的分组</view>
    <view wx:for="{{myGroups}}" wx:key="id" class="my-group-card">
      <view class="my-group-icon" style="background: {{item.themeBg}}; color: {{item.themeColor}}">{{item.abbr}}</view>
      <view class="my-group-body">
        <view class="my-group-name">{{item.name}}</view>
        <view class="my-group-meta">
          <text class="tag {{item.role === 'publisher' ? 'tag-brand' : 'tag-neutral'}}">
            {{item.role === 'publisher' ? '发布者' : '成员'}}
          </text>
          <text class="my-group-code">邀请码 {{item.inviteCode}}</text>
        </view>
      </view>
      <view class="my-group-action" wx:if="{{item.role === 'publisher'}}" bindtap="copyCode" data-code="{{item.inviteCode}}">复制</view>
      <view class="my-group-action my-group-leave" wx:else bindtap="confirmLeave" data-id="{{item.id}}">退出</view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
