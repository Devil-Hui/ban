/* pages/join/join.wxss —— 加入/创建分组样式 */

.page-join {
  min-height: 100vh;
  padding: 0 var(--s-md) calc(env(safe-area-inset-bottom) + 80rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* —— 顶部 Hero —— */
.join-hero {
  position: relative;
  margin: 16rpx 0 24rpx;
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-elevated);
}
.join-hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(70% 80% at 0% 0%, rgba(126, 200, 227, 0.5) 0%, transparent 60%),
    radial-gradient(70% 80% at 100% 100%, rgba(184, 221, 233, 0.4) 0%, transparent 60%),
    linear-gradient(135deg, #FFFFFF 0%, #EAF1FF 100%);
}
.join-hero-content {
  position: relative;
  padding: 48rpx 32rpx;
}
.join-hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--r-lg);
  background: linear-gradient(135deg, #2B6DE5 0%, #2B6DE5 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(126, 200, 227, 0.4);
}
.join-hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--c-text);
  margin-top: 24rpx;
  letter-spacing: 0.5rpx;
}
.join-hero-desc {
  font-size: var(--f-cap);
  color: var(--c-text-2);
  margin-top: 8rpx;
  line-height: 1.6;
}

/* —— 模式切换 —— */
.mode-switch {
  display: flex;
  background: var(--c-card);
  border-radius: var(--r-pill);
  padding: 6rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: var(--s-md);
}
.mode-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 64rpx;
  border-radius: var(--r-pill);
  font-size: var(--f-cap);
  color: var(--c-text-2);
  font-weight: 500;
  transition: all .2s;
}
.mode-active {
  background: linear-gradient(135deg, #2B6DE5 0%, #2B6DE5 100%);
  color: var(--c-text-inv);
  box-shadow: 0 4rpx 12rpx rgba(126, 200, 227, 0.35);
}
.mode-icon { font-size: 28rpx; }

/* —— 表单卡片 —— */
.form-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: var(--s-md);
}
.form-section { margin-bottom: var(--s-md); }
.form-section:last-of-type { margin-bottom: 0; }
.form-label {
  font-size: var(--f-cap);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 12rpx;
}
.form-required { color: var(--c-danger); font-weight: 500; }
.form-optional { color: var(--c-text-3); font-weight: 400; }
.form-hint {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* —— 邀请码输入 —— */
.code-input-row {
  position: relative;
  display: flex;
  gap: 12rpx;
}
.code-cell {
  flex: 1;
  height: 96rpx;
  background: var(--c-primary-lightest);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-text);
  transition: all .15s;
}
.code-filled {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
}
.code-active {
  border-color: var(--c-primary);
  box-shadow: 0 0 0 4rpx rgba(126, 200, 227, 0.18);
}
/* 隐藏的真实 input，覆盖在格子行上以接收键盘输入 */
.code-hidden-input {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  z-index: 2;
}

/* —— 输入框 —— */
.input-wrap { width: 100%; }

/* —— 预览卡片 —— */
.preview-card {
  background: var(--c-primary-lightest);
  border-radius: var(--r-md);
  padding: 20rpx;
  margin-top: 8rpx;
}
.preview-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-bottom: 12rpx;
}
.preview-body {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.preview-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}
.preview-info { flex: 1; min-width: 0; }
.preview-name {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.preview-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 4rpx;
}

/* —— 简称选择 —— */
.abbr-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.abbr-cell {
  min-width: 80rpx;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--c-primary-lightest);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--f-body);
  font-weight: 500;
  color: var(--c-text-2);
  transition: all .15s;
}
.abbr-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
  font-weight: 600;
}

/* —— 循环规则 —— */
.rule-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}
.rule-cell {
  background: var(--c-primary-lightest);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20rpx;
  transition: all .15s;
}
.rule-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
}
.rule-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 4rpx;
}
.rule-active .rule-title { color: var(--c-primary-dark); }
.rule-desc {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}

/* —— 时段模板 —— */
.template-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.template-card {
  background: var(--c-primary-lightest);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20rpx;
  transition: all .15s;
}
.template-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
}
.template-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.template-name {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.template-active .template-name { color: var(--c-primary-dark); }
.template-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.template-periods {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.template-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}

/* —— 提交按钮 —— */
.join-submit {
  margin-top: 32rpx;
}

/* —— 我已加入 —— */
.my-groups-section {
  margin-top: var(--s-lg);
}
.my-group-card {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.my-group-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.my-group-body { flex: 1; min-width: 0; }
.my-group-name {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.my-group-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}
.my-group-code {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  letter-spacing: 0.5rpx;
}
.my-group-action {
  font-size: var(--f-cap);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 10rpx 20rpx;
  border-radius: var(--r-pill);
}
.my-group-leave {
  color: var(--c-danger);
  background: rgba(232, 139, 139, 0.10);
}

.bottom-spacer { height: 80rpx; }
