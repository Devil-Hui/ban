/* pages/schedule/schedule.wxss —— 日程页样式 */

.page-schedule {
  min-height: 100vh;
  padding: 0 var(--s-md) calc(env(safe-area-inset-bottom) + 180rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* —— 分组筛选 —— */
.group-filter {
  white-space: nowrap;
  padding: 16rpx 0 8rpx;
}
.gf-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  background: var(--c-card);
  border: 2rpx solid var(--c-border);
  border-radius: var(--r-pill);
  font-size: 22rpx;
  color: var(--c-text-2);
  transition: all 0.15s;
}
.gf-active {
  background: var(--c-primary);
  border-color: var(--c-primary-dark);
  color: var(--c-text-inv);
}
.gf-active.gf-pub {
  background: var(--c-primary);
}
.gf-name { font-weight: 500; }
.gf-role {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: var(--r-pill);
}
.gf-active .gf-role {
  background: rgba(255, 255, 255, 0.25);
}

/* —— 月份概览统计卡（替代旧 cal-head） —— */
.month-stat {
  display: flex;
  align-items: center;
  background: var(--c-card);
  border-radius: var(--r-lg);
  padding: 20rpx 24rpx;
  margin: 16rpx 0 8rpx;
  box-shadow: var(--shadow-card);
  gap: 16rpx;
}
.ms-month {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
  padding-right: 16rpx;
  border-right: 1rpx solid var(--c-divider);
}
.ms-year {
  font-size: 20rpx;
  color: var(--c-text-3);
}
.ms-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--c-text);
  line-height: 1;
}
.ms-unit {
  font-size: 22rpx;
  color: var(--c-text-3);
}
.ms-stats {
  flex: 1;
  display: flex;
  justify-content: space-around;
}
.ms-stat {
  text-align: center;
}
.ms-stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
  line-height: 1;
}
.ms-stat-brand { color: var(--c-primary-dark); }
.ms-stat-warn { color: var(--c-warning); }
.ms-stat-label {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.ms-nav {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.ms-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--c-text-2);
}
.ms-arrow:active { background: var(--c-primary-lighter); color: var(--c-primary-dark); }

/* —— 月份切换（保留旧类，兼容） —— */
.cal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 8rpx 16rpx;
}
.cal-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--c-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: var(--c-text-2);
  box-shadow: var(--shadow-card);
}
.cal-arrow:active { background: var(--c-primary-lighter); color: var(--c-primary-dark); }

.cal-tip-hint {
  text-align: center;
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}
.cal-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.cal-year {
  font-size: var(--f-cap);
  color: var(--c-text-3);
  font-weight: 500;
}
.cal-month {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 0.5rpx;
}

/* —— 日历卡片 —— */
.cal-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 20rpx 16rpx 16rpx;
  margin-top: 8rpx;
}

.cal-weekrow {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 8rpx;
}
.cal-weekday {
  text-align: center;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  font-weight: 500;
  padding: 8rpx 0;
}
.cal-weekday-end { color: var(--c-text-3); opacity: .6; }

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}
.cal-cell {
  aspect-ratio: 1 / 1.1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 0;
  border-radius: var(--r-sm);
  position: relative;
  transition: background .15s;
}
.cal-cell:active { background: var(--c-primary-lightest); }
.cal-cell-out { opacity: 0.35; }
.cal-cell-today {
  outline: 2rpx solid var(--c-primary);
  outline-offset: -2rpx;
}
.cal-cell-selected {
  outline: 2rpx solid var(--c-primary-dark);
  outline-offset: -2rpx;
}

/* 热力等级 */
.heat-0 { background: transparent; }
.heat-1 { background: #BBF7D0; }
.heat-2 { background: #86EFAC; }
.heat-3 { background: var(--c-primary); }
.heat-3 .cal-day { color: var(--c-text-inv); font-weight: 700; }
.heat-3 .cal-count { color: var(--c-text-inv); }

.cal-count {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--c-primary-dark);
  margin-top: 2rpx;
  line-height: 1;
}

.cal-day {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
  height: 40rpx;
  line-height: 40rpx;
}
.cal-day-today {
  width: 40rpx;
  height: 40rpx;
  background: var(--c-primary);
  color: var(--c-text-inv);
  border-radius: 50%;
  font-weight: 600;
}

.cal-periods {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: center;
  margin-top: 4rpx;
  width: 100%;
}
.cal-period {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}
.cal-period.published { background: var(--c-primary); color: var(--c-text-inv); }
.cal-period.pending { background: var(--c-primary-lighter); color: var(--c-primary-dark); }
.cal-period.objection { background: rgba(232, 139, 139, 0.18); color: var(--c-danger); }

.cal-dots {
  display: flex;
  gap: 4rpx;
  margin-top: 6rpx;
}
.cal-dot {
  width: 8rpx;
  height: 8rpx;
}

/* —— 图例 —— */
.cal-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-divider);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
}
.legend-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.legend-dot-brand { background: var(--c-primary); }
.legend-dot-soft { background: var(--c-primary-lighter); border: 1rpx solid var(--c-primary-light); }
.legend-dot-warn { background: var(--c-danger); }

/* —— 热力图例 —— */
.heat-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-sm);
}
.hl-text {
  font-size: 20rpx;
  color: var(--c-text-3);
}
.hl-swatch {
  width: 32rpx;
  height: 20rpx;
  border-radius: 4rpx;
}
.hl-swatch.heat-0 { background: #F2F4F6; }
.hl-swatch.heat-1 { background: #BBF7D0; }
.hl-swatch.heat-2 { background: #86EFAC; }
.hl-swatch.heat-3 { background: var(--c-primary); }

/* —— 今日概览卡 —— */
.today-card {
  background: var(--c-primary-lighter);
  border-radius: var(--r-lg);
  padding: 20rpx 24rpx;
  margin: 16rpx 0;
  border-left: 6rpx solid var(--c-primary);
}
.tc-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.tc-title {
  font-size: var(--f-md);
  font-weight: 600;
  color: var(--c-text);
}
.tc-date {
  font-size: 22rpx;
  color: var(--c-text-3);
}
.tc-body {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}
.tc-stat {
  flex: 1;
  text-align: center;
}
.tc-stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-primary-dark);
  line-height: 1;
}
.tc-stat-warn { color: var(--c-warning); }
.tc-stat-ok { color: #6FBF9A; }
.tc-stat-label {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.tc-cta {
  font-size: 24rpx;
  color: var(--c-primary-dark);
  font-weight: 600;
  text-align: right;
}

/* —— 段落标题 —— */
.section-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin: 32rpx 4rpx 16rpx;
}
.section-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.section-count {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  background: var(--c-card);
  padding: 2rpx 12rpx;
  border-radius: var(--r-pill);
}

/* —— 任务行 —— */
.task-row {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  transition: transform .15s;
}
.task-row:active { transform: scale(0.99); }

.task-row-left {
  flex: 1;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  min-width: 0;
}
.task-state-pill {
  font-size: var(--f-tiny);
  padding: 4rpx 12rpx;
  border-radius: var(--r-pill);
  font-weight: 500;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.task-state-collecting { background: rgba(34, 197, 94, 0.15); color: var(--c-primary-dark); }
.task-state-reviewing { background: rgba(242, 185, 98, 0.15); color: var(--c-warning); }
.task-state-published { background: rgba(107, 199, 133, 0.15); color: var(--c-success); }
.task-state-adjusting { background: rgba(232, 139, 139, 0.15); color: var(--c-danger); }

.task-row-body { flex: 1; min-width: 0; }
.task-row-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-row-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 6rpx;
}
.dot-sep { color: var(--c-text-3); }

.task-row-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}
.progress-bar {
  flex: 1;
  height: 8rpx;
  background: var(--c-divider);
  border-radius: var(--r-pill);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--c-primary);
  border-radius: var(--r-pill);
  transition: width .3s;
}
.progress-text {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}

.task-row-cta {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--f-cap);
  color: var(--c-primary-dark);
  font-weight: 500;
  flex-shrink: 0;
}

/* —— 新任务行（紧凑可视化） —— */
.tr-state {
  width: 6rpx;
  height: 64rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}
.tr-state-collecting { background: var(--c-primary); }
.tr-state-published { background: #6FBF9A; }
.tr-state-reviewing { background: #E89B4F; }
.tr-state-adjusting { background: #E88B8B; }
.tr-body {
  flex: 1;
  min-width: 0;
}
.tr-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.tr-title {
  font-size: var(--f-sm);
  font-weight: 600;
  color: var(--c-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tr-state-label {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--r-pill);
  font-weight: 500;
  flex-shrink: 0;
}
.tr-state-label-collecting { background: var(--c-primary-lighter); color: var(--c-primary-dark); }
.tr-state-label-published { background: rgba(107, 199, 133, 0.15); color: #4FA877; }
.tr-state-label-reviewing { background: rgba(232, 155, 79, 0.15); color: #C77F35; }
.tr-meta {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-bottom: 8rpx;
}
.tr-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.pr-bar {
  flex: 1;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: 3rpx;
  overflow: hidden;
}
.pr-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.3s;
}
.pr-fill-collecting { background: var(--c-primary); }
.pr-fill-published { background: var(--c-success); }
.pr-fill-reviewing { background: var(--c-warning); }
.pr-text {
  font-size: 20rpx;
  color: var(--c-text-3);
  font-weight: 500;
}
.tr-arrow {
  font-size: 32rpx;
  color: var(--c-text-3);
  flex-shrink: 0;
  margin-left: 8rpx;
  align-self: center;
}

/* —— 值班卡（简洁：当前 + 即将） —— */
.duty-card {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 12rpx;
  transition: transform .15s;
}
.duty-card:active { transform: scale(0.99); }

.dc-head {
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx dashed var(--c-divider);
}
.dc-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
  line-height: 1.3;
}
.dc-meta {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
}
.dc-remark {
  font-size: 22rpx;
  color: var(--c-text-2);
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  background: var(--c-bg);
  border-radius: var(--r-sm);
  line-height: 1.5;
}

/* 当前值班 / 即将值班 行 */
.dc-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}
.dc-row-current {
  background: var(--c-primary-lighter);
  border-radius: var(--r-sm);
  padding: 14rpx 16rpx;
  margin-bottom: 4rpx;
}
.dc-row-next {
  padding: 14rpx 16rpx;
}

.dcr-label {
  width: 130rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.dcr-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-primary);
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.20);
  margin-bottom: 4rpx;
}
.dcr-dot-next {
  background: var(--c-text-3);
  box-shadow: none;
}
.dcr-label > text {
  font-size: 22rpx;
  color: var(--c-text-2);
  font-weight: 600;
  line-height: 1.2;
}
.dc-row-current .dcr-label > text {
  color: var(--c-primary-dark);
}
.dcr-period {
  font-size: 20rpx !important;
  color: var(--c-text-3) !important;
  font-weight: 500 !important;
  letter-spacing: 0.3rpx;
}

.dcr-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.dcr-name {
  font-size: 32rpx;
  color: var(--c-text);
  font-weight: 700;
  line-height: 1.2;
}
.dcr-name-next {
  font-size: 28rpx;
  color: var(--c-text);
  font-weight: 600;
}
.dcr-phone {
  font-size: 26rpx;
  color: var(--c-primary-dark);
  letter-spacing: 1rpx;
  line-height: 1.3;
  font-weight: 500;
}
.dc-row-next .dcr-phone {
  color: var(--c-text-3);
  font-weight: 400;
}

.dcr-empty {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: var(--c-text-3);
}

/* —— 新即将排班卡（紧凑） —— */
.uc-dots {
  display: flex;
  gap: 4rpx;
  flex-shrink: 0;
}
.uc-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--c-divider);
}
.uc-dot-active {
  background: var(--c-primary);
}

/* —— 详情弹层新样式 —— */
.si-period {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.si-period-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--c-text);
}
.si-period-state {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--r-pill);
}
.si-state-published { background: rgba(107, 199, 133, 0.15); color: #4FA877; }
.si-state-pending { background: rgba(232, 155, 79, 0.15); color: #C77F35; }
.si-state-objection { background: rgba(232, 139, 139, 0.15); color: #C77; }
.si-main {
  background: var(--c-bg);
  border-radius: var(--r-md);
  padding: 12rpx 16rpx;
}
.si-group {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-bottom: 8rpx;
}
.si-people {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.si-member {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.avatar-color-1 { background: var(--c-primary); }
.avatar-color-2 { background: #6FBF9A; }
.avatar-color-3 { background: #E89B4F; }
.avatar-color-4 { background: #B895D5; }
.si-member-info {
  display: flex;
  flex-direction: column;
}
.si-member-name {
  font-size: 22rpx;
  color: var(--c-text);
  font-weight: 500;
}
.si-member-phone {
  font-size: 18rpx;
  color: var(--c-text-3);
}
.si-action {
  font-size: 22rpx;
  color: #C77;
  background: rgba(232, 139, 139, 0.12);
  padding: 6rpx 16rpx;
  border-radius: var(--r-pill);
  margin-top: 8rpx;
  align-self: flex-end;
}

/* 空状态 */
.ds-empty {
  padding: 40rpx 0;
  text-align: center;
}
.ds-empty-ico {
  font-size: 56rpx;
  color: var(--c-text-3);
  opacity: 0.5;
}
.ds-empty-text {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 8rpx;
}
.task-row-arrow { font-size: 32rpx; line-height: 1; }

.empty-inline {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 60rpx 0;
  color: var(--c-text-3);
  font-size: var(--f-cap);
}
.empty-icon-sm {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-primary);
}

/* —— 即将排班 —— */
.upcoming-card {
  background: var(--c-card);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-card);
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
}
.upcoming-date {
  width: 96rpx;
  text-align: center;
  background: var(--c-primary-lightest);
  border-radius: var(--r-md);
  padding: 16rpx 0;
  flex-shrink: 0;
}
.upcoming-day {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--c-primary-dark);
  line-height: 1;
}
.upcoming-mon {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 6rpx;
}
.upcoming-body { flex: 1; min-width: 0; }
.upcoming-title {
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.upcoming-meta {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.upcoming-periods {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

/* —— 详情卡 —— */
.day-detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(26, 43, 60, 0.36);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.day-detail-sheet {
  width: 100%;
  background: var(--c-card);
  border-radius: var(--r-xl) var(--r-xl) 0 0;
  padding: 24rpx var(--s-md) calc(env(safe-area-inset-bottom) + 32rpx);
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp .25s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 64rpx;
  height: 6rpx;
  background: var(--c-divider);
  border-radius: var(--r-pill);
  margin: 0 auto 20rpx;
}
.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.sheet-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.sheet-sub {
  font-size: var(--f-cap);
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-divider);
  color: var(--c-text-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.schedule-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-divider);
}
.schedule-item:last-child { border-bottom: none; }
.schedule-period {
  width: 140rpx;
  font-size: var(--f-cap);
  color: var(--c-primary-dark);
  font-weight: 500;
  flex-shrink: 0;
}
.schedule-main { flex: 1; min-width: 0; }
.schedule-group {
  font-size: var(--f-body);
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 12rpx;
}
.schedule-people {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.schedule-member {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.schedule-member-info { display: flex; flex-direction: column; }
.schedule-member-name {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
}
.schedule-member-phone {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.schedule-action {
  font-size: var(--f-cap);
  color: var(--c-danger);
  background: rgba(232, 139, 139, 0.10);
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  align-self: center;
}

.bottom-spacer { height: 100rpx; }

/* —— 日历 UI 增强 —— */
/* 月份概览卡渐变光晕 */
.month-stat {
  position: relative;
  overflow: hidden;
}
.month-stat::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: transparent;
  border-radius: 50%;
  pointer-events: none;
}

/* 日历卡片增强阴影 */
.cal-card {
  position: relative;
  background: var(--c-primary-lighter) 0%, #FAFCFE 100%);
}

/* 今日格子增强：脉冲动画 */
.cal-cell-today {
  outline: 3rpx solid var(--c-primary);
  outline-offset: -3rpx;
  position: relative;
}
.cal-cell-today::after {
  content: '';
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--c-primary);
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.3);
  animation: todayPulse 1.6s ease-in-out infinite;
}
@keyframes todayPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.7; }
}

/* 选中日期增强 */
.cal-cell-selected {
  outline: 3rpx solid var(--c-primary-dark);
  outline-offset: -3rpx;
  background: var(--c-primary-lighter) !important;
}

/* 热力等级增强：更柔和过渡 */
.cal-cell {
  transition: background .2s, transform .15s;
}
.cal-cell:active {
  transform: scale(0.92);
  background: var(--c-primary-lightest);
}

/* 热力色更精致 */
.heat-0 { background: transparent; }
.heat-1 { background: var(--c-primary-lighter); }
.heat-2 { background: var(--c-primary-light); }
.heat-3 {
  background: var(--c-primary);
  box-shadow: inset 0 0 0 1rpx rgba(91, 175, 218, 0.3);
}

/* 任务行增强：悬停感 */
.task-row {
  position: relative;
  overflow: hidden;
}
.task-row::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: var(--c-primary);
  opacity: 0;
  transition: opacity .2s;
}
.task-row:active::before {
  opacity: 1;
}

/* 即将排班卡增强 */
.upcoming-card {
  position: relative;
  overflow: hidden;
  transition: transform .15s;
}
.upcoming-card:active { transform: scale(0.98); }
.upcoming-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: var(--c-primary-lighter), var(--c-primary));
}

/* 详情弹层增强 */
.day-detail-sheet {
  background: var(--c-primary-lighter) 0%, #FAFCFE 100%);
  box-shadow: 0 -8rpx 32rpx rgba(34, 197, 94, 0.18);
}

/* 时段卡增强 */
.schedule-item {
  background: var(--c-primary-lightest);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--c-border);
}
.schedule-item:last-child {
  margin-bottom: 0;
}

/* 浮动按钮增强动画 */
.fab {
  animation: fabFloat 3s ease-in-out infinite;
}
@keyframes fabFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

/* 分组筛选增强 */
.gf-chip {
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
.gf-chip:active {
  transform: scale(0.95);
}

/* 章节标题增强 */
.section-head {
  position: relative;
  padding-left: 16rpx;
}
/* 章节标题增强 */
.section-head::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 28rpx;
  background: var(--c-primary-lighter), var(--c-primary-dark));
  border-radius: 2rpx;
}

/* —— 视图模式分段控制（周视图左列模式切换） —— */
.seg-ctrl {
  display: flex;
  background: var(--c-card);
  border-radius: var(--r-pill);
  padding: 6rpx;
  margin: 12rpx 0 4rpx;
  box-shadow: var(--shadow-card);
}
.seg-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--c-text-2);
  padding: 14rpx 0;
  border-radius: var(--r-pill);
  transition: all 0.15s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.seg-active {
  background: var(--c-primary);
  color: var(--c-text-inv);
  font-weight: 600;
}

/* —— 周视图导航 —— */
.wk-nav {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
}
.wk-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--c-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--c-text-2);
}
.wk-arrow:active { background: var(--c-primary-lighter); color: var(--c-primary-dark); }
.wk-label {
  font-size: 22rpx;
  color: var(--c-text-3);
  min-width: 220rpx;
  text-align: center;
}
.wk-today {
  font-size: 22rpx;
  color: var(--c-primary-dark);
  padding: 4rpx 14rpx;
  background: var(--c-primary-lighter);
  border-radius: var(--r-pill);
}

