/* pages/cal-edit-period/cal-edit-period.wxss —— 节次日历编辑页 */
@import "/pages/cal-edit-time/cal-edit-time.wxss";

/* 节次特有：左侧显示节次名 */
.ct-period {
  font-size: 22rpx;
  color: var(--c-text);
  font-weight: 500;
}
.ct-time {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 2rpx;
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-pill);
  padding: 4rpx 8rpx;
}
.sp-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.sp-val {
  font-size: var(--f-sm);
  color: var(--c-text);
  font-weight: 600;
  min-width: 40rpx;
  text-align: center;
}

/* 节次配置列表 */
.period-list {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--c-bg);
  border-radius: var(--r-md);
}
.pl-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.pl-name {
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
}
.pl-time {
  font-size: 22rpx;
  color: var(--c-text-3);
  font-family: monospace;
}
