<view class="page-pad" wx:if="{{!loading && group}}">
  <view class="card group-head">
    <view class="gh-name">{{group.name}}</view>
    <view class="text-2 small mt-8" wx:if="{{group.description}}">{{group.description}}</view>
    <view class="gh-stats flex gap-12 mt-16">
      <view class="stat"><text class="stat-n">{{members.length}}</text><text class="text-2 tiny">成员</text></view>
      <view class="stat"><text class="stat-n">{{taskList.length}}</text><text class="text-2 tiny">任务</text></view>
      <view class="stat"><text class="stat-n sm">{{group.myRole === 'publisher' || group.myRole === 'owner' ? '发布者' : '成员'}}</text><text class="text-2 tiny">我的角色</text></view>
    </view>
  </view>

  <view class="section-bar flex-between">
    <view class="sec-title">排班任务</view>
    <button wx:if="{{isPublisher}}" class="btn btn-primary btn-sm" bindtap="openCreate">＋ 新建</button>
  </view>

  <view wx:if="{{taskList.length === 0}}" class="empty"><view class="emoji">📋</view><view>暂无排班任务</view></view>
  <view wx:else class="gap-12">
    <task-card wx:for="{{taskList}}" wx:key="id" task="{{item}}" bind:tap="onTaskTap" />
  </view>

  <view class="section-bar flex-between mt-16">
    <view class="sec-title">成员 ({{members.length}})</view>
    <view class="text-2 small" bindtap="toggleMembers">{{showMembers ? '收起' : '展开'}}</view>
  </view>
  <view wx:if="{{showMembers}}" class="card mt-8">
    <view class="member" wx:for="{{members}}" wx:key="userId">
      <image wx:if="{{item.avatar}}" class="m-avatar" src="{{item.avatar}}" mode="aspectFill" />
      <view wx:else class="m-avatar m-initial">{{item.name[0]}}</view>
      <view class="m-info">
        <view class="m-name">{{item.name}}
          <text class="tag tag-muted" wx:if="{{item.role === 'publisher' || item.role === 'owner'}}">发布者</text>
        </view>
        <view class="text-3 tiny">{{item.phoneMasked || ''}}</view>
      </view>
      <view wx:if="{{isPublisher && item.role !== 'publisher' && item.role !== 'owner'}}" class="m-kick" data-uid="{{item.userId}}" bindtap="onKick">移出</view>
    </view>
  </view>

  <button wx:if="{{!isPublisher}}" class="btn btn-line btn-block mt-16" bindtap="onLeave">退出分组</button>
</view>

<view wx:if="{{loading}}" class="loading">加载中…</view>

<!-- 新建任务：mode + 基础作息模板（非硬编码钟点） -->
<view wx:if="{{showCreate}}" class="mask" bindtap="closeCreate">
  <view class="sheet sheet-tall" catchtap="noop">
    <view class="sheet-title">新建排班任务</view>
    <input class="field" placeholder="任务标题（如：下周值班）" value="{{taskForm.title}}" data-field="title" bindinput="onTaskInput" />
    <textarea class="field area" placeholder="说明（选填）" value="{{taskForm.description}}" data-field="description" bindinput="onTaskInput" />

    <view class="field-label text-2 small">排班日期范围</view>
    <view class="range-row">
      <picker mode="date" value="{{taskForm.dateRangeStart}}" bindchange="onRangeStartChange">
        <view class="field picker flex-1">起 {{taskForm.dateRangeStart || '选择'}}</view>
      </picker>
      <text class="range-sep">至</text>
      <picker mode="date" value="{{taskForm.dateRangeEnd}}" bindchange="onRangeEndChange">
        <view class="field picker flex-1">止 {{taskForm.dateRangeEnd || '选择'}}</view>
      </picker>
    </view>

    <picker mode="date" value="{{taskForm.deadline}}" bindchange="onDeadlineChange">
      <view class="field picker">收集截止：{{taskForm.deadline || '请选择'}}</view>
    </picker>

    <view class="field-label text-2 small">展示方式</view>
    <picker mode="selector" range="{{modeOptions}}" range-key="name" value="{{modeIndex}}" bindchange="onModeChange">
      <view class="field picker">{{modeOptions[modeIndex].name}}</view>
    </picker>
    <view class="text-3 tiny tpl-desc">{{modeOptions[modeIndex].desc}}</view>

    <view class="field-label text-2 small">基础作息模板</view>
    <picker mode="selector" range="{{profileOptions}}" range-key="name" value="{{profileIndex}}" bindchange="onProfileChange">
      <view class="field picker">
        {{profileOptions[profileIndex].name || '加载中…'}}
        <text wx:if="{{profileOptions[profileIndex]}}"> · {{profileOptions[profileIndex].slots.length}} 段</text>
      </view>
    </picker>
    <view class="text-3 tiny tpl-desc">{{profileOptions[profileIndex].description || '来自系统众数种子，可在运维端修改'}}</view>

    <scroll-view scroll-x class="period-preview" enable-flex>
      <view class="period-chip" wx:for="{{previewPeriods}}" wx:key="id">
        <view class="pc-name">{{item.name}}</view>
        <view class="pc-time text-3 tiny" wx:if="{{item.start}}">{{item.start}}-{{item.end}}</view>
      </view>
    </scroll-view>

    <button class="btn btn-primary btn-block mt-16" loading="{{submitting}}" bindtap="submitTask">创建</button>
    <button class="btn btn-ghost btn-block mt-8" bindtap="closeCreate">取消</button>
  </view>
</view>
