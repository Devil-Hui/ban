/* pages/task-create/task-create.wxss —— 新建任务样式 */

.page-tc {
  min-height: 100vh;
  padding: var(--s-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  box-sizing: border-box;
  background: var(--c-bg);
}

/* 模板时段预览条 */
.period-preview-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin: 12rpx 0 20rpx;
  padding-bottom: 8rpx;
}
.period-chip-preview {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 14rpx 16rpx;
  margin-right: 12rpx;
  background: rgba(126, 200, 227, 0.15);
  border-radius: 12rpx;
  color: var(--c-primary-dark, #3a7a94);
}
.pcp-name { font-size: 24rpx; font-weight: 600; line-height: 1.2; }
.pcp-time { font-size: 20rpx; margin-top: 4rpx; opacity: 0.9; }
.period-readonly-hint {
  font-size: 22rpx;
  color: var(--c-text-3, #9CA8B5);
  line-height: 1.5;
  padding: 8rpx 0 4rpx;
}
.btn-disabled { opacity: 0.55; pointer-events: none; }
.picker-block { min-height: 72rpx; display: flex; align-items: center; }

/* —— 顶部 Hero —— */
.tc-hero {
  position: relative;
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: var(--s-md);
  overflow: hidden;
}
.tc-hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #B8DDE9 0%, #7EC8E3 100%);
}
.hero-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--r-md);
  background: linear-gradient(135deg, #7EC8E3 0%, #5BAFDA 100%);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(126, 200, 227, 0.35);
}
.hero-body { flex: 1; min-width: 0; }
.hero-title {
  font-size: var(--f-sub);
  font-weight: 600;
  color: var(--c-text);
}
.hero-desc {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.hero-group {
  text-align: right;
  flex-shrink: 0;
}
.hg-label {
  display: block;
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.hg-name {
  font-size: var(--f-cap);
  color: var(--c-primary-dark);
  font-weight: 500;
  margin-top: 4rpx;
  display: block;
}

/* —— 步骤 —— */
.stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--c-card);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: var(--s-md);
  box-shadow: var(--shadow-card);
}
.step {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}
.step-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--c-divider);
  color: var(--c-text-3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.step-done .step-num {
  background: var(--c-primary-lighter);
  color: var(--c-primary-dark);
}
.step-current .step-num {
  background: var(--c-primary);
  color: var(--c-text-inv);
}
.step-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  font-weight: 500;
}
.step-current .step-label,
.step-done .step-label {
  color: var(--c-text);
}

/* —— 段落卡 —— */
.section-card {
  background: var(--c-card);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-card);
  padding: 0;
  margin-bottom: var(--s-md);
  overflow: hidden;
}
.section-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--c-divider);
}
.sh-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
}
.sh-title {
  flex: 1;
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.sh-optional {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.sh-action {
  font-size: var(--f-cap);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
}
.section-body { padding: 24rpx; }

/* —— 字段 —— */
.field { margin-bottom: 24rpx; }
.field:last-child { margin-bottom: 0; }
.field-label {
  font-size: var(--f-cap);
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 12rpx;
}
.req { color: var(--c-danger); }
.opt { color: var(--c-text-3); font-weight: 400; }
.field-hint {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  margin-top: 8rpx;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--c-primary-lightest);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  font-size: var(--f-body);
  color: var(--c-text);
  box-sizing: border-box;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.field-cell { display: flex; flex-direction: column; }

.picker-value {
  background: var(--c-primary-lightest);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  font-size: var(--f-body);
  color: var(--c-text);
}
.picker-block { margin-top: 12rpx; }

/* —— 循环规则 —— */
.cycle-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.cycle-chip {
  height: 64rpx;
  padding: 0 24rpx;
  background: var(--c-primary-lightest);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--f-cap);
  color: var(--c-text-2);
  transition: all .15s;
}
.cycle-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
  font-weight: 600;
}

/* —— 时段 —— */
.period-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: rgba(126, 200, 227, 0.08);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  line-height: 1.5;
}
.tip-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-text-inv);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.period-row {
  background: var(--c-primary-lightest);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}
.period-row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.period-row-label {
  font-size: var(--f-tiny);
  color: var(--c-text-2);
  font-weight: 500;
}
.period-row-del {
  font-size: var(--f-tiny);
  color: var(--c-danger);
}
.period-row-body {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.time-picker {
  background: var(--c-card);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-sm);
  padding: 14rpx 20rpx;
  font-size: var(--f-cap);
  color: var(--c-text);
  font-weight: 500;
}
.time-sep { color: var(--c-text-3); }
.period-preview { margin-left: auto; }

.period-template-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.ptr-label {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
}
.ptr-chips {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.ptr-chip {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-primary-lighter);
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  transition: all 0.15s ease;
}
.ptr-chip:active { transform: scale(0.94); }
.ptr-chip-danger {
  color: #C77;
  background: rgba(232, 139, 139, 0.12);
}

/* —— 自定义循环周次 —— */
.custom-cycle {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--c-primary-lighter);
  border-radius: var(--r-md);
  border: 1rpx dashed rgba(126, 200, 227, 0.6);
}
.cc-title {
  font-size: var(--f-cap);
  color: var(--c-text-2);
  margin-bottom: 12rpx;
}
.cc-weeks {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.cc-week {
  flex: 0 0 auto;
  min-width: 120rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  padding: 0 20rpx;
  background: var(--c-card);
  color: var(--c-text-2);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-sm);
  font-size: var(--f-cap);
}
.cc-week-active {
  background: var(--c-primary);
  color: var(--c-text-inv);
  border-color: var(--c-primary-dark);
  font-weight: 600;
}
.cc-summary {
  margin-top: 12rpx;
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-card);
  padding: 8rpx 12rpx;
  border-radius: var(--r-sm);
}

/* —— 计数器 —— */
.counter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--c-primary-lightest);
  border-radius: var(--r-md);
  padding: 8rpx;
}
.counter-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--r-sm);
  background: var(--c-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--c-text);
  font-weight: 600;
}
.counter-btn:active { background: var(--c-primary-lighter); }
.counter-btn.disabled { opacity: 0.4; }
.counter-value {
  flex: 1;
  text-align: center;
  font-size: var(--f-body);
  font-weight: 600;
  color: var(--c-text);
}
.counter-unit {
  font-size: var(--f-tiny);
  color: var(--c-text-3);
  padding-right: 8rpx;
}
.counter-clear {
  font-size: var(--f-tiny);
  color: var(--c-primary-dark);
  background: var(--c-card);
  padding: 12rpx 16rpx;
  border-radius: var(--r-sm);
}

/* —— 截止时间 —— */
.deadline-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.dl-chip {
  height: 64rpx;
  padding: 0 24rpx;
  background: var(--c-primary-lightest);
  border: 1rpx solid var(--c-border);
  border-radius: var(--r-pill);
  display: flex;
  align-items: center;
  font-size: var(--f-cap);
  color: var(--c-text-2);
  transition: all .15s;
}
.dl-active {
  background: var(--c-primary-lighter);
  border-color: var(--c-primary);
  color: var(--c-primary-dark);
  font-weight: 600;
}

/* —— 摘要 —— */
.summary-card {
  background: linear-gradient(135deg, rgba(126, 200, 227, 0.08) 0%, rgba(184, 221, 233, 0.18) 100%);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-bottom: var(--s-md);
}
.sc-title {
  font-size: var(--f-cap);
  font-weight: 600;
  color: var(--c-primary-dark);
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}
.sc-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: var(--f-cap);
}
.sc-label { color: var(--c-text-2); }
.sc-value { color: var(--c-text); font-weight: 500; }

/* —— 底部 —— */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx var(--s-md) calc(env(safe-area-inset-bottom) + 16rpx);
  background: var(--c-card);
  box-shadow: 0 -4rpx 20rpx rgba(126, 200, 227, 0.12);
  z-index: 50;
}
