<!-- pages/index/index.wxml —— 1:1 对齐设计板「1.首页」 -->
<view class="page-home page-with-tab">
  <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

  <!-- 顶栏：智能排班 + 头像 -->
  <view class="topbar">
    <view class="brand-row">
      <view class="brand-logo">
        <view class="brand-logo-grid"></view>
      </view>
      <text class="brand-title">智能排班</text>
    </view>
    <view class="avatar" bindtap="goProfile" hover-class="tap-dim">{{user.initial}}</view>
  </view>

  <!-- 全宽主按钮：创建分组（设计板） -->
  <view class="btn-create" bindtap="onCreateGroup" hover-class="btn-create-hover">
    <text class="btn-create-plus">+</text>
    <text class="btn-create-text">创建分组</text>
  </view>

  <!-- 数据卡片列表（设计板：左色块图标 + 标题副文案 + 右侧份数/角标） -->
  <view class="list-area">
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="skeleton" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>

    <block wx:else>
      <!-- 有分组：每组一张数据卡 -->
      <view
        wx:for="{{cards}}"
        wx:key="id"
        class="data-card"
        data-type="{{item.type}}"
        data-id="{{item.id}}"
        data-task-id="{{item.taskId}}"
        bindtap="onCardTap"
        hover-class="data-card-hover"
      >
        <view class="data-icon data-icon-{{item.tone}}">{{item.iconText}}</view>
        <view class="data-mid">
          <view class="data-title">{{item.title}}</view>
          <view class="data-desc">{{item.desc}}</view>
        </view>
        <view wx:if="{{item.badge}}" class="data-badge data-badge-{{item.badgeTone || 'green'}}">{{item.badge}}</view>
        <view wx:elif="{{item.count != null}}" class="data-count">
          <text class="data-count-num">{{item.count}}</text>
          <text class="data-count-unit">{{item.unit || '份'}}</text>
        </view>
        <text wx:else class="data-arrow">›</text>
      </view>

      <!-- 空态（设计板 08） -->
      <view wx:if="{{cards.length === 0}}" class="empty-box">
        <view class="empty-ico">📋</view>
        <view class="empty-title">暂无分组</view>
        <view class="empty-desc">还没有创建或加入任何分组</view>
        <view class="empty-actions">
          <view class="empty-btn primary" bindtap="onCreateGroup">去创建</view>
          <view class="empty-btn" bindtap="goJoin">去邀请</view>
        </view>
      </view>
    </block>
  </view>

  <view class="safe-bottom"></view>
</view>
