/* pages/index/index.wxss —— 设计板「1.首页」1:1 视觉 */
.page-home {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 32rpx;
  background: #F8FAFC;
  color: #111827;
}

.status-bar { width: 100%; }

/* —— 顶栏 —— */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 28rpx;
}
.brand-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.brand-logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #22C55E;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 94, 0.35);
  position: relative;
  overflow: hidden;
}
/* 小日历格纹理，贴近设计板 logo */
.brand-logo-grid {
  width: 30rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background:
    linear-gradient(#fff 1.5rpx, transparent 1.5rpx) 0 0 / 100% 33%,
    linear-gradient(90deg, #fff 1.5rpx, transparent 1.5rpx) 0 0 / 33% 100%;
  opacity: 0.9;
}
.brand-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
  letter-spacing: 0.5rpx;
}
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #DCFCE7;
  color: #16A34A;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tap-dim { opacity: 0.85; }

/* —— 创建分组 全宽绿钮（设计板核心） —— */
.btn-create {
  height: 96rpx;
  border-radius: 20rpx;
  background: #22C55E;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(34, 197, 94, 0.32);
  margin-bottom: 28rpx;
}
.btn-create-hover {
  background: #16A34A;
  transform: scale(0.99);
}
.btn-create-plus {
  font-size: 40rpx;
  font-weight: 400;
  color: #fff;
  line-height: 1;
  margin-top: -4rpx;
}
.btn-create-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* —— 数据卡片列表 —— */
.list-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.data-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F3F4F6;
  min-height: 120rpx;
  box-sizing: border-box;
}
.data-card-hover {
  background: #F9FAFB;
}

.data-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}
/* 设计板卡片色：橙 / 绿 / 蓝 */
.data-icon-orange {
  background: #FFEDD5;
  color: #EA580C;
}
.data-icon-green {
  background: #DCFCE7;
  color: #16A34A;
}
.data-icon-blue {
  background: #DBEAFE;
  color: #2563EB;
}
.data-icon-amber {
  background: #FEF3C7;
  color: #D97706;
}

.data-mid {
  flex: 1;
  min-width: 0;
}
.data-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.data-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧「3 份」样式（设计板） */
.data-count {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding-left: 8rpx;
}
.data-count-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}
.data-count-unit {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.data-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}
.data-badge-green {
  background: #DCFCE7;
  color: #16A34A;
}
.data-badge-orange {
  background: #FFEDD5;
  color: #EA580C;
}
.data-badge-blue {
  background: #DBEAFE;
  color: #2563EB;
}
.data-arrow {
  color: #D1D5DB;
  font-size: 32rpx;
  font-weight: 300;
  padding: 0 4rpx;
}

/* 空态 */
.empty-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 56rpx 32rpx 48rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F3F4F6;
}
.empty-ico {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  opacity: 0.85;
}
.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}
.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
.empty-actions {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
}
.empty-btn {
  height: 72rpx;
  padding: 0 32rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E5E7EB;
  background: #fff;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}
.empty-btn.primary {
  background: #22C55E;
  border-color: #22C55E;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(34, 197, 94, 0.28);
}

/* skeleton */
.loading-wrap { display: flex; flex-direction: column; gap: 16rpx; }
.skeleton {
  height: 120rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s ease infinite;
}
@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.safe-bottom {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
