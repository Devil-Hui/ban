<view class="sv">
  <view class="sv-row sv-head">
    <view class="sv-cell sv-date">日期</view>
    <view class="sv-cell sv-period" wx:for="{{columns}}" wx:key="id">
      <view class="sv-ptitle">{{item.title}}</view>
      <view class="sv-psub text-3 tiny" wx:if="{{item.sub}}">{{item.sub}}</view>
    </view>
  </view>

  <view class="sv-row" wx:for="{{rows}}" wx:key="date">
    <view class="sv-cell sv-date">
      <view class="sv-d">{{item.date}}</view>
      <view class="sv-w text-3 tiny">{{item.weekday}}</view>
    </view>
    <view class="sv-cell sv-body" wx:for="{{columns}}" wx:for-item="col" wx:key="id">
      <block wx:if="{{item.cells[col.id] && item.cells[col.id].length > 0}}">
        <view class="sv-user" wx:for="{{item.cells[col.id]}}" wx:for-item="u" wx:key="id">
          <image wx:if="{{u.avatar}}" class="sv-avatar" src="{{u.avatar}}" mode="aspectFill" />
          <text wx:else class="sv-initial">{{u.name[0]}}</text>
          <text class="sv-uname ellipsis">{{u.name}}</text>
        </view>
      </block>
      <view class="sv-empty text-3 tiny" wx:else>—</view>
    </view>
  </view>
</view>
