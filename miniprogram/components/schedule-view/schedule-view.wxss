.sv {
  background: var(--c-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.sv-row {
  display: flex;
  align-items: stretch;
  border-bottom: 2rpx solid var(--c-border);
}
.sv-row:last-child { border-bottom: none; }

.sv-head {
  background: var(--c-primary-soft);
  color: var(--c-primary);
  font-size: 24rpx;
  font-weight: 600;
}
.sv-head .sv-cell { padding: 14rpx 6rpx; }
.sv-period { min-width: 0; }
.sv-ptitle { font-size: 22rpx; line-height: 1.2; font-weight: 600; }
.sv-psub { margin-top: 4rpx; line-height: 1.2; opacity: 0.85; white-space: nowrap; }

.sv-cell {
  flex: 1;
  padding: 16rpx 8rpx;
  text-align: center;
  border-right: 2rpx solid var(--c-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.sv-cell:last-child { border-right: none; }

.sv-date {
  flex: 0 0 120rpx;
  background: #FBFCFE;
}
.sv-d { font-size: 26rpx; font-weight: 600; color: var(--c-text); }
.sv-w { margin-top: 2rpx; }

.sv-user {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
}
.sv-avatar {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: var(--c-primary-soft); flex-shrink: 0;
}
.sv-initial {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: var(--c-primary-light); color: var(--c-primary);
  font-size: 22rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.sv-uname { font-size: 22rpx; color: var(--c-text); max-width: 90rpx; }
.sv-empty { padding: 14rpx 0; }
