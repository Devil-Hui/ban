.grp-card {
  background: var(--c-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
  padding: 28rpx;
}
.grp-card:active { background: #FAFBFC; }

.grp-head { display: flex; align-items: center; }
.grp-avatar {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  background: var(--c-primary-soft);
  color: var(--c-primary);
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; font-weight: 600; margin-right: 22rpx; flex-shrink: 0;
}
.grp-meta { flex: 1; min-width: 0; }
.grp-name { font-size: 32rpx; font-weight: 600; color: var(--c-text); }
.grp-sub { margin-top: 6rpx; }
.grp-desc { margin-top: 18rpx; line-height: 1.5; }
